      "html": "\n<section class=\"flex h-screen bg-[#0F1115] text-[#F7F5F2] overflow-hidden font-sans selection:bg-[#076653]/30\" data-kid=\"0\">\n    \n    <aside class=\"w-72 bg-[#171A20] border-r border-white/5 flex flex-col z-30 relative\" data-kid=\"1\">\n        <div class=\"p-8 pb-4\" data-kid=\"2\">\n            <h1 class=\"font-serif text-3xl text-[#076653] tracking-tight flex items-center gap-2\" data-kid=\"3\">\n                <span class=\"w-8 h-8 rounded-lg bg-[#076653]/10 flex items-center justify-center border border-[#076653]/20\" data-kid=\"4\">\n                    <i class=\"ti ti-brand-framer text-xl\" data-kid=\"5\"></i>\n                </span>\n                Fingo AI\n            </h1>\n        </div>\n        \n        <nav class=\"flex-1 px-4 space-y-1.5 mt-8 overflow-y-auto custom-scrollbar\" data-kid=\"6\">\n            <div class=\"px-4 mb-2 text-[10px] font-bold uppercase tracking-[0.2em] text-white/20\" data-kid=\"7\">Menu</div>\n            <a href=\"#\" class=\"nav-link flex items-center gap-3 px-4 py-3 rounded-xl text-white/40 hover:text-white hover:bg-white/5 group transition-colors\" data-kid=\"8\">\n                <i class=\"ti ti-layout-dashboard text-xl group-hover:text-[#076653]\" data-kid=\"9\"></i>\n                <span class=\"font-medium text-sm\" data-kid=\"10\">Dashboard</span>\n            </a>\n            <a href=\"#\" class=\"nav-link flex items-center gap-3 px-4 py-3 rounded-xl bg-[#076653]/10 text-[#076653] border border-[#076653]/20 shadow-lg shadow-[#076653]/5\" data-kid=\"11\">\n                <i class=\"ti ti-receipt text-xl\" data-kid=\"12\"></i>\n                <span class=\"font-medium text-sm\" data-kid=\"13\">Transactions</span>\n            </a>\n            <a href=\"#\" class=\"nav-link flex items-center gap-3 px-4 py-3 rounded-xl text-white/40 hover:text-white hover:bg-white/5 group transition-colors\" data-kid=\"14\">\n                <i class=\"ti ti-chart-dots text-xl group-hover:text-[#076653