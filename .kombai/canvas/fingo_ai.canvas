      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Cormorant+Garamond:wght@600&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/geist-font@1.1.0/dist/geist.css');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n  @import url('https://unpkg.com/lenis@1/dist/lenis.css');\n\n  :root {\n    --bg-void: #0F1115;\n    --sidebar-base: #171A20;\n    --emerald-accent: #076653;\n    --emerald-glow: #0F8A6B;\n    --amber-cta: #FF812B;\n    --white-soft: rgba(255, 255, 255, 0.9);\n  }\n\n  body {\n    margin: 0;\n    padding: 0;\n    background-color: var(--bg-void);\n    color: var(--white-soft);\n    font-family: 'Inter', sans-serif;\n    overflow-x: clip;\n  }\n\n  .font-geist { font-family: 'Geist', sans-serif; }\n  .font-cormorant { font-family: 'Cormorant Garamond', serif; }\n\n  /* Premium Panel utility */\n  .premium-panel {\n    background: #171A20;\n    border: 1px solid rgba(255, 255, 255, 0.08);\n    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.4);\n  }\n\n  .glass-sidebar {\n    background: #111418;\n    border-right: 1px solid rgba(255, 255, 255, 0.05);\n  }\n\n  /* Custom scrollbar for webkit */\n  ::-webkit-scrollbar {\n    width: 6px;\n  }\n  ::-webkit-scrollbar-track {\n    background: transparent;\n  }\n  ::-webkit-scrollbar-thumb {\n    background: rgba(255, 255, 255, 0.1);\n    border-radius: 10px;\n  }\n  ::-webkit-scrollbar-thumb:hover {\n    background: rgba(255, 255, 255, 0.2);\n  }\n\n  /* Animations classes */\n  .processing-shimmer {\n    background: linear-gradient(90deg, transparent, rgba(255, 129, 43, 0.1), transparent);\n    background-size: 200% 100%;\n    animation: shimmer 2s infinite;\n  }\n\n  @keyframes shimmer {\n    0% { background-position: -200% 0; }\n    100% { background-position: 200% 0; }\n  }\n\n  .active-nav {\n    background: linear-gradient(90deg, rgba(7, 102, 83, 0.2) 0%, transparent 100%);\n    border-left: 3px solid var(--emerald-accent);\n  }\n</style>\n\n<div class=\"flex h-screen overflow-hidden bg-[var(--bg-void)]\" data-kid=\"1\">\n  \n  <aside class=\"w-20 lg:w-64 glass-sidebar flex flex-col z-50\" data-kid=\"2\">\n    <div class=\"p-6 flex items-center gap-3\" data-kid=\"3\">\n      <div class=\"w-10 h-10 bg-emerald-500 rounded-xl flex items-center justify-center shadow-lg shadow-emerald-500/20\" data-kid=\"4\">\n        <i class=\"ti ti-currency-bitcoin text-white text-2xl\" data-kid=\"5\"></i>\n      </div>\n      <span class=\"text-2xl font-cormorant font-bold hidden lg:block tracking-tight\" data-kid=\"6\">Fingo AI</span>\n    </div>\n\n    <nav class=\"flex-1 mt-6 px-4 space-y-1\" data-kid=\"7\">\n      <div class=\"group flex items-center gap-4 p-3.5 rounded-xl hover:bg-white/5 transition-colors cursor-pointer\" data-kid=\"8\">\n        <i class=\"ti ti-smart-home text-xl text-white/30 group-hover:text-emerald-400 transition-colors\" data-kid=\"9\"></i>\n        <span class=\"hidden lg:block text-sm font-semibold text-white/50 group-hover:text-white\" data-kid=\"10\">Overview</span>\n      </div>\n      <div class=\"group flex items-center gap-4 p-3.5 rounded-xl hover:bg-white/5 transition-colors cursor-pointer\" data-kid=\"11\">\n        <i class=\"ti ti-receipt-2 text-xl text-white/30 group-hover:text-emerald-400 transition-colors\" data-kid=\"12\"></i>\n        <span class=\"hidden lg:block text-sm font-semibold text-white/50 group-hover:text-white\" data-kid=\"13\">Transactions</span>\n      </div>\n      <div class=\"group active-nav flex items-center gap-4 p-3.5 rounded-xl cursor-pointer\" data-kid=\"14\">\n        <i class=\"ti ti-folder text-xl text-emerald-400\" data-kid=\"15\"></i>\n        <span class=\"hidden lg:block text-sm font-bold text-white\" data-kid=\"16\">Documents</span>\n      </div>\n      <div class=\"group flex items-center gap-4 p-3.5 rounded-xl hover:bg-white/5 transition-colors cursor-pointer\" data-kid=\"17\">\n        <i class=\"ti ti-chart-bar text-xl text-white/30 group-hover:text-emerald-400 transition-colors\" data-kid=\"18\"></i>\n        <span class=\"hidden lg:block text-sm font-semibold text-white/50 group-hover:text-white\" data-kid=\"19\">UPI Analyzer</span>\n      </div>\n      <div class=\"group flex items-center gap-4 p-3.5 rounded-xl hover:bg-white/5 transition-colors cursor-pointer\" data-kid=\"20\">\n        <i class=\"ti ti-robot text-xl text-white/30 group-hover:text-emerald-400 transition-colors\" data-kid=\"21\"></i>\n        <span class=\"hidden lg:block text-sm font-semibold text-white/50 group-hover:text-white\" data-kid=\"22\">AI Coach</span>\n      </div>\n    </nav>\n\n    <div class=\"p-6 border-t border-white/5\" data-kid=\"23\">\n      <div class=\"flex items-center gap-3\" data-kid=\"24\">\n        <img src=\"https://i.pravatar.cc/150?u=fingo\" alt=\"User\" class=\"w-10 h-10 rounded-full border border-white/10\" decoding=\"async\" loading=\"lazy\" data-kid=\"25\">\n        <div class=\"hidden lg:block overflow-hidden\" data-kid=\"26\">\n          <p class=\"text-sm font-semibold truncate\" data-kid=\"27\">Alex Rivera</p>\n          <p class=\"text-xs text-white/40 truncate\" data-kid=\"28\">Pro Plan</p>\n        </div>\n      </div>\n    </div>\n  </aside>\n\n  \n  <main class=\"flex-1 flex flex-col relative overflow-hidden\" data-kid=\"29\">\n    \n    <header class=\"h-20 border-b border-white/5 flex items-center justify-between px-8 bg-white/[0.01] backdrop-blur-md z-40\" data-kid=\"30\">\n      <div class=\"flex items-center gap-4 flex-1\" data-kid=\"31\">\n        <div class=\"relative w-full max-w-md group\" data-kid=\"32\">\n          <i class=\"ti ti-search absolute left-4 top-1/2 -translate-y-1/2 text-white/30 group-focus-within:text-emerald-400 transition-colors\" data-kid=\"33\"></i>\n          <input type=\"text\" placeholder=\"Search documents, receipts, or tags...\" class=\"w-full bg-white/5 border border-white/10 rounded-full py-2.5 pl-11 pr-4 text-sm focus:outline-hidden focus:border-emerald-500/50 transition-all\" data-kid=\"34\">\n        </div>\n      </div>\n      <div class=\"flex items-center gap-6\" data-kid=\"35\">\n        <button class=\"relative p-2 text-white/60 hover:text-white\" data-kid=\"36\">\n          <i class=\"ti ti-bell text-2xl\" data-kid=\"37\"></i>\n          <span class=\"absolute top-2 right-2 w-2 h-2 bg-emerald-500 rounded-full\" data-kid=\"38\"></span>\n        </button>\n        <button class=\"bg-emerald-500 hover:bg-emerald-600 text-white px-5 py-2.5 rounded-full text-sm font-semibold flex items-center gap-2 shadow-lg shadow-emerald-500/20 transition-all hover:scale-105\" data-kid=\"39\">\n          <i class=\"ti ti-cloud-upload\" data-kid=\"40\"></i>\n          Upload Document\n        </button>\n      </div>\n    </header>\n\n    \n    <div class=\"flex-1 flex overflow-hidden\" data-kid=\"41\">\n      \n      <section class=\"w-96 border-r border-white/5 flex flex-col bg-white/[0.01]\" data-kid=\"42\">\n        <div class=\"p-6 pb-2 flex items-center justify-between\" data-kid=\"43\">\n          <h2 class=\"text-lg font-bold font-geist\" data-kid=\"44\">Repository</h2>\n          <div class=\"flex items-center gap-2\" data-kid=\"45\">\n             <span class=\"text-[10px] font-bold text-white/20 uppercase tracking-widest\" data-kid=\"46\">12 Total</span>\n             <i class=\"ti ti-sort-descending text-white/40 cursor-pointer hover:text-white transition-colors\" data-kid=\"47\"></i>\n          </div>\n        </div>\n        \n        <div class=\"flex-1 overflow-y-auto p-4 space-y-3\" id=\"document-list\" data-kid=\"48\">\n          \n          <div class=\"document-item group relative bg-emerald-500/5 border border-emerald-500/30 rounded-2xl p-5 cursor-pointer\" data-kid=\"49\">\n            <div class=\"flex items-center gap-4\" data-kid=\"50\">\n              <div class=\"w-11 h-11 bg-emerald-500/10 rounded-xl flex items-center justify-center text-emerald-400 border border-emerald-500/20\" data-kid=\"51\">\n                <i class=\"ti ti-file-type-pdf text-2xl\" data-kid=\"52\"></i>\n              </div>\n              <div class=\"flex-1 overflow-hidden\" data-kid=\"53\">\n                <div class=\"flex justify-between items-center mb-1\" data-kid=\"54\">\n                  <h4 class=\"text-base font-bold text-white truncate pr-2 font-geist\" data-kid=\"55\">Starbucks_Receipt.pdf</h4>\n                </div>\n                <div class=\"flex items-center justify-between\" data-kid=\"56\">\n                  <p class=\"text-xs text-white/30 font-medium\" data-kid=\"57\">12 Jun • 1.2 MB</p>\n                  <span class=\"badge px-3 py-1 rounded-full bg-emerald-500/10 text-emerald-400 text-[10px] font-bold uppercase border border-emerald-500/20 tracking-wide\" data-kid=\"58\">Complete</span>\n                </div>\n              </div>\n            </div>\n          </div>\n\n          \n          <div class=\"document-item group relative bg-white/[0.03] border border-white/5 rounded-2xl p-5 cursor-pointer hover:border-white/10 overflow-hidden\" data-kid=\"59\">\n            <div class=\"absolute inset-0 processing-shimmer opacity-20\" data-kid=\"60\"></div>\n            <div class=\"flex items-center gap-4 relative z-10\" data-kid=\"61\">\n              <div class=\"w-11 h-11 bg-amber-500/10 rounded-xl flex items-center justify-center text-amber-500 border border-amber-500/10\" data-kid=\"62\">\n                <i class=\"ti ti-file-text text-2xl\" data-kid=\"63\"></i>\n              </div>\n              <div class=\"flex-1 overflow-hidden\" data-kid=\"64\">\n                <div class=\"flex justify-between items-center mb-1\" data-kid=\"65\">\n                  <h4 class=\"text-base font-bold text-white/80 truncate pr-2 font-geist\" data-kid=\"66\">Amazon_Invoice_82.png</h4>\n                </div>\n                <div class=\"flex items-center justify-between\" data-kid=\"67\">\n                  <p class=\"text-xs text-white/30 font-medium\" data-kid=\"68\">Just now • 450 KB</p>\n                  <span class=\"badge px-3 py-1 rounded-full bg-amber-500/10 text-amber-400 text-[10px] font-bold uppercase border border-amber-500/20 tracking-wide\" data-kid=\"69\">Processing</span>\n                </div>\n              </div>\n            </div>\n          </div>\n\n          \n          <div class=\"document-item group relative bg-white/5 border border-white/5 rounded-2xl p-4 cursor-pointer hover:border-white/20\" data-kid=\"70\">\n            <div class=\"flex items-center gap-4\" data-kid=\"71\">\n              <div class=\"w-12 h-12 bg-blue-500/10 rounded-xl flex items-center justify-center text-blue-400\" data-kid=\"72\">\n                <i class=\"ti ti-photo text-2xl\" data-kid=\"73\"></i>\n              </div>\n              <div class=\"flex-1 overflow-hidden\" data-kid=\"74\">\n                <div class=\"flex justify-between items-start mb-1\" data-kid=\"75\">\n                  <h4 class=\"text-sm font-semibold truncate pr-2\" data-kid=\"76\">Uber_Ride_History.jpg</h4>\n                  <span class=\"badge px-2 py-0.5 rounded-full bg-emerald-500/10 text-emerald-400 text-[9px] font-bold uppercase border border-emerald-500/20\" data-kid=\"77\">Complete</span>\n                </div>\n                <p class=\"text-[11px] text-white/40\" data-kid=\"78\">10 Jun • 2.8 MB</p>\n              </div>\n            </div>\n          </div>\n\n          \n          <div class=\"document-item group relative bg-white/5 border border-white/5 rounded-2xl p-4 cursor-pointer hover:border-white/20 opacity-60\" data-kid=\"79\">\n            <div class=\"flex items-center gap-4\" data-kid=\"80\">\n              <div class=\"w-12 h-12 bg-purple-500/10 rounded-xl flex items-center justify-center text-purple-400\" data-kid=\"81\">\n                <i class=\"ti ti-file-description text-2xl\" data-kid=\"82\"></i>\n              </div>\n              <div class=\"flex-1 o