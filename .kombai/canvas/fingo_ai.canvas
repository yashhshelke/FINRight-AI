order-white/5 overflow-hidden group\" data-kid=\"31\">\n                <div class=\"absolute -top-10 -right-10 w-24 h-24 bg-[#076653]/20 blur-3xl rounded-full\" data-kid=\"32\"></div>\n                <div class=\"flex items-center gap-2 mb-3\" data-kid=\"33\">\n                    <div class=\"w-2 h-2 rounded-full bg-[#076653] animate-pulse\" data-kid=\"34\"></div>\n                    <span class=\"text-[10px] font-bold uppercase tracking-widest text-[#076653]\" data-kid=\"35\">AI Advisor Active</span>\n                </div>\n                <p class=\"text-xs text-white/60 leading-relaxed mb-4\" data-kid=\"36\">\"You've spent 12% more on dining than last month.\"</p>\n                <button class=\"w-full py-2.5 bg-[#FF812B] hover:bg-[#ff944d] text-black text-xs font-bold rounded-xl transition-all shadow-lg shadow-[#FF812B]/10 active:scale-95\" data-kid=\"37\">Optimize Budget</button>\n            </div>\n        </div>\n    </aside>\n\n    \n    <main class=\"flex-1 flex flex-col overflow-hidden relative\" data-kid=\"38\">\n        \n        <header class=\"h-20 border-b border-white/5 flex items-center justify-between px-10 z-20 backdrop-blur-xl bg-[#0F1115]/50\" data-kid=\"39\">\n            <div class=\"flex items-center gap-6 flex-1\" data-kid=\"40\">\n                <h2 class=\"text-2xl font-bold font-geist tracking-tight\" data-kid=\"41\">Transactions</h2>\n                <div class=\"h-8 w-[1px] bg-white/5\" data-kid=\"42\"></div>\n                \n                <div class=\"relative w-full max-w-lg group\" data-kid=\"43\">\n                    <i class=\"ti ti-search absolute left-4 top-1/2 -translate-y-1/2 text-white/40 group-focus-within:text-[#076653] transition-colors\" data-kid=\"44\"></i>\n                    <input type=\"text\" placeholder=\"Search merchants, categories, or notes...\" class=\"w-full bg-[#171A20] border border-white/5 rounded-2xl py-2.5 pl-12 pr-4 text-sm focus:outline-hidden focus:border-[#076653]/40 focus:ring-4 focus:ring-[#076653]/5 transition-all placeholder:text-white/40\" data-kid=\"45\">\n                    <div class=\"absolute right-3 top-1/2 -translate-y-1/2 flex gap-1 pointer-events-none opacity-0 group-focus-within:opacity-100 transition-opacity\" data-kid=\"46\">\n                        <kbd class=\"px-1.5 py-0.5 rounded-md bg-white/5 border border-white/10 text-[10px] font-mono text-white/40\" data-kid=\"47\">ESC</kbd>\n                    </div>\n                </div>\n            </div>\n\n            <div class=\"flex items-center gap-4\" data-kid=\"48\">\n                <div class=\"flex items-center bg-[#171A20] border border-white/5 rounded-2xl p-1 gap-1\" data-kid=\"49\">\n                    <button class=\"px-4 py-1.5 rounded-xl text-xs font-bold text-[#076653] bg-[#076653]/10 border border-[#076653]/20\" data-kid=\"50\">All</button>\n                    <button class=\"px-4 py-1.5 rounded-xl text-xs font-bold text-white/30 hover:text-white transition-colors\" data-kid=\"51\">Income</button>\n                    <button class=\"px-4 py-1.5 rounded-xl text-xs font-bold text-white/30 hover:text-white transition-colors\" data-kid=\"52\">Expenses</button>\n                </div>\n                \n                <div class=\"relative h-11 px-4 bg-[#171A20] border border-white/5 rounded-2xl flex items-center gap-3 cursor-pointer hover:bg-white/5 transition-colors\" data-kid=\"53\">\n                    <i class=\"ti ti-calendar-range text-white/30 text-lg\" data-kid=\"54\"></i>\n                    <span class=\"text-xs font-semibold text-white/80 whitespace-nowrap\" data-kid=\"55\">Oct 1 - Oct 31, 2023</span>\n                    <i class=\"ti ti-chevron-down text-white/20 text-xs\" data-kid=\"56\"></i>\n                </div>\n\n                <button onclick=\"toggleModal()\" class=\"h-11 px-5 bg-[#076653] hover:bg-[#087a63] text-white font-bold text-sm rounded-2xl flex items-center gap-2.5 shadow-xl shadow-[#076653]/10 active:scale-95 transition-all\" dat