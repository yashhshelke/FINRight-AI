60 hover:text-white hover:bg-white/5 transition-all flex items-center gap-2\" data-kid=\"71\">\n                        <i class=\"ti ti-copy text-sm\" data-kid=\"72\"></i>\n                        Batch Action\n                    </button>\n                </div>\n            </div>\n\n            \n            <div class=\"bg-[#171A20]/30 border border-white/5 rounded-[32px] overflow-hidden shadow-3xl backdrop-blur-sm mb-6\" data-kid=\"73\">\n                <table class=\"w-full text-left border-collapse min-w-[1000px]\" data-kid=\"74\">\n                    <thead class=\"sticky top-0 bg-[#171A20] z-20\" data-kid=\"75\">\n                        <tr class=\"text-[10px] font-black uppercase tracking-[0.25em] text-white/40 border-b border-white/5\" data-kid=\"76\">\n                            <th class=\"py-5 px-8 w-16\" data-kid=\"77\">\n                                <div class=\"flex items-center justify-center\" data-kid=\"78\">\n                                    <input type=\"checkbox\" class=\"w-4 h-4 rounded-md border-white/10 bg-transparent accent-[#076653] cursor-pointer\" data-kid=\"79\">\n                                </div>\n                            </th>\n                            <th class=\"py-5 px-4 w-40\" data-kid=\"80\">Date</th>\n                            <th class=\"py-5 px-4\" data-kid=\"81\">Merchant</th>\n                            <th class=\"py-5 px-4 w-48\" data-kid=\"82\">Category</th>\n                            <th class=\"py-5 px-4 w-40\" data-kid=\"83\">Status</th>\n                            <th class=\"py-5 px-10 w-48 text-right\" data-kid=\"84\">Amount</th>\n                        </tr>\n                    </thead>\n                    <tbody class=\"divide-y divide-white/5\" data-kid=\"85\">\n                        \n                        <tr class=\"transaction-row group cursor-pointer\" data-kid=\"86\">\n                            <td class=\"py-4 px-8\" data-kid=\"87\">\n                                <div class=\"flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"88\">\n                                    <input type=\"checkbox\" class=\"w-4 h-4 rounded-md border-white/10 bg-transparent accent-[#076653] cursor-pointer\" data-kid=\"89\">\n                                </div>\n                            </td>\n                            <td class=\"py-4 px-4\" data-kid=\"90\">\n                                <div class=\"text-xs font-bold text-white/80\" data-kid=\"91\">Oct 26, 2023</div>\n                                <div class=\"text-[10px] text-white/30 font-medium\" data-kid=\"92\">10:42 PM</div>\n                            </td>\n                            <td class=\"py-4 px-4\" data-kid=\"93\">\n                                <div class=\"flex items-center gap-3\" data-kid=\"94\">\n                                    \n                                    <div class=\"w-10 h-10 rounded-xl bg-black flex items-center justify-center border border-white/10 shadow-lg group-hover:border-[#076653]/40 transition-colors overflow-hidden\" data-kid=\"95\">\n                                        <i class=\"ti ti-brand-apple text-xl\" data-kid=\"96\"></i>\n                                    </div>\n                                    <div data-kid=\"97\">\n                                        <div class=\"text-sm font-bold text-white/90\" data-kid=\"98\">Apple Store</div>\n                                        <div class=\"text-[10px] text-white/30 font-medium\" data-kid=\"99\">Electronics • SF, CA</div>\n                                    </div>\n                                </div>\n                            </td>\n                            <td class=\"py-4 px-4\" data-kid=\"100\">\n                                <div class=\"inline-flex items-center gap-2 px-3 py-1.5 rounded-xl bg-[#076653]/10 border border-[#076653]/20\" data-kid=\"101\">\n                                    <i class=\"ti ti-de