e/10\" data-kid=\"183\">\n                Dismiss\n              </button>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"col-span-12 lg:col-span-4 bento-item bg-[var(--bg-card)] p-10 rounded-[2rem] border border-white/5\" id=\"progress-checklist\" data-kid=\"184\">\n          <div class=\"flex items-center justify-between mb-10\" data-kid=\"185\">\n            <h3 class=\"text-lg font-bold\" data-kid=\"186\">Strategic Goals</h3>\n            <button class=\"w-8 h-8 rounded-lg bg-white/5 flex items-center justify-center text-[var(--emerald)] hover:bg-[var(--emerald)]/10 transition-colors\" data-kid=\"187\">\n              <i class=\"ti ti-plus\" data-kid=\"188\"></i>\n            </button>\n          </div>\n          \n          <div class=\"space-y-10\" data-kid=\"189\">\n            <div class=\"space-y-4\" data-kid=\"190\">\n              <div class=\"flex justify-between items-end\" data-kid=\"191\">\n                <div data-kid=\"192\">\n                  <div class=\"flex items-center gap-2 mb-1\" data-kid=\"193\">\n                    <i class=\"ti ti-shield-check text-[var(--emerald)]\" data-kid=\"194\"></i>\n                    <p class=\"text-sm font-bold\" data-kid=\"195\">Emergency Fund</p>\n                  </div>\n                  <p class=\"text-[10px] text-[var(--text-secondary)] font-bold uppercase tracking-widest\" data-kid=\"196\">Progressing • High Priority</p>\n                </div>\n                <p class=\"text-sm font-bold text-white\" data-kid=\"197\">$12,000<span class=\"text-[var(--text-secondary)] font-medium\" data-kid=\"198\"> / $15k</span></p>\n              </div>\n              <div class=\"h-2 w-full bg-white/5 rounded-full overflow-hidden\" data-kid=\"199\">\n                <div class=\"h-full bg-[var(--emerald)] w-[80%] rounded-full shadow-[0_0_12px_rgba(7,102,83,0.4)]\" data-kid=\"200\"></div>\n              </div>\n            </div>\n\n            <div class=\"space-y-4\" data-kid=\"201\"