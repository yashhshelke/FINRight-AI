            <div class=\"text-3xl font-bold text-white font-heading\" data-kid=\"194\">₹1,499 <span class=\"text-xs font-normal text-gray-500 uppercase tracking-widest\" data-kid=\"195\">/ Year</span></div>\n                            </div>\n                        </div>\n                        <div class=\"absolute -z-10 bottom-0 left-1/2 -translate-x-1/2 w-3/4 h-8 bg-[#FF9900]/20 blur-3xl rounded-full opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"196\"></div>\n                    </div>\n\n                    \n                    <div class=\"relative h-auto group cursor-pointer\" data-kid=\"197\">\n                        <div class=\"bg-emerald-500/[0.03] border border-dashed border-emerald-500/20 rounded-[32px] p-8 flex flex-col items-center justify-center text-center transition-all hover:bg-emerald-500/[0.08] hover:border-emerald-500/40 h-full\" data-kid=\"198\">\n                            <div class=\"w-14 h-14 rounded-full bg-emerald-500/10 flex items-center justify-center text-emerald-400 mb-6 group-hover:scale-110 transition-transform border border-emerald-500/20\" data-kid=\"199\">\n                                <i class=\"ti ti-plus text-3xl\" data-kid=\"200\"></i>\n                            </div>\n                            <div class=\"text-lg font-bold text-emerald-400 font-heading\" data-kid=\"201\">New Insight</div>\n                            <p class=\"text-xs text-gray-500 mt-3 max-w-[200px] leading-relaxed\" data-kid=\"202\">Neural engine detected a potential ₹299 recurring charge to \"Google Play\".</p>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"fixed bottom-8 right-8 z-50 group\" data-kid=\"203\">\n                <div class=\"absolute inset-0 bg-emerald-500/20 blur-2xl rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-500\" data-kid=\"204\"></div>\n                <button class=\"relative w-16 h-16 bg-[#076653] text-white rounded-2xl flex items-center justify-center text-3xl shadow-2xl shadow-emerald-500/40 transform transition-all hover:scale-110 active:scale-95 group\" data-kid=\"205\">\n                    <i class=\"ti ti-robot\" data-kid=\"206\"></i>\n                    \n                    <span class=\"absolute top-0 right-0 w-4 h-4 bg-amber-500 border-4 border-[#0F1115] rounded-full\" data-kid=\"207\"></span>\n                </button>\n            </div>\n\n        </section>\n    </main>\n</div>\n\n<style data-kid=\"208\">\n@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@600&family=Inter:wght@400;500;600;700&family=Geist:wght@400;600;800&display=swap');\n@import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n:root {\n  --color-emerald-brand: #076653;\n  --color-amber-cta: #FF812B;\n}\n\nbody {\n    background-color: #0F1115;\n}\n\n.font-sans { font-family: 'Inter', sans-serif; }\n.font-serif { font-family: 'Cormorant Garamond', serif; }\n.font-heading { font-family: 'Geist', sans-serif; }\n\nh1, h2, h3 { font-family: 'Geist', sans-serif; }\n\n/* Scanner Animations */\n.scanner-card {\n    transform: perspective(1000px) rotateX(15deg);\n}\n\n@keyframes laser-scan {\n    0%, 100% { top: 0%; }\n    50% { top: 100%; }\n}\n\n@keyframes glow-move {\n    0%, 100% { transform: translateY(-100%); opacity: 0; }\n    25%, 75% { opacity: 1; }\n    50% { transform: translateY(0%); opacity: 1; }\n}\n\n.scanner-laser {\n    animation: laser-scan 4s cubic-bezier(0.4, 0, 0.2, 1) infinite;\n}\n\n.scanner-glow {\n    animation: laser-scan 4s cubic-bezier(0.4, 0, 0.2, 1) infinite;\n}\n\n/* Floating Data Bits */\n@keyframes node-float {\n    0%, 100% { transform: translate(0, 0); opacity: 0.5; }\n    50% { transform: translate(5px, -5px); opacity: 1; }\n}\n\n.data-node {\n    animation: node-float 3s ease-in-out infinite;\n}\n.data-node:nth-child(2) { animation-delay: 1s; }\n.data-node:nth-child(3) { animation-delay: 2s; }\n\n/* Hide Scrollbar */\n::-webkit-scrollbar {\n    width: 6px;\n}\n::-webkit-scrollbar-track {\n    background: transparent;\n}\n::-webkit-scrollbar-thumb {\n    background: #171A20;\n    border-radius: 10px;\n}\n::-webkit-scrollbar-thumb:hover {\n    background: #076653;\n}\n</style>\n\n<link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" data-kid=\"209\">\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"210\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"211\"></script>\n<script data-kid=\"212\">gsap.registerPlugin(ScrollTrigger);</script>\n<script type=\"module\" data-kid=\"213\">\n    import Lenis from \"https://esm.sh/lenis@1\"\n    \n    // Initialize Lenis\n    const lenis = new Lenis({\n        lerp: 0.1,\n        smoothWheel: true,\n    });\n\n    // Synchronize ScrollTrigger with Lenis\n    lenis.on('scroll', ScrollTrigger.update);\n    gsap.ticker.add((time) => {\n        lenis.raf(time * 1000);\n    });\n    gsap.ticker.lagSmoothing(0);\n\n    // Individual Reveal Animations (Breaking AI-slop)\n    gsap.from('#stat-outflow, #stat-savings, #stat-merchant', {\n        opacity: 0,\n        x: -20,\n        duration: 1,\n        stagger: 0.1,\n        ease: 'power4.out',\n        clearProps: 'all',\n        scrollTrigger: {\n            trigger: '#stat-outflow',\n            start: 'top 95%',\n        }\n    });\n\n    gsap.from('#upload-panel', {\n        opacity: 0,\n        scale: 0.95,\n        duration: 1.2,\n        ease: 'expo.out',\n        scrollTrigger: {\n            trigger: '#upload-panel',\n            start: 'top 90%',\n        }\n    });\n\n    gsap.from('#chart-panel', {\n        opacity: 0,\n        x: 40,\n        duration: 1.2,\n        ease: 'expo.out',\n        scrollTrigger: {\n            trigger: '#chart-panel',\n            start: 'top 90%',\n        }\n    });\n\n    gsap.from('.subscription-card', {\n        opacity: 0,\n        y: 40,\n        duration: 0.8,\n        stagger: 0.12,\n        ease: 'back.out(1.4)',\n        scrollTrigger: {\n            trigger: '#subscriptions-section',\n            start: 'top 85%',\n        }\n    });\n\n    // Donut Rings Animation\n    gsap.from('circle[stroke-dashoffset]', {\n        strokeDashoffset: (i, target) => target.getAttribute('stroke-dasharray'),\n        duration: 2,\n        delay: 0.5,\n        ease: 'power3.out',\n        scrollTrigger: {\n            trigger: 'svg',\n            start: 'top 80%',\n        }\n    });\n\n    // Hover Lift for Subscription Cards\n    // Using simple hover in CSS as per constraints for GSAP\n</script>\n",
