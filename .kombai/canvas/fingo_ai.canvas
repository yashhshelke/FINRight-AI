      "html": "\n<div class=\"min-h-screen bg-[#0F1115] text-white font-sans selection:bg-emerald-500/30 overflow-x-clip\" data-kid=\"0\">\n    \n    <main id=\"main-content\" class=\"flex\" data-kid=\"1\">\n        \n        \n        <aside class=\"w-72 h-screen sticky top-0 bg-[#171A20] border-r border-white/5 flex flex-col p-8 shrink-0\" data-kid=\"2\">\n            <div class=\"flex items-center gap-3 mb-12\" data-kid=\"3\">\n                <div class=\"w-10 h-10 bg-emerald-500 rounded-xl flex items-center justify-center shadow-lg shadow-emerald-500/20\" data-kid=\"4\">\n                    <i class=\"ti ti-hexagon-filled text-2xl\" data-kid=\"5\"></i>\n                </div>\n                <span class=\"text-2xl font-serif tracking-tight text-white\" data-kid=\"6\">Fingo AI</span>\n            </div>\n\n            <nav class=\"space-y-2 flex-1\" data-kid=\"7\">\n                <p class=\"text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-4 px-3\" data-kid=\"8\">Main Menu</p>\n                <a href=\"#\" class=\"flex items-center gap-3 p-3 rounded-xl text-gray-400 hover:bg-white/5 transition-colors group\" data-kid=\"9\">\n                    <i class=\"ti ti-layout-dashboard text-xl group-hover:text-emerald-400\" data-kid=\"10\"></i>\n                    <span class=\"font-medium\" data-kid=\"11\">Overview</span>\n                </a>\n                <a href=\"#\" class=\"flex items-center gap-3 p-3 rounded-xl bg-emerald-500/10 text-emerald-400 border border-emerald-500/20\" data-kid=\"12\">\n                    <i class=\"ti ti-chart-pie text-xl\" data-kid=\"13\"></i>\n                    <span class=\"font-medium\" data-kid=\"14\">UPI Analyzer</span>\n                </a>\n                <a href=\"#\" class=\"flex items-center gap-3 p-3 rounded-xl text-gray-400 hover:bg-white/5 transition-colors group\" data-kid=\"15\">\n                    <i class=\"ti ti-receipt text-xl group-hover:text-emerald-400\" data-kid=\"16\"></i>\n                    <span class=\"font-medium\" data-kid=\"17\">Transactions</span>\n                </a>\n                <a href=\"#\" class=\"flex items-center gap-3 p-3 rounded-xl text-gray-400 hover:bg-white/5 transition-colors group\" data-kid=\"18\">\n                    <i class=\"ti ti-target-arrow text-xl group-hover:text-emerald-400\" data-kid=\"19\"></i>\n                    <span class=\"font-medium\" data-kid=\"20\">Goals Tracker</span>\n                </a>\n                \n                <div class=\"pt-8\" data-kid=\"21\">\n                    <p class=\"text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-4 px-3\" data-kid=\"22\">AI Coach</p>\n                    <a href=\"#\" class=\"flex items-center gap-3 p-3 rounded-xl text-gray-400 hover:bg-white/5 transition-colors group\" data-kid=\"23\">\n                        <i class=\"ti ti-message-chatbot text-xl group-hover:text-emerald-400\" data-kid=\"24\"></i>\n                        <span class=\"font-medium\" data-kid=\"25\">Financial Briefing</span>\n                    </a>\n                </div>\n            </nav>\n\n            <div class=\"mt-auto p-4 bg-white/5 rounded-2xl border border-white/5\" data-kid=\"26\">\n                <div class=\"flex items-center gap-3 mb-3\" data-kid=\"27\">\n                    <div class=\"w-8 h-8 rounded-full bg-emerald-500/20 flex items-center justify-center text-emerald-400\" data-kid=\"28\">\n                        <i class=\"ti ti-shield-check\" data-kid=\"29\"></i>\n                    </div>\n                    <div class=\"text-xs\" data-kid=\"30\">\n                        <div class=\"font-bold\" data-kid=\"31\">Premium Plan</div>\n                        <div class=\"text-gray-500 text-[10px]\" data-kid=\"32\">Renewal in 12 days</div>\n                    </div>\n                </div>\n                <button class=\"w-full py-2 bg-emerald-500 hover:bg-emerald-600 text-white rounded-lg text-xs font-bold transition-all shadow-lg shadow