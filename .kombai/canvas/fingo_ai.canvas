           <div class=\"space-y-2\" data-kid=\"271\">\n                            <label class=\"text-[10px] font-bold uppercase tracking-widest text-white/30 ml-1\" data-kid=\"272\">Merchant Name</label>\n                            <input type=\"text\" placeholder=\"e.g. Starbucks\" class=\"w-full bg-[#0F1115] border border-white/5 rounded-xl p-3 text-sm focus:border-[#076653]/50 focus:outline-hidden\" data-kid=\"273\">\n                        </div>\n                        <div class=\"space-y-2\" data-kid=\"274\">\n                            <label class=\"text-[10px] font-bold uppercase tracking-widest text-white/30 ml-1\" data-kid=\"275\">Category</label>\n                            <select class=\"w-full bg-[#0F1115] border border-white/5 rounded-xl p-3 text-sm focus:border-[#076653]/50 focus:outline-hidden appearance-none\" data-kid=\"276\">\n                                <option data-kid=\"277\">Dining</option>\n                                <option data-kid=\"278\">Shopping</option>\n                                <option data-kid=\"279\">Travel</option>\n                                <option data-kid=\"280\">Personal</option>\n                            </select>\n                        </div>\n                    </div>\n\n                    <div class=\"grid grid-cols-2 gap-6\" data-kid=\"281\">\n                        <div class=\"space-y-2\" data-kid=\"282\">\n                            <label class=\"text-[10px] font-bold uppercase tracking-widest text-white/30 ml-1\" data-kid=\"283\">Date</label>\n                            <input type=\"date\" class=\"w-full bg-[#0F1115] border border-white/5 rounded-xl p-3 text-sm focus:border-[#076653]/50 focus:outline-hidden\" data-kid=\"284\">\n                        </div>\n                        <div class=\"space-y-2\" data-kid=\"285\">\n                            <label class=\"text-[10px] font-bold uppercase tracking-widest text-white/30 ml-1\" data-kid=\"286\">Amount</label>\n                            <div class=\"relative\" data-kid=\"287\">\n                                <span class=\"absolute left-3 top-1/2 -translate-y-1/2 text-white/20 font-bold\" data-kid=\"288\">$</span>\n                                <input type=\"number\" step=\"0.01\" placeholder=\"0.00\" class=\"w-full bg-[#0F1115] border border-white/5 rounded-xl p-3 pl-8 text-sm focus:border-[#076653]/50 focus:outline-hidden\" data-kid=\"289\">\n                            </div>\n                        </div>\n                    </div>\n\n                    <div class=\"space-y-2\" data-kid=\"290\">\n                        <label class=\"text-[10px] font-bold uppercase tracking-widest text-white/30 ml-1\" data-kid=\"291\">Notes</label>\n                        <textarea rows=\"3\" placeholder=\"Add additional details...\" class=\"w-full bg-[#0F1115] border border-white/5 rounded-xl p-3 text-sm focus:border-[#076653]/50 focus:outline-hidden\" data-kid=\"292\"></textarea>\n                    </div>\n\n                    <div class=\"flex gap-4 pt-4\" data-kid=\"293\">\n                        <button type=\"button\" onclick=\"toggleModal()\" class=\"flex-1 py-4 rounded-2xl bg-white/5 hover:bg-white/10 text-white text-sm font-bold transition-all\" data-kid=\"294\">Cancel</button>\n                        <button type=\"submit\" class=\"flex-2 py-4 rounded-2xl bg-[#076653] hover:bg-[#087a63] text-white text-sm font-bold transition-all shadow-xl shadow-[#076653]/10\" data-kid=\"295\">Save Transaction</button>\n                    </div>\n                </form>\n            </div>\n        </div>\n    </div>\n</section>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"296\"></script>\n<script type=\"module\" data-kid=\"297\">\n    // 1. Entrance Animation\n    gsap.from('.nav-link', {\n        x: -20,\n        opacity: 0,\n        stagger: 0.05,\n        duration: 0.6,\n        ease: 'power3.out'\n    });\n\n    gsap.from('.transaction-row', {\n        y: 20,\n        opacity: 0,\n        stagger: 0.04,\n        duration: 0.8,\n        ease: 'power3.out',\n        delay: 0.2\n    });\n\n    // 2. Row Hover Interactions using GSAP to avoid conflict with entrance transforms\n    const rows = document.querySelectorAll('.transaction-row');\n    rows.forEach(row => {\n        row.addEventListener('mouseenter', () => {\n            gsap.to(row, {\n                y: -2,\n                backgroundColor: 'rgba(255, 255, 255, 0.04)',\n                duration: 0.3,\n                ease: 'power2.out',\n                overwrite: 'auto'\n            });\n        });\n        row.addEventListener('mouseleave', () => {\n            gsap.to(row, {\n                y: 0,\n                backgroundColor: 'rgba(255, 255, 255, 0)',\n                duration: 0.4,\n                ease: 'power2.out',\n                overwrite: 'auto'\n            });\n        });\n    });\n\n    // Modal Toggle logic\n    window.toggleModal = () => {\n        const modal = document.getElementById('addTransactionModal');\n        const isOpen = !modal.classList.contains('hidden');\n        \n        if (isOpen) {\n            gsap.to(modal, { opacity: 0, duration: 0.3, onComplete: () => modal.classList.add('hidden') });\n        } else {\n            modal.classList.remove('hidden');\n            gsap.fromTo(modal, { opacity: 0 }, { opacity: 1, duration: 0.3 });\n            gsap.fromTo('.modal-content-panel', { scale: 0.9, y: 20 }, { scale: 1, y: 0, duration: 0.5, ease: 'back.out(1.7)' });\n        }\n    };\n</script>\n\n<style data-kid=\"298\">\n@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@600&family=Inter:wght@400;500;600;700;800;900&family=Geist:wght@700;800;900&display=swap');\n@import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n.font-serif { font-family: 'Cormorant Garamond', serif; }\n.font-sans { font-family: 'Inter', sans-serif; }\n.font-geist { font-family: 'Geist', sans-serif; }\n\n/* Hide default checkbox but keep it accessible if needed - simplified for UI */\ninput[type=\"checkbox\"] {\n    appearance: none;\n    -webkit-appearance: none;\n    width: 1rem;\n    height: 1rem;\n    border: 1px solid rgba(255, 255, 255, 0.1);\n    border-radius: 0.375rem;\n    background-color: transparent;\n    cursor: pointer;\n    position: relative;\n    transition: all 0.2s;\n}\ninput[type=\"checkbox\"]:checked {\n    background-color: #076653;\n    border-color: #076653;\n}\ninput[type=\"checkbox\"]:checked::after {\n    content: \"\\eb33\";\n    font-family: 'tabler-icons';\n    position: absolute;\n    top: 50%;\n    left: 50%;\n    transform: translate(-50%, -50%);\n    color: white;\n    font-size: 0.6rem;\n}\n\n/* Custom Scrollbar */\n.custom-scrollbar::-webkit-scrollbar {\n    width: 5px;\n    height: 5px;\n}\n.custom-scrollbar::-webkit-scrollbar-track {\n    background: transparent;\n}\n.custom-scrollbar::-webkit-scrollbar-thumb {\n    background: rgba(255, 255, 255, 0.05);\n    border-radius: 10px;\n}\n.custom-scrollbar::-webkit-scrollbar-thumb:hover {\n    background: rgba(7, 102, 83, 0.3);\n}\n\n/* Animations Utility */\n.transaction-row {\n    will-change: transform, background-color;\n}\n\n/* Modal form adjustments */\ninput[type=\"date\"]::-webkit-calendar-picker-indicator {\n    filter: invert(1);\n    opacity: 0.3;\n    cursor: pointer;\n}\n</style>\n",
