ata-kid=\"140\"></div>\n                  <div class=\"flex-1 bg-white/10 h-28 rounded-3xl\" data-kid=\"141\"></div>\n                  <div class=\"flex-1 bg-gradient-to-t from-[#22C55E]/40 to-[#22C55E] h-72 rounded-3xl shadow-[0_0_40px_rgba(34,197,94,0.4)]\" data-kid=\"142\"></div>\n                  <div class=\"flex-1 bg-white/5 h-44 rounded-3xl\" data-kid=\"143\"></div>\n                  <div class=\"flex-1 bg-white/5 h-64 rounded-3xl\" data-kid=\"144\"></div>\n                  <div class=\"flex-1 bg-white/10 h-40 rounded-3xl\" data-kid=\"145\"></div>\n               </div>\n            </div>\n            <div class=\"h-1/3 flex gap-10\" data-kid=\"146\">\n               <div class=\"flex-1 glass rounded-[56px] p-12 shadow-inner border-white/5\" data-kid=\"147\">\n                  <h5 class=\"font-geist font-black text-xl mb-10 tracking-tight\" data-kid=\"148\">Savings Goals</h5>\n                  <div class=\"space-y-8\" data-kid=\"149\">\n                     <div class=\"flex items-center gap-5\" data-kid=\"150\">\n                        <div class=\"w-12 h-12 rounded-2xl bg-[#FF812B]/20 flex items-center justify-center text-[#FF812B] shadow-inner\" data-kid=\"151\">\n                           <i class=\"ti ti-home text-2xl\" data-kid=\"152\"></i>\n                        </div>\n                        <div class=\"flex-1\" data-kid=\"153\">\n                           <div class=\"flex justify-between text-xs font-bold mb-3 uppercase tracking-wider\" data-kid=\"154\"><span data-kid=\"155\">House Fund</span><span data-kid=\"156\">82%</span></div>\n                           <div class=\"h-2 bg-white/5 rounded-full overflow-hidden shadow-inner\" data-kid=\"157\"><div class=\"h-full bg-gradient-to-r from-[#FF812B] to-[#ff9347] w-[82%]\" data-kid=\"158\"></div></div>\n                        </div>\n                     </div>\n                     <div class=\"flex items-center gap-5\" data-kid=\"159\">\n                        <div class=\"w-12 h-12 rounded-2xl bg-[#22C55E]/20 flex items-center justify-center text-[#22C55E] shadow-inner\" data-kid=\"160\">\n                           <i class=\"ti ti-plane text-2xl\" data-kid=\"161\"></i>\n                        </div>\n                        <div class=\"flex-1\" data-kid=\"162\">\n                           <div class=\"flex justify-between text-xs font-bold mb-3 uppercase tracking-wider\" data-kid=\"163\"><span data-kid=\"164\">Bali Trip</span><span data-kid=\"165\">45%</span></div>\n                           <div class=\"h-2 bg-white/5 rounded-full overflow-hidden shadow-inner\" data-kid=\"166\"><div class=\"h-full bg-gradient-to-r from-[#22C55E] to-[#4ade80] w-[45%]\" data-kid=\"167\"></div></div>\n                        </div>\n                     </div>\n                  </div>\n               </div>\n               <div class=\"flex-1 glass rounded-[56px] p-12 hidden md:block shadow-inner border-white/5\" data-kid=\"168\">\n                  <h5 class=\"font-geist font-black text-xl mb-10 tracking-tight\" data-kid=\"169\">Subscriptions</h5>\n                  <div class=\"space-y-6\" data-kid=\"170\">\n                     <div class=\"flex justify-between items-center py-4 border-b border-white/5\" data-kid=\"171\">\n                        <span class=\"text-sm font-medium\" data-kid=\"172\">Netflix Premium</span>\n                        <span class=\"text-sm font-black font-geist\" data-kid=\"173\">₹799</span>\n                     </div>\n                     <div class=\"flex justify-between items-center py-4 border-b border-white/5\" data-kid=\"174\">\n                        <span class=\"text-sm font-medium\" data-kid=\"175\">Adobe Creative Cloud</span>\n                        <span class=\"text-sm font-black font-geist\" data-kid=\"176\">₹4,230</span>\n                     </div>\n                     <div class=\"flex justify-between items-center py-4\" data-kid=\"177\">\n                        <span class=\"text-sm font-medium\" data-kid=\"178\">Cloud Storage</span>\n                        <span class=\"text-sm font-black font-geist\" data-kid=\"179\">₹199</span>\n                     </div>\n                  </div>\n               </div>\n            </div>\n          </div>\n\n          \n          <div class=\"hidden xl:flex col-span-3 flex-col glass rounded-[56px] p-12 shadow-inner border-white/5\" data-kid=\"180\">\n            <div class=\"flex items-center gap-5 mb-12\" data-kid=\"181\">\n               <div class=\"w-14 h-14 glass rounded-full flex items-center justify-center text-[#FF812B] shadow-xl\" data-kid=\"182\">\n                  <i class=\"ti ti-message-chatbot text-3xl\" data-kid=\"183\"></i>\n               </div>\n               <span class=\"font-geist font-black text-2xl tracking-tight\" data-kid=\"184\">AI Coach</span>\n            </div>\n            <div class=\"flex-1 space-y-10\" data-kid=\"185\">\n               <div class=\"p-8 bg-white/5 rounded-[36px] text-lg leading-relaxed border border-white/5 shadow-inner italic\" data-kid=\"186\">\n                  \"Your spending at luxury dining is up 14% this month. Reducing this by 6% would accelerate your Bali Trip goal by 4 weeks.\"\n               </div>\n               <div class=\"p-8 bg-[#FF812B]/10 rounded-[36px] text-lg leading-relaxed border border-[#FF812B]/20 text-[#FF812B] font-bold shadow-inner\" data-kid=\"187\">\n                  \"Detected an abandoned subscription for Hulu. Want me to cancel it?\"\n               </div>\n            </div>\n            <div class=\"mt-10 p-6 glass rounded-[28px] flex items-center justify-between text-sm text-[#94A3B8] font-bold border-white/5 cursor-pointer\" data-kid=\"188\">\n               Ask Fingo...\n               <i class=\"ti ti-send text-xl\" data-kid=\"189\"></i>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <footer class=\"bg-[#0F1115] pt-48 pb-24 px-12 border-t border-white/5\" data-kid=\"190\">\n    <div class=\"max-w-7xl mx-auto\" data-kid=\"191\">\n      <div class=\"grid grid-cols-1 md:grid-cols-4 gap-24 mb-40\" data-kid=\"192\">\n        <div class=\"col-span-1\" data-kid=\"193\">\n          <div class=\"flex items-center gap-5 mb-10\" data-kid=\"194\">\n            <div class=\"w-12 h-12 glass rounded-2xl flex items-center justify-center border-white/10 shadow-xl\" data-kid=\"195\">\n              <span class=\"font-logo text-3xl text-[#FF812B]\" data-kid=\"196\">F</span>\n            </div>\n            <span class=\"font-logo text-4xl tracking-tight\" data-kid=\"197\">Fingo AI</span>\n          </div>\n          <p class=\"text-[#94A3B8] font-inter text-lg leading-relaxed\" data-kid=\"198\">\n            Revolutionizing personal finance with autonomous intelligence and premium design.\n          </p>\n        </div>\n        <div data-kid=\"199\">\n          <h5 class=\"font-geist font-black mb-10 text-[#94A3B8] uppercase text-xs tracking-[0.3em]\" data-kid=\"200\">Platform</h5>\n          <ul class=\"space-y-6 text-sm font-black\" data-kid=\"201\">\n            <li data-kid=\"202\"><a href=\"#\" class=\"hover:text-[#FF812B] transition-colors\" data-kid=\"203\">Core Features</a></li>\n            <li data-kid=\"204\"><a href=\"#\" class=\"hover:text-[#FF812B] transition-colors\" data-kid=\"205\">AI Assistant</a></li>\n            <li data-kid=\"206\"><a href=\"#\" class=\"hover:text-[#FF812B] transition-colors\" data-kid=\"207\">Enterprise Security</a></li>\n            <li data-kid=\"208\"><a href=\"#\" class=\"hover:text-[#FF812B] transition-colors\" data-kid=\"209\">Tier Pricing</a></li>\n          </ul>\n        </div>\n        <div data-kid=\"210\">\n          <h5 class=\"font-geist font-black mb-10 text-[#94A3B8] uppercase text-xs tracking-[0.3em]\" data-kid=\"211\">Company</h5>\n          <ul class=\"space-y-6 text-sm font-black\" data-kid=\"212\">\n            <li data-kid=\"213\"><a href=\"#\" class=\"hover:text-[#FF812B] transition-colors\" data-kid=\"214\">Our Vision</a></li>\n            <li data-kid=\"215\"><a href=\"#\" class=\"hover:text-[#FF812B] transition-colors\" data-kid=\"216\">Careers</a></li>\n            <li data-kid=\"217\"><a href=\"#\" class=\"hover:text-[#FF812B] transition-colors\" data-kid=\"218\">Privacy</a></li>\n            <li data-kid=\"219\"><a href=\"#\" class=\"hover:text-[#FF812B] transition-colors\" data-kid=\"220\">Press Kit</a></li>\n          </ul>\n        </div>\n        <div data-kid=\"221\">\n          <h5 class=\"font-geist font-black mb-10 text-[#94A3B8] uppercase text-xs tracking-[0.3em]\" data-kid=\"222\">Stay Updated</h5>\n          <div class=\"flex gap-3\" data-kid=\"223\">\n            <input type=\"text\" placeholder=\"Your email\" class=\"w-full glass px-8 py-4 rounded-3xl outline-hidden focus:border-[#FF812B] transition-all text-sm font-bold shadow-inner\" data-kid=\"224\">\n            <button class=\"bg-[#FF812B] px-6 py-4 rounded-3xl hover:bg-[#ff9347] transition-all shadow-xl shadow-[#FF812B]/20\" data-kid=\"225\">\n              <i class=\"ti ti-arrow-right\" data-kid=\"226\"></i>\n            </button>\n          </div>\n        </div>\n      </div>\n      <div class=\"pt-12 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-10\" data-kid=\"227\">\n        <div class=\"text-[#94A3B8] text-xs font-black uppercase tracking-widest italic\" data-kid=\"228\">© 2024 Fingo AI. Intelligence for the elite.</div>\n        <div class=\"flex gap-12\" data-kid=\"229\">\n          <i class=\"ti ti-brand-twitter text-2xl text-[#94A3B8] hover:text-[#FF812B] transition-colors cursor-pointer\" data-kid=\"230\"></i>\n          <i class=\"ti ti-brand-github text-2xl text-[#94A3B8] hover:text-[#FF812B] transition-colors cursor-pointer\" data-kid=\"231\"></i>\n          <i class=\"ti ti-brand-linkedin text-2xl text-[#94A3B8] hover:text-[#FF812B] transition-colors cursor-pointer\" data-kid=\"232\"></i>\n        </div>\n      </div>\n    </div>\n  </footer>\n\n  <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"233\"></script>\n  <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"234\"></script>\n  <script type=\"module\" data-kid=\"235\">\n    import Lenis from \"https://esm.sh/lenis@1\"\n    import { animate } from 'https://esm.sh/animejs@4'\n    \n    // Smooth Scroll\n    const lenis = new Lenis();\n    function raf(time) {\n      lenis.raf(time);\n      requestAnimationFrame(raf);\n    }\n    requestAnimationFrame(raf);\n\n    gsap.registerPlugin(ScrollTrigger);\n\n    // Initial Entrance\n    window.addEventListener('load', () => {\n      const tl = gsap.timeline();\n      tl.from(\"#peephole\", { scale: 0.7, opacity: 0, duration: 1.8, ease: \"expo.out\" })\n        .to(\"#heroText\", { opacity: 1, y: 0, duration: 1.2, ease: \"power2.out\" }, \"-=1\");\n    });\n\n    // Robot Movement Logic\n    const robot = document.querySelector('#robot');\n    const path = document.querySelector('#motionPath');\n    const pathLength = path.getTotalLength();\n    \n    ScrollTrigger.create({\n      trigger: \"#storytelling\",\n      start: \"top top\",\n      end: \"bottom bottom\",\n      scrub: 1,\n      onUpdate: (self) => {\n        const p = self.progress;\n        \n        // Handle Robot visibility\n        if (p < 0.05) robot.style.opacity = p * 20;\n        else if (p > 0.95) robot.style.opacity = (1 - p) * 20;\n        else robot.style.opacity = 1;\n\n        // Position on path\n        const point = path.getPointAtLength(p * pathLength);\n        robot.style.transform = `translate(${point.x - 72}px, ${point.y - 72}px)`;\n      }\n    });\n\n    // Feature reveals\n    document.querySelectorAll('.feature-item').forEach((el) => {\n      gsap.to(el, {\n        opacity: 1,\n        y: 0,\n        duration: 1.2,\n        ease: \"power2.out\",\n        scrollTrigger: {\n          trigger: el,\n          start: \"top 85%\",\n          toggleActions: \"play none none reverse\"\n        }\n      });\n    });\n\n    // Spring physics for dock items using Anime.js as required\n    document.querySelectorAll('.dock-item').forEach(item => {\n      item.addEventListener('mouseenter', () => {\n        animate(item, {\n          scale: 1.15,\n          translateY: -12,\n          duration: 400,\n          easing: 'spring(1, 80, 15, 0)'\n        });\n      });\n      item.addEventListener('mouseleave', () => {\n        animate(item, {\n          scale: 1,\n          translateY: 0,\n          duration: 300,\n          easing: 'spring(1, 80, 15, 0)'\n        });\n      });\n    });\n\n  </script>\n</div>\n>>>>>>> REPLACE\n",
