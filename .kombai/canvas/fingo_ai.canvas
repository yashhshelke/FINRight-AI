      "html": "<style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@600;700&family=Inter:wght@400;500;600;700&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n    @import url('https://fonts.cdnfonts.com/css/geist');\n\n    :root {\n        --color-bg: #0F1115;\n        --color-sidebar: #171A20;\n        --color-emerald: #076653;\n        --color-emerald-light: #0F8A6B;\n        --color-amber: #FF812B;\n        --border-subtle: rgba(255, 255, 255, 0.05);\n    }\n\n    /* Base structure */\n    .fingo-app-container {\n        background-color: var(--color-bg);\n        color: white;\n        font-family: 'Geist', sans-serif;\n        display: flex;\n        height: 100vh;\n        width: 100%;\n        overflow: hidden;\n    }\n\n    .font-logo { font-family: 'Cormorant Garamond', serif; }\n    \n    /* Custom Scrollbar */\n    .fingo-app-container ::-webkit-scrollbar { width: 4px; }\n    .fingo-app-container ::-webkit-scrollbar-track { background: var(--color-bg); }\n    .fingo-app-container ::-webkit-scrollbar-thumb { background: #333; border-radius: 10px; }\n\n    /* Slider logic classes */\n    .ramp-container {\n        height: 550px;\n        width: 180px;\n        background: #1e222a;\n        border-radius: 32px;\n        position: relative;\n        overflow: hidden;\n        border: 1px solid var(--border-subtle);\n        box-shadow: inset 0 4px 12px rgba(0,0,0,0.6);\n    }\n\n    .handle {\n        position: absolute;\n        left: 50%;\n        transform: translateX(-50%);\n        width: 190px;\n        height: 32px;\n        z-index: 30;\n        cursor: ns-resize;\n    }\n\n    .handle-visual {\n        width: 100%;\n        height: 100%;\n        background: rgba(255, 255, 255, 0.15);\n        backdrop-filter: blur(20px);\n        border: 1px solid rgba(255, 255, 255, 0.3);\n        border-radius: 8px;\n        box-shadow: 0 10px 30px rgba(0,0,0,0.5);\n        display: flex;\n        align-items: center;\n        justify-content: center;\n        transition: all 0.2s ease-out;\n    }\n\n    .handle:hover .handle-visual {\n        background: rgba(255, 255, 255, 0.25);\n        border-color: rgba(255, 255, 255, 0.5);\n        transform: scale(1.02);\n    }\n\n    .handle-line {\n        width: 30px;\n        height: 1px;\n        background: rgba(255, 255, 255, 0.6);\n    }\n\n    .segment-label {\n        position: absolute;\n        left: 0;\n        width: 100%;\n        text-align: center;\n        pointer-events: none;\n    }\n\n    .chart-grid line {\n        stroke: rgba(255, 255, 255, 0.05);\n        stroke-width: 1;\n    }\n\n    .btn-primary {\n        background-color: var(--color-emerald);\n        color: white;\n        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);\n    }\n    .btn-primary:hover {\n        background-color: var(--color-emerald-light);\n        transform: translateY(-1px);\n    }\n\n    .content-wrapper {\n        padding-bottom: 120px; \n    }\n</style>\n\n<div class=\"fingo-app-container\" data-kid=\"1\">\n    \n    <aside class=\"sidebar-nav w-20 lg:w-64 bg-[var(--color-sidebar)] border-r border-white/5 flex flex-col py-8 z-50\" data-kid=\"2\">\n        <div class=\"px-8 mb-16 flex items-center space-x-3\" data-kid=\"3\">\n            <div class=\"w-8 h-8 bg-[var(--color-emerald)] rounded-lg flex items-center justify-center\" data-kid=\"4\">\n                <span class=\"font-logo text-xl font-bold\" data-kid=\"5\">F</span>\n            </div>\n            <span class=\"font-logo text-2xl font-bold hidden lg:block\" data-kid=\"6\">Fingo AI</span>\n        </div>\n\n        <nav class=\"flex-1 px-6 space-y-1\" data-kid=\"7\">\n            <a href=\"#\" class=\"flex items-center space-x-4 px-4 py-3 text-white/40 hover:text-white hover:bg-white/5 rounded-xl transition-all\" data-kid=\"8\">\n                <i class=\"ti ti-layout-dashboard text-xl\" data-kid=\"9\"></i>\n                <span class=\"font-medium hidden lg:block\" data-kid=\"10\">Overview</span>\n            </a>\n            <a href=\"#\" class=\"flex items-center space-x-4 px-4 py-3 text-white/40 hover:text-white hover:bg-white/5 rounded-xl transition-all\" data-kid=\"11\">\n                <i class=\"ti ti-arrows-left-right text-xl\" data-kid=\"12\"></i>\n                <span class=\"font-medium hidden lg:block\" data-kid=\"13\">Transactions</span>\n            </a>\n            <a href=\"#\" class=\"flex items-center space-x-4 px-4 py-3 bg-[var(--color-emerald)]/10 text-[var(--color-emerald-light)] rounded-xl transition-all\" data-kid=\"14\">\n                <i class=\"ti ti-adjustments-horizontal text-xl\" data-kid=\"15\"></i>\n                <span class=\"font-medium hidden lg:block\" data-kid=\"16\">Optimizer</span>\n            </a>\n            <a href=\"#\" class=\"flex items-center space-x-4 px-4 py-3 text-white/40 hover:text-white hover:bg-white/5 rounded-xl transition-all\" data-kid=\"17\">\n                <i class=\"ti ti-target-arrow text-xl\" data-kid=\"18\"></i>\n                <span class=\"font-medium hidden lg:block\" data-kid=\"19\">Goals</span>\n            </a>\n        </nav>\n\n        <div class=\"mt-auto px-6 pt-8 border-t border-white/5\" data-kid=\"20\">\n            <div class=\"flex items-center space-x-3 px-2 py-4 cursor-pointer hover:bg-white/5 rounded-xl transition-all\" data-kid=\"21\">\n                <img src=\"https://i.pravatar.cc/100?u=fingo\" alt=\"Avatar\" class=\"w-8 h-8 rounded-full border border-white/10\" decoding=\"async\" loading=\"lazy\" data-kid=\"22\">\n                <div class=\"hidden lg:block\" data-kid=\"23\">\n                    <p class=\"text-sm font-bold truncate\" data-kid=\"24\">Aryan Sharma</p>\n                    <p class=\"text-xs text-white/30 truncate\" data-kid=\"25\">Free Plan</p>\n                </div>\n            </div>\n        </div>\n    </aside>\n\n    \n    <main class=\"flex-1 overflow-y-auto bg-[var(--color-bg)]\" data-kid=\"26\">\n        <header class=\"top-header sticky top-0 px-12 py-6 flex items-center justify-between bg-[var(--color-bg)]/80 backdrop-blur-xl border-b border-white/5 z-40\" data-kid=\"27\">\n            <div data-kid=\"28\">\n                <h1 class=\"text-xl font-bold\" data-kid=\"29\">Budget Optimizer</h1>\n            </div>\n            <div class=\"flex items-center space-x-6\" data-kid=\"30\">\n                <div class=\"hidden md:flex items-center bg-white/5 rounded-full px-4 py-2 border border-white/10\" data-kid=\"31\">\n                    <i class=\"ti ti-search text-white/30 mr-2\" data-kid=\"32\"></i>\n                    <input type=\"text\" placeholder=\"Search parameters...\" class=\"bg-transparent border-none text-sm outline-hidden w-48 text-white\" data-kid=\"33\">\n                </div>\n                <button class=\"w-10 h-10 flex items-center justify-center bg-white/5 hover:bg-white/10 rounded-full transition-all\" data-kid=\"34\">\n                    <i class=\"ti ti-bell\" data-kid=\"35\"></i>\n                </button>\n            </div>\n        </header>\n\n        <div class=\"content-wrapper p-12 max-w-7xl mx-auto space-y-12\" data-kid=\"36\">\n            \n            <div class=\"animate-card grid grid-cols-1 md:grid-cols-12 bg-white/[0.02] border border-white/10 rounded-[32px] overflow-hidden items-center group\" data-kid=\"37\">\n                <div class=\"md:col-span-8 p-10\" data-kid=\"38\">\n                    <div class=\"flex items-center space-x-3 mb-4\" data-kid=\"39\">\n                        <div class=\"w-8 h-8 bg-[var(--color-emerald)]/20 border border-[var(--color-emerald)]/40 rounded-lg flex items-center justify-center\" data-kid=\"40\">\n                            <i class=\"ti ti-sparkles text-[var(--color-emerald-light)] text-lg\" data-kid=\"41\"></i>\n                        </div>\n                        <span class=\"text-xs font-bold text-[var(--color-emerald-light)] uppercase tracking-wider\" data-kid=\"42\">Efficiency Detected</span>\n                    </div>\n                    <h2 class=\"text-2xl font-bold mb-3\" data-kid=\"43\">AI Optimization Hub</h2>\n                    <p class=\"text-white/50 leading-relaxed max-w-2xl\" data-kid=\"44\">\n                        Based on your real spending, shifting <span class=\"text-white font-medium\" data-kid=\"45\">₹12,500</span> from 'Wants' to 'Savings' results in a <span class=\"text-[var(--color-emerald-light)] font-bold\" data-kid=\"46\">14.2%</span> increase in your annual savings capacity.\n                    </p>\n                </div>\n                <div class=\"md:col-span-4 h-full relative min-h-[200px] bg-black/40\" data-kid=\"47\">\n                    <img src=\"https://images.unsplash.com/photo-1692900856320-91a898b7ecbb?auto=format&w=600&q=80&fit=crop\" alt=\"AI Robot\" class=\"absolute inset-0 w-full h-full object-cover opacity-60 group-hover:opacity-100 transition-all duration-700\" decoding=\"async\" loading=\"lazy\" data-kid=\"48\">\n                </div>\n            </div>\n\n            \n            <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-12 items-start\" data-kid=\"49\">\n                \n                \n                <div class=\"animate-card lg:col-span-4 flex flex-col items-center\" data-kid=\"50\">\n                    <div class=\"w-full mb-8\" data-kid=\"51\">\n                        <h3 class=\"text-sm font-bold text-white/40 mb-1\" data-kid=\"52\">Dynamic Allocation</h3>\n                        <p class=\"text-xs text-white/20\" data-kid=\"53\">Drag the handles to modify budget flow</p>\n                    </div>\n\n                    <div class=\"ramp-container\" id=\"ramp-root\" data-kid=\"54\">\n                        \n                        <div id=\"segment-needs\" class=\"absolute bottom-0 w-full bg-[var(--color-emerald)]/40 transition-all duration-200\" style=\"height: 50%;\" data-kid=\"55\">\n                            <div class=\"segment-label top-1/2 -translate-y-1/2\" data-kid=\"56\">\n                                <span class=\"block text-[10px] font-bold text-white/40 uppercase\" data-kid=\"57\">Needs</span>\n                                <span id=\"val-needs\" class=\"text-2xl font-bold\" data-kid=\"58\">50%</span>\n                            </div>\n                        </div>\n                        \n                        <div id=\"segment-wants\" class=\"absolute w-full bg-[var(--color-emerald)]/20 border-y border-white/5 transition-all duration-200\" style=\"height: 30%; bottom: 50%;\" data-kid=\"59\">\n                            <div class=\"segment-label top-1/2 -translate-y-1/2\" data-kid=\"60\">\n                                <span class=\"block text-[10px] font-bold text-white/40 uppercase\" data-kid=\"61\">Wants</span>\n                                <span id=\"val-wants\" class=\"text-2xl font-bold\" data-kid=\"62\">30%</span>\n                            </div>\n                        </div>\n                        \n                        <div id=\"segment-savings\" class=\"absolute top-0 w-full bg-[var(--color-emerald)] transition-all duration-200\" style=\"height: 20%;\" data-kid=\"63\">\n                            <div class=\"segment-label top-1/2 -translate-y-1/2\" data-kid=\"64\">\n                                <span class=\"block text-[10px] font-bold text-white/40 uppercase\" data-kid=\"65\">Savings</span>\n                                <span id=\"val-savings\" class=\"text-2xl font-bold\" data-kid=\"66\">20%</span>\n                            </div>\n                        </div>\n\n                        \n                        <div id=\"handle-1\" class=\"handle\" style=\"bottom: 50%;\" data-kid=\"67\">\n                            <div class=\"handle-visual\" data-kid=\"68\"><div class=\"handle-line\" data-kid=\"69\"></div></div>\n                        </div>\n                        <div id=\"handle-2\" class=\"handle\" style=\"bottom: 80%;\" data-kid=\"70\">\n                            <div class=\"handle-visual\" data-kid=\"71\"><div class=\"handle-line\" data-kid=\"72\"></div></div>\n                        </div>\n                    </div>\n\n                    <div class=\"w-full mt-10 grid grid-cols-2 gap-4\" data-kid=\"73\">\n                        <div class=\"p-4 bg-white/5 border border-white/5 rounded-2xl\" data-kid=\"74\">\n                            <p class=\"text-[10px] font-bold text-white/30 uppercase mb-1\" data-kid=\"75\">Monthly</p>\n                            <p class=\"font-bold\" data-kid=\"76\">₹85,000</p>\n                        </div>\n                        <div class=\"p-4 bg-white/5 border border-white/5 rounded-2xl\" data-kid=\"77\">\n                            <p class=\"text-[10px] font-bold text-white/30 uppercase mb-1\" data-kid=\"78\">Disposable</p>\n                            <p class=\"font-bold text-[var(--color-emerald-light)]\" data-kid=\"79\">₹12,450</p>\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"animate-card lg:col-span-8 space-y-12\" data-kid=\"80\">\n                    \n                    <div class=\"space-y-8\" data-kid=\"81\">\n                        <div data-kid=\"82\">\n                            <h2 class=\"text-2xl font-bold mb-1\" data-kid=\"83\">What-If Simulator</h2>\n                            <p class=\"text-sm text-white/40\" data-kid=\"84\">Real-time projection based on current sliders</p>\n                        </div>\n\n                        <div class=\"grid grid-cols-2 gap-8\" data-kid=\"85\">\n                            <div class=\"border-l-2 border-[var(--color-emerald)] pl-6 py-2\" data-kid=\"86\">\n                                <p class=\"text-xs font-bold text-white/30 uppercase mb-2\" data-kid=\"87\">Annual Target</p>\n                                <div class=\"flex items-baseline space-x-2\" data-kid=\"88\">\n                                    <span class=\"text-4xl font-bold text-[var(--color-emerald-light)]\" id=\"savings-counter\" data-kid=\"89\">₹204,000</span>\n                                </div>\n                                <p class=\"text-[10px] text-emerald-400 mt-2 flex items-center\" data-kid=\"90\">\n                                    <i class=\"ti ti-arrow-up-right mr-1\" data-kid=\"91\"></i> + ₹14,200 vs baseline\n                                </p>\n                            </div>\n                            <div class=\"border-l-2 border-[var(--color-amber)] pl-6 py-2\" data-kid=\"92\">\n                                <p class=\"text-xs font-bold text-white/30 uppercase mb-2\" data-kid=\"93\">5-Year Growth</p>\n                                <div class=\"flex items-baseline space-x-2\" data-kid=\"94\">\n                                    <span class=\"text-4xl font-bold text-[var(--color-amber)]\" id=\"wealth-counter\" data-kid=\"95\">₹1.42M</span>\n                                </div>\n                                <p class=\"text-[10px] text-white/40 mt-2\" data-kid=\"96\">Compounded @ 8.2%</p>\n                            </div>\n                        </div>\n\n                        \n                        <div class=\"bg-white/[0.02] border border-white/5 p-8 rounded-3xl h-64 relative overflow-hidden\" data-kid=\"97\">\n                            <svg class=\"w-full h-full\" viewBox=\"0 0 800 200\" data-kid=\"98\">\n                                \n                                <g class=\"chart-grid\" data-kid=\"99\">\n                                    <line x1=\"0\" y1=\"40\" x2=\"800\" y2=\"40\" data-kid=\"100\"></line>\n                                    <line x1=\"0\" y1=\"80\" x2=\"800\" y2=\"80\" data-kid=\"101\"></line>\n                                    <line x1=\"0\" y1=\"120\" x2=\"800\" y2=\"120\" data-kid=\"102\"></line>\n                                    <line x1=\"0\" y1=\"160\" x2=\"800\" y2=\"160\" data-kid=\"103\"></line>\n                                    <line x1=\"100\" y1=\"0\" x2=\"100\" y2=\"200\" data-kid=\"104\"></line>\n                                    <line x1=\"300\" y1=\"0\" x2=\"300\" y2=\"200\" data-kid=\"105\"></line>\n                                    <line x1=\"500\" y1=\"0\" x2=\"500\" y2=\"200\" data-kid=\"106\"></line>\n                                    <line x1=\"700\" y1=\"0\" x2=\"700\" y2=\"200\" data-kid=\"107\"></line>\n                                </g>\n                                \n                                <text x=\"10\" y=\"195\" fill=\"rgba(255,255,255,0.2)\" font-size=\"10\" data-kid=\"108\">2024</text>\n                                <text x=\"310\" y=\"195\" fill=\"rgba(255,255,255,0.2)\" font-size=\"10\" data-kid=\"109\">2026</text>\n                                <text x=\"710\" y=\"195\" fill=\"rgba(255,255,255,0.2)\" font-size=\"10\" data-kid=\"110\">2029</text>\n                                \n                                <path id=\"projection-line\" d=\"M0,180 C200,170 400,120 800,40\" fill=\"none\" stroke=\"var(--color-emerald-light)\" stroke-width=\"3\" stroke-linecap=\"round\" data-kid=\"111\"></path>\n                                <circle id=\"chart-marker\" cx=\"400\" cy=\"120\" r=\"4\" fill=\"var(--color-emerald-light)\" data-kid=\"112\"></circle>\n                                <text id=\"chart-label\" x=\"410\" y=\"115\" fill=\"white\" font-size=\"10\" font-weight=\"bold\" data-kid=\"113\">AI Optimal</text>\n                            </svg>\n                        </div>\n                    </div>\n\n                    \n                    <div class=\"grid grid-cols-1 md:grid-cols-2 gap-12\" data-kid=\"114\">\n                        <div class=\"space-y-6\" data-kid=\"115\">\n                            <h4 class=\"text-xs font-bold text-white/40 uppercase tracking-widest\" data-kid=\"116\">Savings Opportunities</h4>\n                            <div class=\"space-y-4\" data-kid=\"117\">\n                                <div class=\"flex items-center justify-between p-4 bg-white/[0.02] border-b border-white/5 hover:bg-white/5 transition-all group cursor-pointer\" data-kid=\"118\">\n                                    <div class=\"flex items-center space-x-4\" data-kid=\"119\">\n                                        <i class=\"ti ti-coin text-[var(--color-emerald-light)] opacity-40 group-hover:opacity-100 transition-opacity\" data-kid=\"120\"></i>\n                                        <span class=\"text-sm font-medium\" data-kid=\"121\">Liquid Fund Rebalance</span>\n                                    </div>\n                                    <span class=\"text-xs font-bold text-[var(--color-emerald-light)]\" data-kid=\"122\">+ ₹1,400</span>\n                                </div>\n                                <div class=\"flex items-center justify-between p-4 bg-white/[0.02] border-b border-white/5 hover:bg-white/5 transition-all group cursor-pointer\" data-kid=\"123\">\n                                    <div class=\"flex items-center space-x-4\" data-kid=\"124\">\n                                        <i class=\"ti ti-credit-card text-white/20 group-hover:text-[var(--color-amber)] transition-colors\" data-kid=\"125\"></i>\n                                        <span class=\"text-sm font-medium\" data-kid=\"126\">Debt Refinance Tool</span>\n                                    </div>\n                                    <span class=\"text-xs font-bold text-[var(--color-amber)]\" data-kid=\"127\">- 2.4% APR</span>\n                                </div>\n                            </div>\n                        </div>\n\n                        <div class=\"space-y-6\" data-kid=\"128\">\n                            <h4 class=\"text-xs font-bold text-white/40 uppercase tracking-widest\" data-kid=\"129\">Redundant Subs</h4>\n                            <div class=\"bg-black/20 rounded-2xl overflow-hidden divide-y divide-white/5 border border-white/5\" data-kid=\"130\">\n                                <div class=\"p-4 flex items-center justify-between text-sm hover:bg-white/5 transition-colors group\" data-kid=\"131\">\n                                    <span class=\"text-white/60\" data-kid=\"132\">Adobe Creative Cloud</span>\n                                    <div class=\"flex items-center space-x-3\" data-kid=\"133\">\n                                        <span class=\"font-mono\" data-kid=\"134\">₹799</span>\n                                        <button class=\"text-red-500/50 hover:text-red-500 transition-colors\" data-kid=\"135\"><i class=\"ti ti-trash\" data-kid=\"136\"></i></button>\n                                    </div>\n                                </div>\n                                <div class=\"p-4 flex items-center justify-between text-sm hover:bg-white/5 transition-colors group\" data-kid=\"137\">\n                                    <span class=\"text-white/60\" data-kid=\"138\">LinkedIn Premium</span>\n                                    <div class=\"flex items-center space-x-3\" data-kid=\"139\">\n                                        <span class=\"font-mono\" data-kid=\"140\">₹650</span>\n                                        <button class=\"text-red-500/50 hover:text-red-500 transition-colors\" data-kid=\"141\"><i class=\"ti ti-trash\" data-kid=\"142\"></i></button>\n                                    </div>\n                                </div>\n                                <div class=\"p-4 bg-[var(--color-amber)]/10 text-center\" data-kid=\"143\">\n                                    <button class=\"text-xs font-bold text-[var(--color-amber)] uppercase tracking-widest hover:underline transition-all\" data-kid=\"144\">Auto-Purge Selected</button>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n\n                    \n                    <div class=\"flex items-center justify-end space-x-6 pt-10 border-t border-white/5\" data-kid=\"145\">\n                        <button class=\"text-sm text-white/30 hover:text-white transition-colors\" data-kid=\"146\">Reset Baseline</button>\n                        <button class=\"btn-primary px-10 py-4 rounded-full font-bold shadow-xl shadow-[var(--color-emerald)]/20\" data-kid=\"147\">Apply Budget Plan</button>\n                    </div>\n\n                </div>\n\n            </div>\n        </div>\n    </main>\n\n    \n    <div class=\"fixed bottom-10 right-10 flex flex-col items-center space-y-4 z-50 group\" data-kid=\"148\">\n        <button class=\"w-14 h-14 bg-[var(--color-emerald)] rounded-full flex items-center justify-center shadow-2xl shadow-[var(--color-emerald)]/40 hover:scale-110 transition-transform relative\" data-kid=\"149\">\n            <i class=\"ti ti-message-2 text-2xl\" data-kid=\"150\"></i>\n            <span class=\"absolute -top-1 -right-1 w-5 h-5 bg-[var(--color-amber)] rounded-full border-2 border-[var(--color-bg)] flex items-center justify-center text-[10px] font-bold text-black\" data-kid=\"151\">1</span>\n        </button>\n    </div>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"152\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"153\"></script>\n<script data-kid=\"154\">\n    gsap.registerPlugin(ScrollTrigger);\n\n    // GSAP Entrances\n    gsap.from(\".sidebar-nav\", { x: -60, opacity: 0, duration: 1, ease: \"expo.out\" });\n    gsap.from(\".top-header\", { y: -30, opacity: 0, duration: 0.8, delay: 0.2, ease: \"power2.out\" });\n    gsap.from(\".animate-card\", { \n        y: 40, \n        opacity: 0, \n        duration: 1.2, \n        delay: 0.4, \n        stagger: 0.15, \n        ease: \"expo.out\" \n    });\n</script>\n<script type=\"module\" data-kid=\"155\">\n    // Slider Logic\n    const rampRoot = document.getElementById('ramp-root');\n    const handle1 = document.getElementById('handle-1');\n    const handle2 = document.getElementById('handle-2');\n    const segNeeds = document.getElementById('segment-needs');\n    const segWants = document.getElementById('segment-wants');\n    const segSavings = document.getElementById('segment-savings');\n    const valNeeds = document.getElementById('val-needs');\n    const valWants = document.getElementById('val-wants');\n    const valSavings = document.getElementById('val-savings');\n    const savingsCounter = document.getElementById('savings-counter');\n    const wealthCounter = document.getElementById('wealth-counter');\n    const projectionLine = document.getElementById('projection-line');\n    const marker = document.getElementById('chart-marker');\n    const label = document.getElementById('chart-label');\n\n    let h1Pos = 50; \n    let h2Pos = 80; \n\n    function updateUI() {\n        if (h2Pos <= h1Pos + 5) h2Pos = h1Pos + 5;\n        if (h1Pos >= h2Pos - 5) h1Pos = h2Pos - 5;\n\n        handle1.style.bottom = `${h1Pos}%`;\n        handle2.style.bottom = `${h2Pos}%`;\n\n        segNeeds.style.height = `${h1Pos}%`;\n        segWants.style.height = `${h2Pos - h1Pos}%`;\n        segWants.style.bottom = `${h1Pos}%`;\n        segSavings.style.height = `${100 - h2Pos}%`;\n\n        const needsVal = h1Pos;\n        const wantsVal = h2Pos - h1Pos;\n        const savingsVal = 100 - h2Pos;\n\n        valNeeds.textContent = `${needsVal}%`;\n        valWants.textContent = `${wantsVal}%`;\n        valSavings.textContent = `${savingsVal}%`;\n\n        const income = 85000;\n        const annual = (income * (savingsVal / 100)) * 12;\n        const wealth5yr = annual * 5 * 1.35;\n\n        savingsCounter.textContent = `₹${Math.round(annual).toLocaleString()}`;\n        wealthCounter.textContent = `₹${(wealth5yr / 1000000).toFixed(2)}M`;\n        \n        // Update Chart Path Dynamically\n        const curve = 180 - (savingsVal * 1.5);\n        const endY = curve - 80;\n        projectionLine.setAttribute('d', `M0,180 C200,175 400,${curve} 800,${endY}`);\n        \n        // Move Marker\n        marker.setAttribute('cy', curve);\n        label.setAttribute('y', curve - 5);\n    }\n\n    function attachSlider(el, type) {\n        let dragging = false;\n        el.addEventListener('pointerdown', (e) => {\n            dragging = true;\n            el.setPointerCapture(e.pointerId);\n        });\n        window.addEventListener('pointermove', (e) => {\n            if (!dragging) return;\n            const r = rampRoot.getBoundingClientRect();\n            let p = 100 - ((e.clientY - r.top) / r.height * 100);\n            p = Math.max(5, Math.min(95, p));\n            if (type === 1) h1Pos = Math.round(p);\n            else h2Pos = Math.round(p);\n            updateUI();\n        });\n        window.addEventListener('pointerup', () => dragging = false);\n    }\n\n    attachSlider(handle1, 1);\n    attachSlider(handle2, 2);\n    updateUI();\n</script>\n>>>>>>> REPLACE\n",
