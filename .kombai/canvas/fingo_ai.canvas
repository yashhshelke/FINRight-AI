      "html": "<div class=\"bg-[#0F1115] text-[#F8FAFC] font-inter selection:bg-[#FF812B] selection:text-white m-0 overflow-x-clip\" data-kid=\"0\">\n  \n  <style data-kid=\"1\">\n    @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@600&family=Geist:wght@400;700;900&family=Inter:wght@400;500;600&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n    :root {\n      --color-bg: #0F1115;\n      --color-surface: #1E222A;\n      --color-cta: #FF812B;\n      --color-success: #22C55E;\n      --font-logo: 'Cormorant Garamond', serif;\n      --font-heading: 'Geist', sans-serif;\n      --font-body: 'Inter', sans-serif;\n    }\n\n    .font-logo { font-family: var(--font-logo); }\n    .font-geist { font-family: var(--font-heading); }\n    .font-inter { font-family: var(--font-body); }\n\n    .grain-overlay {\n      position: fixed;\n      top: 0; left: 0; width: 100%; height: 100%;\n      pointer-events: none; z-index: 9999; opacity: 0.04;\n      background-image: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E\");\n    }\n\n    .glass {\n      background: rgba(255, 255, 255, 0.03);\n      backdrop-filter: blur(20px);\n      border: 1px solid rgba(255, 255, 255, 0.08);\n    }\n\n    .glass-card {\n      background: linear-gradient(135deg, rgba(30, 34, 42, 0.7) 0%, rgba(15, 17, 21, 0.8) 100%);\n      backdrop-filter: blur(24px);\n      border: 1px solid rgba(255, 255, 255, 0.06);\n      box-shadow: 0 30px 60px rgba(0,0,0,0.5), inset 0 1px 1px rgba(255,255,255,0.05);\n    }\n\n    /* Hero Arc Text Fix */\n    .arc-text {\n      position: absolute;\n      top: -100px;\n      left: 50%;\n      transform: translateX(-50%);\n      width: 1000px;\n      height: 1000px;\n      pointer-events: none;\n      z-index: 5;\n    }\n    .arc-text text {\n      fill: #F8FAFC;\n      font-family: var(--font-heading);\n      font-weight: 900;\n      font-size: 32px;\n      letter-spacing: 0.12em;\n      text-transform: uppercase;\n    }\n\n    /* Roadmap Visuals */\n    .roadmap-path {\n      fill: none;\n      stroke: rgba(255, 129, 43, 0.4);\n      stroke-width: 2.5;\n      stroke-dasharray: 10 14;\n      stroke-linecap: round;\n    }\n\n    .dock-bar {\n      background: rgba(30, 34, 42, 0.8);\n      backdrop-filter: blur(32px);\n      border: 1px solid rgba(255, 255, 255, 0.12);\n      padding: 10px;\n      border-radius: 30px;\n      box-shadow: 0 32px 64px -12px rgba(0, 0, 0, 0.8);\n    }\n    \n    .feature-glow {\n      position: absolute;\n      width: 400px;\n      height: 400px;\n      background: radial-gradient(circle, rgba(255, 129, 43, 0.05) 0%, transparent 70%);\n      pointer-events: none;\n      z-index: 0;\n    }\n  </style>\n\n  <link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" data-kid=\"2\">\n  <div class=\"grain-overlay\" data-kid=\"3\"></div>\n\n  \n  <header class=\"fixed top-0 left-0 w-full z-[100] px-12 py-10 flex items-center justify-between pointer-events-none\" data-kid=\"4\">\n    <div class=\"flex items-center gap-5 pointer-events-auto cursor-pointer group\" data-kid=\"5\">\n      <div class=\"w-14 h-14 glass rounded-2xl flex items-center justify-center border-white/10 group-hover:border-[#FF812B]/50 transition-all shadow-xl\" data-kid=\"6\">\n        <span class=\"font-logo text-3xl text-[#FF812B]\" data-kid=\"7\">F</span>\n      </div>\n      <span class=\"font-logo text-4xl tracking-tighter\" data-kid=\"8\">Fingo AI</span>\n    </div>\n\n    <div class=\"flex items-center gap-8 pointer-events-auto\" data-kid=\"9\">\n      <button class=\"font-geist text-sm font-bold text-[#94A3B8] hover:text-[#F8FAFC] transition-colors\" data-kid=\"10\">Login</button>\n      <butt