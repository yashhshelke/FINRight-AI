-91a898b7ecbb?auto=format&w=1200&q=80')] bg-cover bg-center\" data-kid=\"98\"></div>\n        \n        <div class=\"relative h-full flex items-center justify-center p-8 lg:p-12 overflow-y-auto\" data-kid=\"99\">\n          <div class=\"detail-container w-full max-w-5xl flex flex-col lg:flex-row items-stretch gap-8\" data-kid=\"100\">\n            \n            \n            <div class=\"lg:w-[45%] premium-panel rounded-3xl p-3 relative group flex-shrink-0\" data-kid=\"101\">\n              <div class=\"w-full h-full min-h-[550px] rounded-2xl overflow-hidden bg-black/40 border border-white/5 relative\" data-kid=\"102\">\n                <img src=\"https://images.unsplash.com/photo-1698750933104-bb2fd7dea9ff?auto=format&w=800&q=80\" alt=\"Document Preview\" class=\"w-full h-full object-cover opacity-80 group-hover:scale-105 transition-transform duration-[2000ms]\" decoding=\"async\" loading=\"lazy\" data-kid=\"103\">\n                \n                \n                <div class=\"absolute top-[20%] left-[15%] px-3 py-1 bg-[#171A20] border border-emerald-500/40 text-emerald-400 text-[11px] font-bold rounded shadow-xl animate-pulse\" data-kid=\"104\">\n                  MERCHANT: STARBUCKS\n                </div>\n                <div class=\"absolute bottom-[30%] right-[20%] px-3 py-1 bg-[#171A20] border border-amber-500/40 text-amber-400 text-[11px] font-bold rounded shadow-xl animate-pulse\" style=\"animation-delay: 1s;\" data-kid=\"105\">\n                  TOTAL: $14.50\n                </div>\n\n                \n                <div class=\"absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent\" data-kid=\"106\"></div>\n                \n                <div class=\"absolute bottom-6 left-6 right-6 flex items-center justify-between text-white/40\" data-kid=\"107\">\n                  <div class=\"flex items-center gap-3\" data-kid=\"108\">\n                    <i class=\"ti ti-scan text-xl\" data-kid=\"109\"></i>\n                    <span class=\"text-xs font-bold uppercase tracking-wider\" data-kid=\"110\">Neural Analysis Active</span>\n                  </div>\n                  <button class=\"w-9 h-9 rounded-full bg-white/5 border border-white/10 flex items-center justify-center hover:bg-white/10 transition-colors\" data-kid=\"111\">\n                    <i class=\"ti ti-maximize\" data-kid=\"112\"></i>\n                  </button>\n                </div>\n              </div>\n            </div>\n\n            \n            <div class=\"flex-1 flex flex-col gap-6\" data-kid=\"113\">\n              <div class=\"premium-panel rounded-3xl p-10 flex flex-col h-full space-y-8\" data-kid=\"114\">\n                \n                <div class=\"flex flex-col gap-2 border-b border-white/5 pb-8\" data-kid=\"115\">\n                  <div class=\"flex items-center justify-between\" data-kid=\"116\">\n                    <div class=\"flex items-center gap-3\" data-kid=\"117\">\n                      <div class=\"w-10 h-10 rounded-xl bg-emerald-500/10 flex items-center justify-center border border-emerald-500/20 text-emerald-400\" data-kid=\"118\">\n                        <i class=\"ti ti-ai text-2xl\" data-kid=\"119\"></i>\n                      </div>\n                      <h3 class=\"text-3xl font-black font-geist tracking-tight text-white\" data-kid=\"120\">Intelligence Hub</h3>\n                    </div>\n                    <div class=\"flex items-center gap-4\" data-kid=\"121\">\n                      <div class=\"text-right\" data-kid=\"122\">\n                        <span class=\"text-xs font-bold text-white/30 tracking-tight\" data-kid=\"123\">Data Quality</span>\n                        <div class=\"flex items-center gap-2 mt-1\" data-kid=\"124\">\n                          <span class=\"text-xl font-black text-emerald-400 font-geist\" data-kid=\"125\">98.4%</span>\n                          <div class=\"w-16 h-1.5 bg-white/5 rounded-full overflow-hidden\" data-kid=\"126\">\n                            <div class=\"h-full bg-emerald-500\" style=\"width: 98%\" data-kid=\"127\"></div>\n                          </div>\n                        </div>\n                      </div>\n                    </div>\n                  </div>\n                  <p class=\"text-sm text-white/30 font-medium\" data-kid=\"128\">Neural scan completed on June 12, 2024 • File: Starbucks_Receipt.pdf</p>\n                </div>\n\n                \n                <div class=\"space-y-6\" data-kid=\"129\">\n                  <div data-kid=\"130\">\n                    <span class=\"text-xs font-bold text-white/20 uppercase tracking-widest block mb-2\" data-kid=\"131\">Merchant Name</span>\n                    <h2 class=\"text-4xl font-black text-white font-geist leading-tight\" data-kid=\"132\">Starbucks Coffee</h2>\n                    <div class=\"flex items-center gap-2 mt-3 text-emerald-400/80\" data-kid=\"133\">\n                      <i class=\"ti ti-circle-check-filled\" data-kid=\"134\"></i>\n                      <span class=\"text-sm font-bold\" data-kid=\"135\">Verified Corporate Identity</span>\n                    </div>\n                  </div>\n\n                  <div class=\"py-6 border-y border-white/5 flex items-end justify-between\" data-kid=\"136\">\n                    <div class=\"space-y-1\" data-kid=\"137\">\n                      <span class=\"text-xs font-bold text-white/20 uppercase tracking-widest block mb-1\" data-kid=\"138\">Total Transaction Value</span>\n                      <div class=\"flex items-baseline gap-2\" data-kid=\"139\">\n                        <span class=\"text-5xl font-black text-white font-geist\" data-kid=\"140\">$14.50</span>\n                        <span class=\"text-lg font-bold text-white/20\" data-kid=\"141\">USD</span>\n                      </div>\n                    </div>\n                    <div class=\"text-right\" data-kid=\"142\">\n                       <p class=\"text-sm text-white/40 font-bold\" data-kid=\"143\">Tax Included ($1.25)</p>\n                       <p class=\"text-xs text-white/20\" data-kid=\"144\">VAT Receipt #782-AX</p>\n                    </div>\n                  </div>\n\n                  \n                  <div class=\"grid grid-cols-2 gap-8\" data-kid=\"145\">\n                    <div class=\"space-y-1\" data-kid=\"146\">\n                      <span class=\"text-xs font-bold text-white/20 uppercase tracking-widest block\" data-kid=\"147\">Date & Time</span>\n                      <p class=\"text-lg font-bold text-white/70\" data-kid=\"148\">12 June, 2024 <span class=\"text-white/20 ml-2\" data-kid=\"149\">14:32</span></p>\n                    </div>\n                    <div class=\"space-y-1\" data-kid=\"150\">\n                      <span class=\"text-xs font-bold text-white/20 uppercase tracking-widest block\" data-kid=\"151\">Spending Category</span>\n                      <p class=\"text-lg font-bold text-white/70\" data-kid=\"152\">Food & Dining <span class=\"text-white/20 ml-2\" data-kid=\"153\">Coffee</span></p>\n                    </div>\n                  </div>\n                </div>\n\n                \n                <div class=\"flex-1 bg-white/[0.02] border border-white/5 border-l-2 border-l-emerald-500/40 p-6 rounded-2xl flex flex-col justify-center shadow-inner\" data-kid=\"154\">\n                  <div class=\"flex items-center gap-3 mb-3\" data-kid=\"155\">\n                    <i class=\"ti ti-sparkles text-emerald-400 text-lg\" data-kid=\"156\"></i>\n                    <h4 class=\"text-xs font-black text-emerald-400/80 uppercase tracking-widest\" data-kid=\"157\">Autonomous Insight</h4>\n                  </div>\n                  <p class=\"text-base text-white/60 font-medium leading-relaxed italic\" data-kid=\"158\">\n                    \"This transaction marks your 4th visit to Starbucks this month. Spending is trending 15% higher than your average for the Dining category.\"\n                  </p>\n                </div>\n\n                \n                <div class=\"flex items-center gap-4 pt-4\" data-kid=\"159\">\n                  <button class=\"flex-1 bg-[var(--amber-cta)] hover:bg-[#ff954d] text-white font-black py-5 rounded-2xl flex items-center justify-center gap-3 shadow-2xl shadow-orange-500/10 active:scale-95 btn-export font-geist text-lg tracking-tight\" data-kid=\"160\">\n                    <i class=\"ti ti-external-link text-2xl\" data-kid=\"161\"></i>\n                    Export to Transactions\n                  </button>\n                  <button class=\"w-16 h-16 bg-white/5 border border-white/5 rounded-2xl flex items-center justify-center group transition-colors hover:bg-red-500/10\" data-kid=\"162\">\n                    <i class=\"ti ti-trash text-2xl text-white/20 group-hover:text-red-500 transition-colors\" data-kid=\"163\"></i>\n                  </button>\n                </div>\n              </div>\n            </div>\n\n          </div>\n        </div>\n      </section>\n    </div>\n  </main>\n</div>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"164\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"165\"></script>\n<script type=\"module\" data-kid=\"166\">\n  import { animate, stagger, inView } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n  import Lenis from \"https://esm.sh/lenis@1\"\n\n  // Init Lenis\n  const lenis = new Lenis({ autoRaf: true });\n\n  // Initial Entrance Animations\n  window.addEventListener('load', () => {\n    // GSAP for master list stagger\n    gsap.from('.document-item', {\n      opacity: 0,\n      x: -30,\n      duration: 0.8,\n      stagger: 0.1,\n      ease: 'power4.out',\n      delay: 0.2\n    });\n\n    // GSAP for detail panel entrance\n    gsap.from('.detail-container', {\n      opacity: 0,\n      y: 40,\n      duration: 1.2,\n      ease: 'power3.out',\n      delay: 0.4\n    });\n\n    // Badge spring pops\n    animate('.badge', \n      { scale: [0.8, 1], opacity: [0, 1] }, \n      { type: 'spring', visualDuration: 0.5, bounce: 0.6, delay: stagger(0.1, { startDelay: 0.6 }) }\n    );\n  });\n\n  // Interaction: Document List Item Click\n  document.querySelectorAll('.document-item').forEach(item => {\n    item.addEventListener('mouseenter', () => {\n      gsap.to(item, { y: -4, backgroundColor: 'rgba(255, 255, 255, 0.08)', duration: 0.3 });\n    });\n    item.addEventListener('mouseleave', () => {\n      // Check if it's the selected one\n      const isSelected = item.classList.contains('bg-emerald-500/5');\n      gsap.to(item, { \n        y: 0, \n        backgroundColor: isSelected ? 'rgba(7, 102, 83, 0.1)' : 'rgba(255, 255, 255, 0.03)', \n        duration: 0.3 \n      });\n    });\n  });\n\n  // Export button interaction\n  const exportBtn = document.querySelector('.btn-export');\n  exportBtn.addEventListener('mouseenter', () => {\n    gsap.to(exportBtn, { scale: 1.02, boxShadow: '0 10px 25px rgba(255, 129, 43, 0.4)', duration: 0.3 });\n  });\n  exportBtn.addEventListener('mouseleave', () => {\n    gsap.to(exportBtn, { scale: 1, boxShadow: '0 8px 32px 0 rgba(0, 0, 0, 0.3)', duration: 0.3 });\n  });\n  exportBtn.addEventListener('click', () => {\n    animate(exportBtn, { scale: [1, 0.95, 1] }, { duration: 0.2 });\n  });\n\n</script>\n",
