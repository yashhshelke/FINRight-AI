      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,600;1,600&family=Inter:wght@400;500;600&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/geist@1.3.0/dist/fonts/geist-sans/style.css');\n\n  :root {\n    --bg: #0F1115;\n    --surface: #171A20;\n    --brand: #076653;\n    --brand-light: #0F8A6B;\n    --cta: #FF812B;\n    --text-primary: #F8FAFC;\n    --text-secondary: #94A3B8;\n  }\n\n  body {\n    background-color: var(--bg);\n    color: var(--text-primary);\n    font-family: 'Inter', sans-serif;\n    overflow-x: clip;\n    margin: 0;\n  }\n\n  .font-geist { font-family: 'Geist Sans', sans-serif; }\n  .font-logo { font-family: 'Cormorant Garamond', serif; }\n\n  .glass {\n    background: rgba(255, 255, 255, 0.03);\n    backdrop-filter: blur(20px);\n    border: 1px solid rgba(255, 255, 255, 0.08);\n    box-shadow: inset 0 0 20px rgba(255, 255, 255, 0.02);\n  }\n\n  .radial-glow {\n    background: radial-gradient(circle at 50% 50%, rgba(15, 138, 107, 0.12), transparent 70%);\n  }\n\n  .hero-glow {\n    background: radial-gradient(circle at center, rgba(7, 102, 83, 0.2) 0%, transparent 70%);\n  }\n\n  .widget-card {\n    opacity: 0;\n    transform: translateY(30px);\n  }\n\n  /* Custom Scrollbar */\n  ::-webkit-scrollbar { width: 8px; }\n  ::-webkit-scrollbar-track { background: var(--bg); }\n  ::-webkit-scrollbar-thumb { background: #333; border-radius: 10px; }\n  ::-webkit-scrollbar-thumb:hover { background: #444; }\n\n  /* Smooth reveal for content */\n  .reveal { opacity: 0; transform: translateY(20px); }\n</style>\n\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" data-kid=\"1\">\n<link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" data-kid=\"2\">\n\n\n<nav class=\"fixed top-0 left-0 w-full z-50 px-8 py-6 flex justify-between items-center bg-transparent backdrop-blur-sm\" data-kid=\"3\">\n  <div class=\"flex items-center gap-12\" data-kid=\"4\">\n    <a href=\"#\" class=\"font-logo text-3xl font-bold tracking-tight text-white flex items-center gap-2\" data-kid=\"5\">\n      <div class=\"w-8 h-8 bg-gradient-to-br from-[var(--brand)] to-[var(--brand-light)] rounded-lg rotate-12 flex items-center justify-center\" data-kid=\"6\">\n        <span class=\"text-white text-xs rotate-[-12deg]\" data-kid=\"7\">F</span>\n      </div>\n      FINGO AI\n    </a>\n    <div class=\"hidden lg:flex items-center gap-8 text-sm font-medium text-[var(--text-secondary)]\" data-kid=\"8\">\n      <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"9\">Platform</a>\n      <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"10\">Solutions</a>\n      <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"11\">Pricing</a>\n      <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"12\">Company</a>\n    </div>\n  </div>\n  <div class=\"flex items-center gap-4\" data-kid=\"13\">\n    <button class=\"px-6 py-2 text-sm font-semibold text-white hover:text-[var(--brand-light)] transition-colors\" data-kid=\"14\">Log In</button>\n    <button class=\"px-6 py-2 bg-[var(--brand)] hover:bg-[var(--brand-light)] text-white rounded-xl text-sm font-semibold transition-all\" data-kid=\"15\">Get Started</button>\n  </div>\n</nav>\n\n\n<section id=\"hero-story\" class=\"relative bg-[var(--bg)]\" data-kid=\"16\">\n  \n  <div id=\"hero-content\" class=\"relative min-h-screen flex items-center z-20 px-8 lg:px-16 pt-24\" data-kid=\"17\">\n    <div class=\"container mx-auto grid lg:grid-cols-2 items-center\" data-kid=\"18\">\n      <div class=\"max-w-2xl\" data-kid=\"19\">\n        <h1 class=\"font-geist text-6xl lg:text-[84px] font-bold leading-[1.05] tracking-tight mb-8\" data-kid=\"20\">\n          Track your money.<br data-kid=\"21\">\n          <span class=\"text-white/40\" data-kid=\"22\">Build your future.</span>\n        </h1>\n        <p class=\"text-xl text-[var(--text-secondary)] mb-12 max-w-lg leading-relaxed\" data-kid=\"23\">\n          Your personal finance operating system powered by intelligent insights. Experience the next generation of wealth management.\n        </p>\n        \n        <div class=\"glass p-1.5 rounded-2xl flex items-center max-w-md gap-2 shadow-2xl\" data-kid=\"24\">\n          <div class=\"flex-grow flex items-center pl-4 gap-3\" data-kid=\"25\">\n            <i class=\"ti ti-mail text-slate-500\" data-kid=\"26\"></i>\n            <input type=\"email\" placeholder=\"work@email.com\" class=\"bg-transparent border-none outline-none py-3 w-full text-white placeholder:text-slate-500 font-medium\" data-kid=\"27\">\n          </div>\n          <button class=\"bg-[var(--cta)] hover:brightness-110 text-white px-8 py-3 rounded-xl font-bold transition-all shadow-lg shadow-[var(--cta)]/20\" data-kid=\"28\">\n            Start Free\n          </button>\n        </div>\n        \n        <div class=\"mt-8 flex items-center gap-6 text-sm text-[var(--text-secondary)]\" data-kid=\"29\">\n          <div class=\"flex -space-x-3\" data-kid=\"30\">\n            <img src=\"https://i.pravatar.cc/100?u=1\" class=\"w-8 h-8 rounded-full border-2 border-[var(--bg)]\" alt=\"User\" data-kid=\"31\">\n            <img src=\"https://i.pravatar.cc/100?u=2\" class=\"w-8 h-8 rounded-full border-2 border-[var(--bg)]\" alt=\"User\" data-kid=\"32\">\n            <img src=\"https://i.pravatar.cc/100?u=3\" class=\"w-8 h-8 rounded-full border-2 border-[var(--bg)]\" alt=\"User\" data-kid=\"33\">\n          </div>\n          <span data-kid=\"34\">Joined by 12,000+ early adopters</span>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  \n  <div id=\"story-scene\" class=\"h-[200vh]\" data-kid=\"35\">\n    <div class=\"sticky top-0 h-screen flex items-center justify-center overflow-hidden\" data-kid=\"36\">\n      \n      <div class=\"absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(7,102,83,0.15)_0%,transparent_70%)]\" data-kid=\"37\"></div>\n      \n      \n      <div id=\"pinned-robot\" class=\"relative z-20 w-[450px] h-[450px]\" data-kid=\"38\">\n        <img src=\"https://images.unsplash.com/photo-1698750933104-bb2fd7dea9ff?auto=format&w=800&q=80\" class=\"w-full h-full object-contain filter brightness-110 drop-shadow-[0_0_80px_rgba(7,102,83,0.3)]\" alt=\"AI Companion\" decoding=\"async\" loading=\"lazy\" data-kid=\"39\">\n        \n        <div class=\"absolute -top-10 -left-10 glass px-3 py-1 rounded-full text-[10px] font-bold text-[var(--brand-light)] animate-pulse\" data-kid=\"40\">AI ACTIVE</div>\n        <div class=\"absolute -bottom-10 -right-10 glass px-3 py-1 rounded-full text-[10px] font-bold text-orange-500 animate-pulse\" style=\"animation-delay: 1s;\" data-kid=\"41\">REAL-TIME SYNC</div>\n      </div>\n\n      \n      <div id=\"widget-balance\" class=\"widget-card absolute glass p-8 rounded-3xl w-72 z-30\" style=\"top: 15%; left: 10%;\" data-kid=\"42\">\n        <div class=\"flex justify-between items-start mb-6\" data-kid=\"43\">\n          <div data-kid=\"44\">\n            <p class=\"text-xs font-bold uppercase tracking-widest text-[var(--text-secondary)] mb-2\" data-kid=\"45\">Net Balance</p>\n            <h3 class=\"text-3xl font-bold font-geist\" data-kid=\"46\">$42,850.50</h3>\n          </div>\n          <div class=\"p-3 bg-[var(--brand)] rounded-xl\" data-kid=\"47\">\n            <i class=\"ti ti-wallet text-white text-xl\" data-kid=\"48\"></i>\n          </div>\n        </div>\n        <div class=\"h-1 w-full bg-white/10 rounded-full\" data-kid=\"49\">\n          <div class=\"h-full bg-emerald-500 w-3/4\" data-kid=\"50\"></div>\n        </div>\n      </div>\n\n      <div id=\"widget-savings\" class=\"widget-card absolute glass p-8 rounded-3xl w-80 z-30\" style=\"bottom: 15%; left: 15%;\" data-kid=\"51\">\n        <p class=\"text-xs font-bold uppercase tracking-widest text-[var(--text-secondary)] mb-4\" data-kid=\"52\">Savings Progress</p>\n        <div class=\"space-y-4\" data-kid=\"53\">\n          <div class=\"flex justify-between items-end\" data-kid=\"54\">\n            <h3 class=\"text-2xl font-bold font-geist\" data-kid=\"55\">Dream Home</h3>\n            <span class=\"text-[var(--brand-light)] font-bold\" data-kid=\"56\">64%</span>\n          </div>\n          <div class=\"flex gap-1.5 h-12 items-end\" data-kid=\"57\">\n            <div class=\"w-full bg-[var(--brand)]/40 h-[40%] rounded-t-lg\" data-kid=\"58\"></div>\n            <div class=\"w-full bg-[var(--brand)]/60 h-[55%] rounded-t-lg\" data-kid=\"59\"></div>\n            <div class=\"w-full bg-[var(--brand)] h-[64%] rounded-t-lg\" data-kid=\"60\"></div>\n            <div class=\"w-full bg-white/10 h-[30%] rounded-t-lg\" data-kid=\"61\"></div>\n            <div class=\"w-full bg-white/10 h-[20%] rounded-t-lg\" data-kid=\"62\"></div>\n          </div>\n        </div>\n      </div>\n\n      <div id=\"widget-health\" class=\"widget-card absolute glass p-8 rounded-3xl w-72 z-30\" style=\"top: 20%; right: 10%;\" data-kid=\"63\">\n        <p class=\"text-xs font-bold uppercase tracking-widest text-[var(--text-secondary)] mb-6 text-center\" data-kid=\"64\">Financial Health Score</p>\n        <div class=\"relative flex items-center justify-center mb-6\" data-kid=\"65\">\n          <svg class=\"w-32 h-32 transform -rotate-90\" data-kid=\"66\">\n            <circle cx=\"64\" cy=\"64\" r=\"58\" stroke=\"currentColor\" stroke-width=\"10\" fill=\"transparent\" class=\"text-white/5\" data-kid=\"67\"></circle>\n            <circle cx=\"64\" cy=\"64\" r=\"58\" stroke=\"currentColor\" stroke-width=\"10\" fill=\"transparent\" stroke-dasharray=\"364.4\" stroke-dashoffset=\"54.6\" class=\"text-[var(--brand-light)]\" data-kid=\"68\"></circle>\n          </svg>\n          <span class=\"absolute text-4xl font-bold font-geist\" data-kid=\"69\">85</span>\n        </div>\n        <p class=\"text-sm text-center text-slate-400\" data-kid=\"70\">Status: <span class=\"text-emerald-500 font-bold\" data-kid=\"71\">Optimized</span></p>\n      </div>\n\n      <div id=\"scroll-text\" class=\"absolute bottom-12 text-center w-full pointer-events-none\" data-kid=\"72\">\n        <div class=\"flex flex-col items-center gap-2\" data-kid=\"73\">\n          <p class=\"text-xs font-geist uppercase tracking-[0.4em] text-[var(--text-secondary)] animate-pulse\" data-kid=\"74\">Scroll to explore insights</p>\n          <div class=\"w-[1px] h-16 bg-gradient-to-b from-[var(--brand-light)] via-[var(--brand)] to-transparent\" data-kid=\"75\"></div>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n\n<section id=\"features\" class=\"py-32 px-8 lg:px-16 bg-[var(--surface)]\" data-kid=\"76\">\n  <div class=\"container mx-auto max-w-7xl\" data-kid=\"77\">\n    <div class=\"text-center mb-24 reveal\" data-kid=\"78\">\n      <h2 class=\"font-geist text-5xl font-bold mb-6\" data-kid=\"79\">Financial Intelligence<br data-kid=\"80\"><span class=\"text-slate-500\" data-kid=\"81\">Built Different.</span></h2>\n      <p class=\"text-lg text-[var(--text-secondary)] max-w-2xl mx-auto\" data-kid=\"82\">Our platform combines enterprise-grade analytics with a consumer-first AI experience.</p>\n    </div>\n\n    <div class=\"grid lg:grid-cols-3 gap-8\" data-kid=\"83\">\n      \n      <div class=\"lg:col-span-2 glass rounded-[3rem] p-12 overflow-hidden relative group reveal border-white/5\" data-kid=\"84\">\n        <div class=\"relative z-10\" data-kid=\"85\">\n          <h3 class=\"text-4xl font-bold mb-4 font-geist\" data-kid=\"86\">Intelligent AI Coaching</h3>\n          <p class=\"text-[var(--text-secondary)] text-xl mb-12 max-w-lg leading-relaxed\" data-kid=\"87\">Experience finance that talks back. Our RAG-powered engine analyzes your documents and spending to provide actionable, human-level advice.</p>\n          <div class=\"flex gap-4\" data-kid=\"88\">\n            <button class=\"px-8 py-3 bg-white text-black rounded-xl font-bold hover:bg-slate-200 transition-all\" data-kid=\"89\">Chat with Fingo</button>\n            <button class=\"px-8 py-3 glass rounded-xl font-bold hover:bg-white/5 transition-all\" data-kid=\"90\">View Demo</button>\n          </div>\n        </div>\n        \n        <div class=\"absolute -right-8 bottom-0 w-[45%] h-full opacity-40 translate-y-12 group-hover:translate-y-0 transition-transform duration-700\" data-kid=\"91\">\n          <div class=\"space-y-4\" data-kid=\"92\">\n            <div class=\"glass p-5 rounded-3xl rounded-br-none ml-auto border-emerald-500/20 shadow-xl shadow-emerald-500/5\" data-kid=\"93\">\"Analyze my Amazon spending for Q3.\"</div>\n            <div class=\"bg-[var(--brand)] p-6 rounded-3xl rounded-bl-none border border-white/10 shadow-2xl\" data-kid=\"94\">\"You spent $1,240 on electronics. I recommend shifting $400 of this to your emergency fund next month.\"</div>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"glass rounded-[3rem] p-12 group reveal border-white/5\" data-kid=\"95\">\n        <h3 class=\"text-3xl font-bold mb-4 font-geist\" data-kid=\"96\">UPI Insights</h3>\n        <p class=\"text-[var(--text-secondary)] mb-10 text-lg\" data-kid=\"97\">Every transaction decrypted. Identify hidden subscriptions and merchant behavior instantly.</p>\n        <div class=\"space-y-4\" data-kid=\"98\">\n          <div class=\"flex items-center justify-between p-4 glass rounded-2xl border-white/10 group-hover:border-orange-500/40 transition-all\" data-kid=\"99\">\n            <div class=\"flex items-center gap-3\" data-kid=\"100\">\n              <div class=\"w-10 h-10 bg-orange-500/20 rounded-lg flex items-center justify-center\" data-kid=\"101\">\n                <i class=\"ti ti-brand-netflix text-orange-500\" data-kid=\"102\"></i>\n              </div>\n              <span class=\"font-medium\" data-kid=\"103\">Netflix Inc.</span>\n            </div>\n            <span class=\"text-red-400 font-bold\" data-kid=\"104\">-$15.99</span>\n          </div>\n          <div class=\"flex items-center justify-between p-4 glass rounded-2xl border-white/10 opacity-60\" data-kid=\"105\">\n            <div class=\"flex items-center gap-3\" data-kid=\"106\">\n              <div class=\"w-10 h-10 bg-blue-500/20 rounded-lg flex items-center justify-center\" data-kid=\"107\">\n                <i class=\"ti ti-brand-apple text-blue-500\" data-kid=\"108\"></i>\n              </div>\n              <span class=\"font-medium\" data-kid=\"109\">iCloud+</span>\n            </div>\n            <span class=\"text-red-400\" data-kid=\"110\">-$2.99</span>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"lg:col-span-3 glass rounded-[3rem] p-12 group reveal border-white/5 grid lg:grid-cols-2 gap-12 items-center\" data-kid=\"111\">\n        <div data-kid=\"112\">\n          <h3 class=\"text-4xl font-bold mb-6 font-geist\" data-kid=\"113\">Simulated Future State</h3>\n          <p class=\"text-[var(--text-secondary)] text-xl leading-relaxed mb-8\" data-kid=\"114\">What if you saved 5% more? Or changed your commute? Our simulator projects your financial trajectory across the next 30 years with precision.</p>\n          <div class=\"flex items-center gap-8\" data-kid=\"115\">\n            <div class=\"flex flex-col\" data-kid=\"116\">\n              <span class=\"text-3xl font-bold font-geist text-emerald-500\" data-kid=\"117\">+$24k</span>\n              <span class=\"text-xs uppercase tracking-widest text-[var(--text-secondary)]\" data-kid=\"118\">Annual Impact</span>\n            </div>\n            <div class=\"w-[1px] h-12 bg-white/10\" data-kid=\"119\"></div>\n            <div class=\"flex flex-col\" data-kid=\"120\">\n              <span class=\"text-3xl font-bold font-geist text-orange-500\" data-kid=\"121\">4.2 yrs</span>\n              <span class=\"text-xs uppercase tracking-widest text-[var(--text-secondary)]\" data-kid=\"122\">Early Retirement</span>\n            </div>\n          </div>\n        </div>\n        <div class=\"h-64 glass rounded-[2rem] p-8 relative overflow-hidden\" data-kid=\"123\">\n          <div class=\"absolute inset-0 bg-gradient-to-t from-[var(--brand)]/10 to-transparent\" data-kid=\"124\"></div>\n          \n          <svg class=\"w-full h-full\" viewBox=\"0 0 100 40\" preserveAspectRatio=\"none\" data-kid=\"125\">\n            <defs data-kid=\"126\">\n              <linearGradient id=\"chartGrad\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\" data-kid=\"127\">\n                <stop offset=\"0%\" stop-color=\"var(--brand-light)\" stop-opacity=\"0.5\" data-kid=\"128\"></stop>\n                <stop offset=\"100%\" stop-color=\"var(--brand-light)\" stop-opacity=\"0\" data-kid=\"129\"></stop>\n              </linearGradient>\n            </defs>\n            <path d=\"M0,40 L0,30 Q25,25 40,20 T80,5 T100,2 L100,40 Z\" fill=\"url(#chartGrad)\" data-kid=\"130\"></path>\n            <path d=\"M0,30 Q25,25 40,20 T80,5 T100,2\" fill=\"none\" stroke=\"var(--brand-light)\" stroke-width=\"0.5\" stroke-linecap=\"round\" data-kid=\"131\"></path>\n            <circle cx=\"40\" cy=\"20\" r=\"1\" fill=\"white\" data-kid=\"132\"></circle>\n            <circle cx=\"80\" cy=\"5\" r=\"1\" fill=\"white\" data-kid=\"133\"></circle>\n          </svg>\n          <div class=\"absolute top-4 left-4 text-[10px] text-white/40 uppercase tracking-widest\" data-kid=\"134\">Projection Scenario A</div>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n\n<section class=\"py-48 px-8 relative overflow-hidden\" data-kid=\"135\">\n  <div class=\"absolute top-0 left-1/2 -translate-x-1/2 w-full h-[1px] bg-gradient-to-r from-transparent via-[var(--brand-light)] to-transparent opacity-30\" data-kid=\"136\"></div>\n  <div class=\"container mx-auto max-w-6xl text-center relative z-10\" data-kid=\"137\">\n    <h2 class=\"font-geist text-7xl lg:text-[100px] font-bold mb-12 tracking-tight\" data-kid=\"138\">Financial sovereignty<br data-kid=\"139\"><span class=\"text-white/20\" data-kid=\"140\">is a choice.</span></h2>\n    <p class=\"text-2xl text-[var(--text-secondary)] mb-16 max-w-3xl mx-auto font-medium\" data-kid=\"141\">Join 50,000+ investors who use Fingo AI to manage over $2.4B in private assets.</p>\n    <div class=\"flex flex-col sm:flex-row items-center justify-center gap-6\" data-kid=\"142\">\n      <button class=\"w-full sm:w-auto px-12 py-6 bg-[var(--cta)] hover:brightness-110 text-white rounded-2xl font-bold text-xl transition-all shadow-2xl shadow-[var(--cta)]/20\" data-kid=\"143\">\n        Start Your Journey\n      </button>\n      <button class=\"w-full sm:w-auto px-12 py-6 glass hover:bg-white/10 text-white rounded-2xl font-bold text-xl transition-all\" data-kid=\"144\">\n        Book a Demo\n      </button>\n    </div>\n  </div>\n  \n  <div class=\"absolute inset-0 opacity-10 pointer-events-none\" data-kid=\"145\">\n    <div class=\"absolute top-1/4 left-1/4 w-96 h-96 bg-[var(--brand)] blur-[150px]\" data-kid=\"146\"></div>\n    <div class=\"absolute bottom-1/4 right-1/4 w-96 h-96 bg-[var(--brand-light)] blur-[150px]\" data-kid=\"147\"></div>\n  </div>\n</section>\n\n\n<footer class=\"py-24 px-8 border-t border-white/5 bg-[var(--bg)]\" data-kid=\"148\">\n  <div class=\"container mx-auto max-w-7xl grid grid-cols-2 lg:grid-cols-6 gap-12 lg:gap-8\" data-kid=\"149\">\n    <div class=\"col-span-2\" data-kid=\"150\">\n      <a href=\"#\" class=\"font-logo text-3xl font-bold tracking-tight text-white mb-6 block\" data-kid=\"151\">FINGO AI</a>\n      <p class=\"text-[var(--text-secondary)] mb-8 max-w-xs\" data-kid=\"152\">The future of personal finance is intelligent, automated, and human-centric.</p>\n      <div class=\"flex gap-4\" data-kid=\"153\">\n        <a href=\"#\" class=\"w-10 h-10 glass rounded-full flex items-center justify-center hover:bg-white/10 transition-all\" data-kid=\"154\">\n          <i class=\"ti ti-brand-twitter\" data-kid=\"155\"></i>\n        </a>\n        <a href=\"#\" class=\"w-10 h-10 glass rounded-full flex items-center justify-center hover:bg-white/10 transition-all\" data-kid=\"156\">\n          <i class=\"ti ti-brand-linkedin\" data-kid=\"157\"></i>\n        </a>\n        <a href=\"#\" class=\"w-10 h-10 glass rounded-full flex items-center justify-center hover:bg-white/10 transition-all\" data-kid=\"158\">\n          <i class=\"ti ti-brand-github\" data-kid=\"159\"></i>\n        </a>\n      </div>\n    </div>\n    \n    <div class=\"col-span-1\" data-kid=\"160\">\n      <h4 class=\"font-bold mb-6 text-sm uppercase tracking-widest text-white/50\" data-kid=\"161\">Product</h4>\n      <ul class=\"space-y-4 text-[var(--text-secondary)] text-sm\" data-kid=\"162\">\n        <li data-kid=\"163\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"164\">Features</a></li>\n        <li data-kid=\"165\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"166\">AI Coach</a></li>\n        <li data-kid=\"167\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"168\">Security</a></li>\n        <li data-kid=\"169\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"170\">Integrations</a></li>\n      </ul>\n    </div>\n\n    <div class=\"col-span-1\" data-kid=\"171\">\n      <h4 class=\"font-bold mb-6 text-sm uppercase tracking-widest text-white/50\" data-kid=\"172\">Company</h4>\n      <ul class=\"space-y-4 text-[var(--text-secondary)] text-sm\" data-kid=\"173\">\n        <li data-kid=\"174\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"175\">About</a></li>\n        <li data-kid=\"176\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"177\">Careers</a></li>\n        <li data-kid=\"178\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"179\">Blog</a></li>\n        <li data-kid=\"180\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"181\">Contact</a></li>\n      </ul>\n    </div>\n\n    <div class=\"col-span-1\" data-kid=\"182\">\n      <h4 class=\"font-bold mb-6 text-sm uppercase tracking-widest text-white/50\" data-kid=\"183\">Resources</h4>\n      <ul class=\"space-y-4 text-[var(--text-secondary)] text-sm\" data-kid=\"184\">\n        <li data-kid=\"185\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"186\">Documentation</a></li>\n        <li data-kid=\"187\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"188\">Help Center</a></li>\n        <li data-kid=\"189\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"190\">Privacy Policy</a></li>\n        <li data-kid=\"191\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"192\">Terms of Service</a></li>\n      </ul>\n    </div>\n\n    <div class=\"col-span-1\" data-kid=\"193\">\n      <h4 class=\"font-bold mb-6 text-sm uppercase tracking-widest text-white/50\" data-kid=\"194\">Legal</h4>\n      <ul class=\"space-y-4 text-[var(--text-secondary)] text-sm\" data-kid=\"195\">\n        <li data-kid=\"196\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"197\">Security</a></li>\n        <li data-kid=\"198\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"199\">Privacy</a></li>\n        <li data-kid=\"200\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"201\">Cookies</a></li>\n        <li data-kid=\"202\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"203\">Licenses</a></li>\n      </ul>\n    </div>\n  </div>\n  \n  <div class=\"container mx-auto max-w-7xl mt-24 pt-8 border-t border-white/5 flex flex-col md:row justify-between items-center gap-4 text-xs text-white/30\" data-kid=\"204\">\n    <p data-kid=\"205\">&copy; 2026 Fingo AI Inc. All rights reserved.</p>\n    <div class=\"flex gap-6\" data-kid=\"206\">\n      <span data-kid=\"207\">Status: All Systems Operational</span>\n      <span data-kid=\"208\">v1.2.0-stable</span>\n    </div>\n  </div>\n</footer>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"209\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"210\"></script>\n<script type=\"module\" data-kid=\"211\">\n  import Lenis from \"https://esm.sh/lenis@1\"\n  \n  // 1. Initialize Lenis\n  const lenis = new Lenis();\n\n  // 2. Sync Lenis with GSAP\n  lenis.on('scroll', ScrollTrigger.update);\n  gsap.ticker.add((time) => {\n    lenis.raf(time * 1000);\n  });\n  gsap.ticker.lagSmoothing(0);\n\n  // 2. Initialize GSAP ScrollTrigger\n  gsap.registerPlugin(ScrollTrigger);\n\n  // 3. Pointer Follow for Pinned Robot\n  const robot = document.getElementById('pinned-robot');\n  document.addEventListener('mousemove', (e) => {\n    const { clientX, clientY } = e;\n    const { innerWidth, innerHeight } = window;\n    const xPos = (clientX / innerWidth - 0.5) * 30;\n    const yPos = (clientY / innerHeight - 0.5) * 30;\n    \n    gsap.to(robot, {\n      x: xPos,\n      y: yPos,\n      rotationY: xPos * 0.3,\n      rotationX: -yPos * 0.3,\n      duration: 1,\n      ease: 'power2.out'\n    });\n  });\n\n  // 4. Integrated Hero to Story Transition\n  const mainTl = gsap.timeline({\n    scrollTrigger: {\n      trigger: \"#story-scene\",\n      start: \"top top\",\n      end: \"+=150%\",\n      pin: true,\n      scrub: 1,\n    }\n  });\n\n  mainTl\n    .fromTo(\"#hero-content\", { opacity: 1, y: 0 }, { opacity: 0, y: -80, duration: 1 })\n    .fromTo(\"#pinned-robot\", { scale: 0.8, opacity: 0.5 }, { scale: 1.15, opacity: 1, duration: 2, ease: \"power2.out\" }, 0)\n    .from(\"#widget-balance\", { opacity: 0, x: -150, y: 80, rotation: -15, duration: 1.5, ease: \"back.out(1.2)\" }, 0.4)\n    .from(\"#widget-savings\", { opacity: 0, x: 150, y: 120, rotation: 15, duration: 1.5, ease: \"back.out(1.2)\" }, 0.6)\n    .from(\"#widget-health\", { opacity: 0, x: 80, y: -120, rotation: 8, duration: 1.5, ease: \"back.out(1.2)\" }, 0.8);\n\n  // 5. Entrance Animations for Reveal items\n  const reveals = document.querySelectorAll('.reveal');\n  reveals.forEach((el) => {\n    gsap.to(el, {\n      opacity: 1,\n      y: 0,\n      duration: 1,\n      ease: 'power3.out',\n      scrollTrigger: {\n        trigger: el,\n        start: 'top 85%',\n        toggleActions: 'play none none none'\n      }\n    });\n  });\n\n</script>\n",
