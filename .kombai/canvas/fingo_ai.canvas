bg-white/10 w-[21%] rounded-full\" data-kid=\"222\"></div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n    \n    <div class=\"h-20\" data-kid=\"223\"></div>\n  </main>\n\n  \n  <div id=\"fab-stack\" class=\"fixed bottom-10 right-10 flex flex-col items-end gap-3 z-[100]\" data-kid=\"224\">\n    <div class=\"flex flex-col gap-3 mb-3 opacity-0 translate-y-10 invisible\" id=\"fab-menu\" data-kid=\"225\">\n      <button class=\"w-12 h-12 rounded-full bg-[var(--bg-obsidian)] border border-white/10 text-white flex items-center justify-center hover:bg-[var(--emerald)]/20 transition-colors shadow-2xl\" data-kid=\"226\">\n        <i class=\"ti ti-history\" data-kid=\"227\"></i>\n      </button>\n      <button class=\"w-12 h-12 rounded-full bg-[var(--bg-obsidian)] border border-white/10 text-white flex items-center justify-center hover:bg-[var(--emerald)]/20 transition-colors shadow-2xl\" data-kid=\"228\">\n        <i class=\"ti ti-settings\" data-kid=\"229\"></i>\n      </button>\n    </div>\n    <button class=\"fab-launcher w-16 h-16 rounded-[2rem] bg-[var(--emerald)] flex items-center justify-center text-[var(--bg-deep)] cursor-pointer relative z-10\" id=\"fab-trigger\" data-kid=\"230\">\n      <i class=\"ti ti-message-chatbot text-3xl\" data-kid=\"231\"></i>\n      <span class=\"absolute -top-1 -right-1 w-5 h-5 bg-[var(--amber)] rounded-full border-4 border-[var(--bg-deep)] z-20\" data-kid=\"232\"></span>\n      <span class=\"absolute -top-2 -right-2 w-7 h-7 bg-[var(--amber)] rounded-full pulse-amber z-10\" data-kid=\"233\"></span>\n    </button>\n  </div>\n</div>\n\n<link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" data-kid=\"234\">\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"235\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"236\"></script>\n<script data-kid=\"237\">gsap.registerPlugin(ScrollTrigger);</script>\n<script type=\"module\" data-kid=\"238\">\n  import { animate, scroll, inView, stagger } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n  import Lenis from \"https://esm.sh/lenis@1\"\n  import Snap from \"https://esm.sh/lenis@1/snap\"\n\n  // Initialize Lenis\n  const lenis = new Lenis({\n    autoRaf: true,\n  });\n\n  // #gsap-scroll-batch entrance for widgets\n  gsap.set('.bento-item', { opacity: 0, y: 30 });\n  ScrollTrigger.batch('.bento-item', {\n    start: 'top 90%',\n    onEnter: (elements) => {\n      gsap.to(elements, {\n        opacity: 1,\n        y: 0,\n        duration: 0.8,\n        stagger: 0.1,\n        ease: 'power3.out',\n        overwrite: true\n      });\n    }\n  });\n\n  // Floating animation for AI image\n  gsap.to('#ai-briefing img', {\n    y: -15,\n    duration: 3,\n    repeat: -1,\n    yoyo: true,\n    ease: 'power1.inOut'\n  });\n\n  // Pulsing glow for chart dots\n  gsap.to('.chart-dot', {\n    r: 8,\n    strokeWidth: 4,\n    duration: 1.5,\n    repeat: -1,\n    yoyo: true,\n    stagger: 0.2,\n    ease: 'sine.inOut'\n  });\n\n  // Gauge animation\n  gsap.to('.gauge-progress', {\n    strokeDashoffset: 50, // 84/100ish for excellent\n    duration: 1.5,\n    delay: 0.5,\n    ease: 'power2.out',\n    scrollTrigger: {\n      trigger: '#gauge-score',\n      start: 'top 85%'\n    }\n  });\n\n  // Counter animation for totals\n  const balanceEl = document.getElementById('total-balance');\n  const countObj = { val: 0 };\n  gsap.to(countObj, {\n    val: 142850.40,\n    duration: 2,\n    ease: 'power2.out',\n    onUpdate: () => {\n      balanceEl.textContent = '$' + countObj.val.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });\n    },\n    scrollTrigger: {\n      trigger: '#dashboard-bento',\n      start: 'top 85%'\n    }\n  });\n\n  // #fab-stack animation\n  const fabTrigger = document.getElementById('fab-trigger');\n  const fabMenu = document.getElementById('fab-menu');\n  let menuOpen = false;\n\n  fabTrigger.addEventListener('click', () => {\n    menuOpen = !menuOpen;\n    if (menuOpen) {\n      gsap.to(fabMenu, { \n        autoAlpha: 1, \n        y: 0, \n        duration: 0.4, \n        ease: 'back.out(1.7)',\n        visibility: 'visible'\n      });\n      gsap.to(fabTrigger, { rotate: 45, duration: 0.3 });\n    } else {\n      gsap.to(fabMenu, { \n        autoAlpha: 0, \n        y: 20, \n        duration: 0.3, \n        ease: 'power2.in'\n      });\n      gsap.to(fabTrigger, { rotate: 0, duration: 0.3 });\n    }\n  });\n\n  // #anime-hover-lift effect for cards\n  const bentoItems = document.querySelectorAll('.bento-item');\n  bentoItems.forEach(item => {\n    item.addEventListener('mouseenter', () => {\n      gsap.to(item, {\n        y: -4,\n        duration: 0.3,\n        ease: 'power2.out',\n        borderColor: 'rgba(16, 185, 129, 0.3)',\n        backgroundColor: 'rgba(255, 255, 255, 0.03)'\n      });\n    });\n    item.addEventListener('mouseleave', () => {\n      gsap.to(item, {\n        y: 0,\n        duration: 0.4,\n        ease: 'power2.out',\n        borderColor: 'rgba(255, 255, 255, 0.05)',\n        backgroundColor: item.classList.contains('bg-[var(--bg-obsidian)]') ? '#121418' : '#1E222A'\n      });\n    });\n  });\n\n  // #anime-hover-color-sweep for sidebar\n  const navItems = document.querySelectorAll('.nav-item:not(.active-nav)');\n  navItems.forEach(item => {\n    item.addEventListener('mouseenter', () => {\n      gsap.to(item, {\n        backgroundColor: 'rgba(7, 102, 83, 0.08)',\n        color: '#F7F5F2',\n        duration: 0.25\n      });\n    });\n    item.addEventListener('mouseleave', () => {\n      gsap.to(item, {\n        backgroundColor: 'transparent',\n        color: '#94A3B8',\n        duration: 0.3\n      });\n    });\n  });\n\n</script>\n",
