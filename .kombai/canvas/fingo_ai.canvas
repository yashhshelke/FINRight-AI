      "html": "\n<style data-kid=\"0\">\n@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&family=Inter:wght@300;400;500;600;700;800;900&family=Instrument+Sans:wght@400;500;600;700;800&display=swap');\n\n:root {\n  --bg: #F7F5F2;\n  --surface: #FFFFFF;\n  --brand: #076653;\n  --text: #1F2937;\n  --border: #E7E5E4;\n  --cta: #FF812B;\n}\n\nbody {\n  background-color: var(--bg);\n  color: var(--text);\n  font-family: 'Inter', sans-serif;\n  margin: 0;\n  overflow-x: clip;\n}\n\n.font-logo { font-family: 'Cormorant Garamond', serif; }\n.font-heading { font-family: 'Instrument Sans', sans-serif; letter-spacing: -0.03em; font-weight: 800; }\n\n/* Grid Utilities */\n.swiss-grid { display: grid; }\n.swiss-border-r { border-right: 1px solid var(--border); }\n.swiss-border-b { border-bottom: 1px solid var(--border); }\n.swiss-border-l { border-left: 1px solid var(--border); }\n.swiss-border-t { border-top: 1px solid var(--border); }\n\n/* Reveal states - managed by Anime.js or Locomotive */\n.reveal-target {\n  opacity: 0;\n  transform: translateY(30px);\n}\n\n/* Staircase & Sticky */\n.feature-card {\n  background: white;\n  border: 1px solid var(--border);\n  box-shadow: 0 4px 30px rgba(0, 0, 0, 0.02);\n}\n\n/* Custom Cursor/Typewriter */\n#typewriter-text::after {\n  content: '';\n  display: inline-block;\n  width: 2px;\n  height: 0.8em;\n  background-color: var(--brand);\n  margin-left: 4px;\n  vertical-align: middle;\n  animation: blink 1s step-end infinite;\n}\n\n@keyframes blink {\n  from, to { opacity: 1; }\n  50% { opacity: 0; }\n}\n\n/* Locomotive Progress Driving CSS */\n[data-scroll-css-progress] {\n  opacity: calc(0.3 + var(--progress) * 0.7);\n  transform: translateY(calc((1 - var(--progress)) * 40px));\n}\n\n.progress-line-fill {\n  transform-origin: top;\n}\n\n/* Smooth scroll styling for Lenis/Locomotive */\nhtml.lenis {\n  height: auto;\n}\n.lenis.lenis-smooth {\n  scroll-behavior: auto;\n}\n.lenis.lenis-smooth [data-lenis-prevent] {\n  overscroll-behavior: contain;\n}\n.lenis.lenis-stopped {\n  overflow: hidden;\n}\n</style>\n\n<div data-scroll-container data-kid=\"1\">\n  \n  <section class=\"min-h-screen swiss-grid grid-cols-[80px_1fr_450px]\" data-kid=\"2\">\n    \n    <div class=\"swiss-border-r flex flex-col items-center py-12 justify-between sticky top-0 h-screen\" data-kid=\"3\">\n      <div class=\"rotate-[-90deg] origin-center whitespace-nowrap\" data-kid=\"4\">\n        <span class=\"font-logo text-3xl font-bold tracking-[0.2em] text-[var(--brand)] uppercase\" data-kid=\"5\">Fingo AI</span>\n      </div>\n      <div class=\"flex flex-col gap-10 items-center text-[10px] font-bold tracking-[0.3em] uppercase opacity-40\" data-kid=\"6\">\n        <span class=\"rotate-[-90deg]\" data-kid=\"7\">Est. 2024</span>\n        <div class=\"w-px h-16 bg-[var(--border)]\" data-kid=\"8\"></div>\n        <span class=\"rotate-[-90deg]\" data-kid=\"9\">Scroll</span>\n      </div>\n    </div>\n\n    \n    <div class=\"flex flex-col\" data-kid=\"10\">\n      \n      <nav class=\"h-24 swiss-border-b flex items-center px-16 justify-between bg-[var(--bg)]/80 backdrop-blur-md sticky top-0 z-50\" data-kid=\"11\">\n        <div class=\"flex gap-16 text-xs font-bold uppercase tracking-widest opacity-60\" data-kid=\"12\">\n          <a href=\"#\" class=\"hover:opacity-100 transition-opacity\" data-kid=\"13\">Intelligence</a>\n          <a href=\"#\" class=\"hover:opacity-100 transition-opacity\" data-kid=\"14\">Infrastructure</a>\n          <a href=\"#\" class=\"hover:opacity-100 transition-opacity\" data-kid=\"15\">Capital</a>\n        </div>\n        <div class=\"flex items-center gap-8\" data-kid=\"16\">\n          <div class=\"flex items-center gap-2 px-4 py-2 bg-white border border-[var(--border)] rounded-full\" data-kid=\"17\">\n            <div class=\"w-1.5 h-1.5 bg-green-500 rounded-full animate-pulse\" data-kid=\"18\"></div>\n            <span class=\"text-[10px] font-bold uppercase tracking-widest\" data-kid=\"19\">Nodes Active</span>\n          </div>\n          <button class=\"text-xs font-bold uppercase tracking-widest hover:text-[var(--brand)] transition-colors\" data-kid=\"20\">Sign In</button>\n        </div>\n      </nav>\n\n      \n      <div class=\"flex-1 flex flex-col justify-center px-16 py-24\" data-kid=\"21\">\n        <div class=\"max-w-4xl hero-content\" data-kid=\"22\">\n          <div class=\"flex items-center gap-4 mb-8 reveal-target\" data-kid=\"23\">\n            <span class=\"w-12 h-px bg-[var(--brand)]\" data-kid=\"24\"></span>\n            <span class=\"text-[10px] font-black tracking-[0.4em] text-[var(--brand)] uppercase\" data-kid=\"25\">Node_Protocol_01</span>\n          </div>\n          \n          <h1 class=\"font-heading text-8xl lg:text-9xl font-black leading-[1.05] text-[var(--text)] mb-12 reveal-target\" data-kid=\"26\">\n            Track your<br data-kid=\"27\">\n            <span class=\"text-neutral-300\" data-kid=\"28\">money.</span><br data-kid=\"29\">\n            <span id=\"typewriter-text\" class=\"text-[var(--brand)]\" data-kid=\"30\"></span>\n          </h1>\n\n          <p class=\"text-xl text-[var(--text)]/50 max-w-xl mb-12 leading-relaxed reveal-target\" data-kid=\"31\">\n            Your personal finance operating system. Orchestrate your capital with 3D architectural precision and autonomous intelligence.\n          </p>\n\n          <div class=\"flex items-center gap-6 reveal-target\" data-kid=\"32\">\n            <button class=\"group relative px-10 py-5 bg-[var(--brand)] text-white font-bold rounded-xs overflow-hidden transition-all hover:pr-14 active:scale-95\" data-kid=\"33\">\n              <span class=\"relative z-10 text-xs uppercase tracking-widest\" data-kid=\"34\">Initialize Platform</span>\n              <i class=\"ti ti-arrow-right absolute right-4 top-1/2 -translate-y-1/2 opacity-0 group-hover:opacity-100 transition-all\" data-kid=\"35\"></i>\n            </button>\n            <button class=\"px-10 py-5 border border-[var(--border)] bg-white text-[var(--text)] font-bold rounded-xs text-xs uppercase tracking-widest hover:bg-neutral-50 transition-colors\" data-kid=\"36\">\n              Request Access\n            </button>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"h-40 swiss-border-t grid grid-cols-3\" data-kid=\"37\">\n        <div class=\"swiss-border-r p-8 flex flex-col justify-between\" data-scroll style=\"--i: 3\" data-kid=\"38\">\n          <span class=\"text-[9px] font-bold uppercase tracking-[0.3em] opacity-40\" data-kid=\"39\">Security Architecture</span>\n          <div class=\"flex flex-col\" data-kid=\"40\">\n            <span class=\"text-sm font-bold\" data-kid=\"41\">End-to-End Encryption</span>\n            <span class=\"text-[10px] opacity-40\" data-kid=\"42\">256-bit AES Standard</span>\n          </div>\n        </div>\n        <div class=\"swiss-border-r p-8 flex flex-col justify-between\" data-scroll style=\"--i: 4\" data-kid=\"43\">\n          <span class=\"text-[9px] font-bold uppercase tracking-[0.3em] opacity-40\" data-kid=\"44\">Data Integrity</span>\n          <div class=\"flex flex-col\" data-kid=\"45\">\n            <span class=\"text-sm font-bold\" data-kid=\"46\">Bank-Grade Integration</span>\n            <span class=\"text-[10px] opacity-40\" data-kid=\"47\">Direct Plaid Connectivity</span>\n          </div>\n        </div>\n        <div class=\"p-8 flex flex-col justify-between\" data-scroll style=\"--i: 5\" data-kid=\"48\">\n          <span class=\"text-[9px] font-bold uppercase tracking-[0.3em] opacity-40\" data-kid=\"49\">Global Uptime</span>\n          <div class=\"flex flex-col\" data-kid=\"50\">\n            <span class=\"text-sm font-bold\" data-kid=\"51\">99.99% Reliability</span>\n            <span class=\"text-[10px] opacity-40\" data-kid=\"52\">Zero Downtime Infrastructure</span>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"swiss-border-l bg-white flex items-center justify-center overflow-hidden relative\" data-kid=\"53\">\n      <img src=\"https://images.unsplash.com/photo-1674544362969-a4269ef0ea69?auto=format&w=800&q=80\" alt=\"Fingo AI Companion\" class=\"w-full h-full object-cover grayscale-[0.1]\" data-scroll data-scroll-speed=\"-1.2\" data-kid=\"54\">\n      <div class=\"absolute inset-0 bg-gradient-to-t from-[var(--bg)]/10 to-transparent\" data-kid=\"55\"></div>\n    </div>\n  </section>\n\n  \n  <section class=\"grid grid-cols-[80px_1fr_1fr] min-h-[300vh] relative\" data-kid=\"56\">\n    \n    <div class=\"swiss-border-r h-full\" data-kid=\"57\"></div>\n\n    \n    <div class=\"h-screen sticky top-0 flex flex-col justify-center px-16 swiss-border-r bg-[var(--bg)]/50 backdrop-blur-sm\" data-kid=\"58\">\n      <div class=\"max-w-md\" data-kid=\"59\">\n        <span class=\"text-[10px] font-bold uppercase tracking-[0.4em] text-[var(--brand)] mb-6 block\" data-kid=\"60\">Capabilities</span>\n        <h2 class=\"font-heading text-6xl lg:text-7xl font-black leading-[0.9] mb-8 text-[var(--text)]\" data-kid=\"61\">Sophisticated tools for your capital.</h2>\n        <p class=\"text-lg text-[var(--text)]/50 leading-relaxed mb-12\" data-kid=\"62\">\n          Beyond tracking. Fingo AI deep-dives into your financial DNA to uncover optimization opportunities.\n        </p>\n\n        \n        <div class=\"flex items-start gap-8\" data-kid=\"63\">\n          <div class=\"relative w-[1px] h-48 bg-[var(--border)] overflow-hidden\" data-kid=\"64\">\n            <div id=\"scroll-progress-line\" class=\"absolute top-0 left-0 w-full h-full bg-[var(--brand)] progress-line-fill scale-y-0\" data-kid=\"65\"></div>\n          </div>\n          <div class=\"flex flex-col gap-8\" data-kid=\"66\">\n            <div class=\"progress-step active\" data-step=\"1\" data-kid=\"67\">\n              <span class=\"text-[10px] font-bold tracking-widest text-[var(--brand)]\" data-kid=\"68\">01 FINANCIAL HEALTH</span>\n            </div>\n            <div class=\"progress-step opacity-20\" data-step=\"2\" data-kid=\"69\">\n              <span class=\"text-[10px] font-bold tracking-widest\" data-kid=\"70\">02 BUDGET OPTIMIZER</span>\n            </div>\n            <div class=\"progress-step opacity-20\" data-step=\"3\" data-kid=\"71\">\n              <span class=\"text-[10px] font-bold tracking-widest\" data-kid=\"72\">03 GROWTH PROJECTIONS</span>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"py-[20vh] px-16 space-y-[15vh]\" data-kid=\"73\">\n      \n      <div class=\"feature-card p-0 overflow-hidden relative z-10\" data-scroll data-scroll-css-progress data-scroll-offset=\"0,10%\" data-kid=\"74\">\n        <div class=\"grid grid-cols-2 h-[450px]\" data-kid=\"75\">\n          <div class=\"p-12 flex flex-col justify-between\" data-kid=\"76\">\n            <div data-kid=\"77\">\n              <div class=\"flex items-center gap-3 mb-6\" data-kid=\"78\">\n                <i class=\"ti ti-pulse text-2xl text-[var(--brand)]\" data-kid=\"79\"></i>\n                <span class=\"text-[10px] font-black tracking-widest opacity-40\" data-kid=\"80\">SYSTEM_DIAGNOSTIC</span>\n              </div>\n              <h3 class=\"font-heading text-4xl font-black mb-6\" data-kid=\"81\">Financial Health Engine</h3>\n              <p class=\"text-sm text-[var(--text)]/50 leading-relaxed\" data-kid=\"82\">\n                Real-time analysis of debt-to-income, liquidity depth, and net worth velocity.\n              </p>\n            </div>\n            <div class=\"flex items-baseline gap-4\" data-kid=\"83\">\n              <span class=\"text-6xl font-black\" data-kid=\"84\">98.2</span>\n              <span class=\"text-xs font-bold text-[var(--brand)]\" data-kid=\"85\">OPTIMAL</span>\n            </div>\n          </div>\n          <div class=\"bg-neutral-50 border-l border-[var(--border)] p-12 flex flex-col justify-center\" data-kid=\"86\">\n            <div class=\"space-y-6\" data-kid=\"87\">\n               <div class=\"flex justify-between items-end gap-2 h-32\" data-kid=\"88\">\n                 <div class=\"w-full bg-[var(--brand)]/10 h-[20%]\" data-kid=\"89\"></div>\n                 <div class=\"w-full bg-[var(--brand)]/20 h-[45%]\" data-kid=\"90\"></div>\n                 <div class=\"w-full bg-[var(--brand)]/40 h-[65%]\" data-kid=\"91\"></div>\n                 <div class=\"w-full bg-[var(--brand)] h-full\" data-kid=\"92\"></div>\n                 <div class=\"w-full bg-[var(--brand)]/60 h-[80%]\" data-kid=\"93\"></div>\n               </div>\n               <div class=\"pt-6 border-t border-[var(--border)]\" data-kid=\"94\">\n                 <div class=\"flex justify-between text-[10px] font-bold opacity-30\" data-kid=\"95\">\n                   <span data-kid=\"96\">LIQUIDITY</span>\n                   <span data-kid=\"97\">VELOCITY</span>\n                 </div>\n               </div>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"feature-card p-12 relative z-20\" data-scroll data-scroll-css-progress data-scroll-offset=\"0,10%\" data-kid=\"98\">\n        <div class=\"flex flex-col gap-12\" data-kid=\"99\">\n          <div class=\"flex justify-between items-start\" data-kid=\"100\">\n            <div class=\"max-w-sm\" data-kid=\"101\">\n              <h3 class=\"font-heading text-4xl font-black mb-6\" data-kid=\"102\">Budget Optimizer</h3>\n              <p class=\"text-sm text-[var(--text)]/50 leading-relaxed\" data-kid=\"103\">\n                Stop guessing. Autonomous categorization suggests precise adjustments to maximize savings rate.\n              </p>\n            </div>\n            <div class=\"w-24 h-24 bg-[var(--brand)] text-white flex items-center justify-center font-black text-2xl\" data-kid=\"104\">\n              24%\n            </div>\n          </div>\n          <div class=\"grid grid-cols-3 gap-1\" data-kid=\"105\">\n             <div class=\"h-2 bg-[var(--brand)]\" data-kid=\"106\"></div>\n             <div class=\"h-2 bg-neutral-200\" data-kid=\"107\"></div>\n             <div class=\"h-2 bg-neutral-100\" data-kid=\"108\"></div>\n          </div>\n          <div class=\"grid grid-cols-3 gap-8\" data-kid=\"109\">\n            <div class=\"space-y-2\" data-kid=\"110\">\n              <div class=\"text-[10px] font-bold opacity-40\" data-kid=\"111\">ALLOCATED</div>\n              <div class=\"text-lg font-bold\" data-kid=\"112\">$4,200.00</div>\n            </div>\n            <div class=\"space-y-2\" data-kid=\"113\">\n              <div class=\"text-[10px] font-bold opacity-40\" data-kid=\"114\">UTILIZED</div>\n              <div class=\"text-lg font-bold\" data-kid=\"115\">$2,840.12</div>\n            </div>\n            <div class=\"space-y-2\" data-kid=\"116\">\n              <div class=\"text-[10px] font-bold opacity-40\" data-kid=\"117\">SURPLUS</div>\n              <div class=\"text-lg font-bold text-[var(--brand)]\" data-kid=\"118\">+$1,359.88</div>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"feature-card p-0 overflow-hidden relative z-30 bg-neutral-900 text-white\" data-scroll data-scroll-css-progress data-scroll-offset=\"0,10%\" data-kid=\"119\">\n        <div class=\"p-12\" data-kid=\"120\">\n          <div class=\"flex justify-between items-center mb-16\" data-kid=\"121\">\n            <h3 class=\"font-heading text-4xl font-black\" data-kid=\"122\">Growth Projections</h3>\n            <div class=\"text-[10px] font-bold border border-white/20 px-4 py-2 uppercase tracking-widest\" data-kid=\"123\">Confidence: 94.2%</div>\n          </div>\n          <div class=\"relative h-40 border-b border-white/10\" data-kid=\"124\">\n             <svg class=\"w-full h-full\" viewBox=\"0 0 100 100\" preserveAspectRatio=\"none\" data-kid=\"125\">\n               <path d=\"M0 100 Q 25 80, 50 60 T 100 0\" fill=\"none\" stroke=\"#0F8A6B\" stroke-width=\"2\" vector-effect=\"non-scaling-stroke\" data-kid=\"126\"></path>\n               <path d=\"M0 100 Q 25 80, 50 60 T 100 0 L 100 100 Z\" fill=\"url(#grad)\" opacity=\"0.2\" data-kid=\"127\"></path>\n               <defs data-kid=\"128\">\n                 <linearGradient id=\"grad\" x1=\"0%\" y1=\"0%\" x2=\"0%\" y2=\"100%\" data-kid=\"129\">\n                   <stop offset=\"0%\" style=\"stop-color:#0F8A6B;stop-opacity:1\" data-kid=\"130\"></stop>\n                   <stop offset=\"100%\" style=\"stop-color:#0F8A6B;stop-opacity:0\" data-kid=\"131\"></stop>\n                 </linearGradient>\n               </defs>\n             </svg>\n          </div>\n          <div class=\"grid grid-cols-2 p-12 bg-white/5\" data-kid=\"132\">\n            <div class=\"flex flex-col gap-2\" data-kid=\"133\">\n              <span class=\"text-[10px] font-bold opacity-40\" data-kid=\"134\">10-YEAR OUTLOOK</span>\n              <span class=\"text-4xl font-black\" data-kid=\"135\">$2,482,900</span>\n            </div>\n            <div class=\"flex items-center justify-end\" data-kid=\"136\">\n              <button class=\"px-8 py-4 bg-[var(--brand)] text-xs font-bold uppercase tracking-widest hover:bg-white hover:text-black transition-colors\" data-kid=\"137\">Simulate Event</button>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"swiss-grid grid-cols-[80px_1fr_1fr] min-h-[70vh] swiss-border-t bg-white relative overflow-hidden\" data-kid=\"138\">\n    <div class=\"swiss-border-r flex items-center justify-center relative z-10\" data-kid=\"139\">\n       <div class=\"rotate-[-90deg] text-[10px] font-bold tracking-[0.5em] opacity-20 uppercase\" data-kid=\"140\">Finalize_Process</div>\n    </div>\n    \n    \n    <div class=\"p-24 flex flex-col justify-between swiss-border-r relative z-10\" data-kid=\"141\">\n      <div data-kid=\"142\">\n        <div class=\"flex items-center gap-4 mb-12\" data-kid=\"143\">\n          <span class=\"w-12 h-px bg-[var(--brand)]\" data-kid=\"144\"></span>\n          <span class=\"text-[10px] font-black tracking-widest text-[var(--brand)] uppercase\" data-kid=\"145\">Next Level Infrastructure</span>\n        </div>\n        <h2 class=\"font-heading text-8xl font-black leading-none mb-12\" data-kid=\"146\">Ready to evolve your capital?</h2>\n      </div>\n      \n      <div class=\"flex gap-12 items-end\" data-kid=\"147\">\n        <div class=\"flex flex-col gap-4\" data-kid=\"148\">\n          <span class=\"text-[10px] font-bold opacity-30 uppercase tracking-widest\" data-kid=\"149\">Global Network</span>\n          <div class=\"flex -space-x-3\" data-kid=\"150\">\n            <img src=\"https://i.pravatar.cc/100?u=1\" class=\"w-12 h-12 rounded-full border-4 border-white\" alt=\"Avatar\" data-kid=\"151\">\n            <img src=\"https://i.pravatar.cc/100?u=2\" class=\"w-12 h-12 rounded-full border-4 border-white\" alt=\"Avatar\" data-kid=\"152\">\n            <img src=\"https://i.pravatar.cc/100?u=3\" class=\"w-12 h-12 rounded-full border-4 border-white\" alt=\"Avatar\" data-kid=\"153\">\n            <div class=\"w-12 h-12 rounded-full border-4 border-white bg-neutral-100 flex items-center justify-center text-[10px] font-bold\" data-kid=\"154\">50K+</div>\n          </div>\n        </div>\n        <p class=\"text-sm text-[var(--text)]/50 max-w-xs leading-relaxed\" data-kid=\"155\">\n          Integrated with the most sophisticated financial networks worldwide.\n        </p>\n      </div>\n    </div>\n\n    \n    <div class=\"p-24 bg-neutral-50 flex flex-col justify-center relative z-10\" data-kid=\"156\">\n      <div class=\"space-y-12\" data-kid=\"157\">\n        <button class=\"group w-full flex items-center justify-between p-12 border border-[var(--border)] bg-white hover:bg-[var(--brand)] hover:text-white transition-all duration-500\" data-kid=\"158\">\n          <div class=\"text-left\" data-kid=\"159\">\n            <div class=\"text-[10px] font-black opacity-30 uppercase mb-2\" data-kid=\"160\">Default Action</div>\n            <div class=\"text-2xl font-black uppercase tracking-tight\" data-kid=\"161\">Create Free Account</div>\n          </div>\n          <i class=\"ti ti-arrow-right text-4xl transform group-hover:translate-x-4 transition-transform\" data-kid=\"162\"></i>\n        </button>\n        \n        <button class=\"group w-full flex items-center justify-between p-12 border border-[var(--border)] bg-transparent hover:bg-black hover:text-white transition-all duration-500\" data-kid=\"163\">\n          <div class=\"text-left\" data-kid=\"164\">\n            <div class=\"text-[10px] font-black opacity-30 uppercase mb-2\" data-kid=\"165\">Detailed Spec</div>\n            <div class=\"text-2xl font-black uppercase tracking-tight\" data-kid=\"166\">Platform Overview</div>\n          </div>\n          <i class=\"ti ti-download text-4xl transform group-hover:-translate-y-2 transition-transform\" data-kid=\"167\"></i>\n        </button>\n      </div>\n    </div>\n  </section>\n      \n    </div>\n  \n\n  \n  <footer class=\"swiss-grid grid-cols-[80px_1fr] bg-white swiss-border-t\" data-kid=\"168\">\n    <div class=\"swiss-border-r\" data-kid=\"169\"></div>\n    <div class=\"px-24 py-12 flex items-center justify-between\" data-kid=\"170\">\n      <div class=\"font-logo text-3xl font-bold text-[var(--brand)]\" data-kid=\"171\">FINGO AI</div>\n      <div class=\"flex gap-16 text-[10px] font-black uppercase tracking-[0.2em] opacity-30\" data-kid=\"172\">\n        <a href=\"#\" class=\"hover:opacity-100 transition-opacity\" data-kid=\"173\">Protocol</a>\n        <a href=\"#\" class=\"hover:opacity-100 transition-opacity\" data-kid=\"174\">Privacy</a>\n        <a href=\"#\" class=\"hover:opacity-100 transition-opacity\" data-kid=\"175\">Nodes</a>\n        <a href=\"#\" class=\"hover:opacity-100 transition-opacity\" data-kid=\"176\">Auth</a>\n      </div>\n      <div class=\"text-[10px] font-black uppercase tracking-[0.2em] opacity-20\" data-kid=\"177\">© 2024 FINGO TECH CORP</div>\n    </div>\n  </footer>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"178\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"179\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/locomotive-scroll@5/bundled/locomotive-scroll.min.js\" data-kid=\"180\"></script>\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/locomotive-scroll@5/bundled/locomotive-scroll.css\" data-kid=\"181\">\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" data-kid=\"182\">\n\n<script type=\"module\" data-kid=\"183\">\n  import { animate, splitText } from 'https://esm.sh/animejs@4';\n\n  // Initialize Locomotive Scroll\n  const scroll = new LocomotiveScroll({\n    lenisOptions: {\n      duration: 1.2,\n      easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t))\n    }\n  });\n\n  // Typewriter Effect\n  const words = [\"Build your future.\", \"Own your time.\", \"Master your capital.\"];\n  let wordIndex = 0;\n  const target = document.getElementById('typewriter-text');\n\n  function type() {\n    const word = words[wordIndex];\n    let i = 0;\n    target.textContent = \"\";\n    \n    const interval = setInterval(() => {\n      target.textContent += word[i];\n      i++;\n      if (i >= word.length) {\n        clearInterval(interval);\n        setTimeout(erase, 2000);\n      }\n    }, 100);\n  }\n\n  function erase() {\n    let word = target.textContent;\n    const interval = setInterval(() => {\n      target.textContent = word.substring(0, word.length - 1);\n      word = target.textContent;\n      if (word.length === 0) {\n        clearInterval(interval);\n        wordIndex = (wordIndex + 1) % words.length;\n        setTimeout(type, 500);\n      }\n    }, 50);\n  }\n\n  type();\n\n  // Hero Stagger Reveal\n  animate('.reveal-target', {\n    opacity: [0, 1],\n    translateY: [30, 0],\n    duration: 1500,\n    delay: (el, i) => i * 150,\n    easing: 'outExpo'\n  });\n\n  // Reveal animations for scroll elements\n  const scrollReveals = document.querySelectorAll('.feature-card');\n  scrollReveals.forEach(el => {\n     el.style.opacity = '0';\n     el.style.transform = 'translateY(40px)';\n  });\n\n  scroll.on('scroll', () => {\n    scrollReveals.forEach(el => {\n      const rect = el.getBoundingClientRect();\n      if (rect.top < window.innerHeight * 0.8 && el.style.opacity === '0') {\n        animate(el, {\n          opacity: [0, 1],\n          translateY: [40, 0],\n          duration: 1200,\n          easing: 'outExpo'\n        });\n      }\n    });\n  });\n\n  // Refined Scroll Progress Logic\n  scroll.on('scroll', (args) => {\n    const progressLine = document.getElementById('scroll-progress-line');\n    const section = document.querySelector('.relative.min-h-\\\\[300vh\\\\]');\n    \n    if (section) {\n      const rect = section.getBoundingClientRect();\n      const viewportHeight = window.innerHeight;\n      \n      // Calculate how far through the section the top of the viewport is\n      // We start counting progress when the section hits the top of the screen\n      const totalScrollable = rect.height - viewportHeight;\n      const currentScroll = -rect.top;\n      \n      let progress = Math.min(Math.max(currentScroll / totalScrollable, 0), 1);\n      \n      if (progressLine) {\n        progressLine.style.transform = `scaleY(${progress})`;\n      }\n      \n      // Update step highlights\n      if (progress < 0.33) updateSteps(0);\n      else if (progress < 0.66) updateSteps(1);\n      else updateSteps(2);\n    }\n  });\n\n  function updateSteps(activeIdx) {\n    const steps = document.querySelectorAll('.progress-step');\n    steps.forEach((step, idx) => {\n      if (idx === activeIdx) {\n        step.classList.add('active');\n        step.style.opacity = '1';\n        step.querySelector('span').style.color = 'var(--brand)';\n      } else {\n        step.classList.remove('active');\n        step.style.opacity = '0.2';\n        step.querySelector('span').style.color = 'var(--text)';\n      }\n    });\n  }\n\n  // GSAP Parallax and Reveal Tweaks\n  gsap.registerPlugin(ScrollTrigger);\n  \n  // Custom reveals if needed (though Locomotive handles most via [data-scroll])\n  // Ensuring the sticky line is smooth\n  gsap.to(\".progress-line-fill\", {\n    scrollTrigger: {\n      trigger: \".relative.min-h-\\\\[300vh\\\\]\",\n      start: \"top top\",\n      end: \"bottom bottom\",\n      scrub: true\n    },\n    scaleY: 1,\n    ease: \"none\"\n  });\n\n</script>\n",
