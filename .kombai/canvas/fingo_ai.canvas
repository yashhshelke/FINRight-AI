class=\"text-[10px] text-white/30 uppercase tracking-widest font-bold\" data-kid=\"186\">Key Milestones</p>\n                        <div class=\"flex items-center gap-3 p-3 rounded-xl bg-white/[0.02] border border-white/5\" data-kid=\"187\">\n                            <i class=\"ti ti-checkbox text-emerald-400\" data-kid=\"188\"></i>\n                            <span class=\"text-xs font-medium text-white/70\" data-kid=\"189\">Initial Accumulation Base</span>\n                        </div>\n                    </div>\n\n                    <div class=\"mt-auto flex items-center gap-2 text-xs text-purple-400 bg-purple-400/5 p-4 rounded-2xl border border-purple-400/10\" data-kid=\"190\">\n                        <i class=\"ti ti-infinity\" data-kid=\"191\"></i>\n                        <span data-kid=\"192\">Compounding effect peaks in <span class=\"font-bold\" data-kid=\"193\">15 years</span>.</span>\n                    </div>\n                </div>\n            </div>\n            </div>\n            \n        \n    </main>\n\n    \n    <aside class=\"w-[400px] bg-[#171A20] border-l border-white/5 flex flex-col overflow-y-auto no-scrollbar shrink-0\" data-kid=\"194\">\n        <div class=\"p-8 space-y-10\" data-kid=\"195\">\n            <div class=\"flex flex-col gap-8\" data-kid=\"196\">\n                <div class=\"relative w-full aspect-[4/3] rounded-3xl overflow-hidden bg-[#0F1115] shadow-2xl border border-white/5\" data-kid=\"197\">\n                    <img src=\"https://images.unsplash.com/photo-1535378620166-273708d44e4c?auto=format&w=600&q=80&fit=crop\" alt=\"AI Robot\" class=\"w-full h-full object-cover mix-blend-screen opacity-70\" decoding=\"async\" loading=\"lazy\" data-kid=\"198\">\n                    <div class=\"absolute inset-0 bg-radial-[at_70%_30%] from-[#0F8A6B]/20 to-transparent\" data-kid=\"199\"></div>\n                    <div class=\"absolute inset-0 bg-linear-to-t from-[#171A20] via-transparent to-transparent\" data-kid=\"200\"></div>\n                    <div class=\"absolute top-4 left-4\" data-kid=\"201\">\n                        <div class=\"flex items-center gap-2 px-3 py-1 bg-emerald-500/20 border border-emerald-500/30 rounded-full backdrop-blur-md\" data-kid=\"202\">\n                            <span class=\"w-2 h-2 bg-emerald-500 rounded-full animate-pulse\" data-kid=\"203\"></span>\n                            <span class=\"text-[10px] font-bold text-emerald-400 uppercase tracking-widest\" data-kid=\"204\">AI Agent active</span>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"space-y-4\" data-kid=\"205\">\n                    <h2 class=\"text-3xl font-geist font-bold tracking-tight\" data-kid=\"206\">Contribution Planning</h2>\n                    <p class=\"text-white/50 text-sm leading-relaxed font-medium\" data-kid=\"207\">\n                        Based on your UPI activity from the last 30 days, I've detected $640 in surplus funds that can be diverted to your high-priority goals.\n                    </p>\n                </div>\n            </div>\n\n            <div class=\"space-y-6\" data-kid=\"208\">\n                \n                <div class=\"p-6 rounded-2xl bg-white/5 border border-white/10 space-y-6\" data-kid=\"209\">\n                    <div class=\"flex justify-between items-center\" data-kid=\"210\">\n                        <span class=\"text-sm font-bold\" data-kid=\"211\">Monthly Boost</span>\n                        <span class=\"text-amber-500 font-geist font-bold text-xl\" id=\"boost-value\" data-kid=\"212\">+$450/mo</span>\n                    </div>\n                    \n                    <div class=\"relative pt-4\" data-kid=\"213\">\n                        <input type=\"range\" min=\"0\" max=\"2000\" step=\"50\" value=\"450\" id=\"boost-slider\" class=\"w-full h-1 bg-white/10 rounded-lg appearance-none cursor-pointer accent-amber-500\" data-kid=\"214\">\n                    </div>\n\n                    <div class=\"space-y-4 pt-4 border-t border-white/5\" data-kid=\"215\">\n                        <p class=\"text-[11px] uppercase tracking-widest text-white/30 font-bold\" data-kid=\"216\">Projected Goal Acceleration</p>\n                        \n                        <div class=\"space-y-3\" data-kid=\"217\">\n                            <div class=\"flex justify-between items-center text-xs\" data-kid=\"218\">\n                                <span class=\"text-white/60\" data-kid=\"219\">Tesla Model S</span>\n                                <span class=\"text-emerald-400 font-bold\" data-kid=\"220\">-8 Months</span>\n                            </div>\n                            <div class=\"h-1 w-full bg-white/5 rounded-full overflow-hidden\" data-kid=\"221\">\n                                <div class=\"h-full bg-emerald-500/40 w-[80%]\" data-kid=\"222\"></div>\n                            </div>\n\n                            <div class=\"flex justify-between items-center text-xs\" data-kid=\"223\">\n                                <span class=\"text-white/60\" data-kid=\"224\">House Downpayment</span>\n                                <span class=\"text-emerald-400 font-bold\" data-kid=\"225\">-14 Months</span>\n                            </div>\n                            <div class=\"h-1 w-full bg-white/5 rounded-full overflow-hidden\" data-kid=\"226\">\n                                <div class=\"h-full bg-emerald-500/40 w-[65%]\" data-kid=\"227\"></div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"p-6 rounded-2xl bg-[#076653]/10 border border-[#076653]/20 space-y-4\" data-kid=\"228\">\n                    <div class=\"flex items-center gap-3\" data-kid=\"229\">\n                        <div class=\"w-10 h-10 rounded-full bg-emerald-500/20 flex items-center justify-center border border-emerald-500/30\" data-kid=\"230\">\n                            <i class=\"ti ti-rocket text-emerald-400 text-lg\" data-kid=\"231\"></i>\n                        </div>\n                        <div data-kid=\"232\">\n                            <p class=\"text-sm font-bold\" data-kid=\"233\">Efficiency Peak</p>\n                            <p class=\"text-[10px] text-emerald-400 font-medium\" data-kid=\"234\">AI Strategy: Recommended</p>\n                        </div>\n                    </div>\n                    <p class=\"text-xs text-white/60 leading-relaxed\" data-kid=\"235\">\n                        This adjustment will increase your average feasibility score to <span class=\"text-white font-bold\" data-kid=\"236\">94%</span> and potentially save you <span class=\"text-white font-bold\" data-kid=\"237\">$12,400</span> in future inflation costs.\n                    </p>\n                </div>\n\n                <button class=\"w-full py-5 bg-linear-to-r from-emerald-600 to-emerald-500 hover:from-emerald-500 hover:to-emerald-400 text-white rounded-2xl font-bold transition-all shadow-[0_15px_30px_rgba(16,185,129,0.25)] active:scale-95 border border-emerald-400/20\" data-kid=\"238\">\n                    Activate Optimized Plan\n                </button>\n            </div>\n        </div>\n    </aside>\n</div>\n\n<script type=\"module\" data-kid=\"239\">\n    import { animate, scroll, inView, stagger } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n\n    // GSAP Configuration with proper scroller targeting\n    const scrollerSelector = '.flex-1.overflow-y-auto';\n    \n    gsap.set('.goal-card', { autoAlpha: 0, y: 50 });\n    ScrollTrigger.batch('.goal-card', {\n        scroller: scrollerSelector,\n        start: 'top 95%',\n        onEnter: (elements) => {\n            gsap.to(elements, {\n                autoAlpha: 1,\n                y: 0,\n                duration: 1.2,\n                stagger: 0.2,\n                ease: 'expo.out',\n                overwrite: true\n            });\n        }\n    });\n\n    // Uniform Hover Animation using GSAP to prevent conflict with entrance\n    const goalCards = document.querySelectorAll('.goal-card');\n    goalCards.forEach(card => {\n        card.addEventListener('mouseenter', () => {\n            gsap.to(card, { \n                y: -12, \n                scale: 1.015, \n                duration: 0.4, \n                ease: 'power3.out',\n                boxShadow: '0 20px 40px rgba(0,0,0,0.4)',\n                borderColor: 'rgba(255,255,255,0.15)'\n            });\n            \n            const badge = card.querySelector('.achievement-badge');\n            if (badge) {\n                animate(badge, { scale: [1, 1.2, 1], rotate: [12, -5, 12] }, { type: 'spring', bounce: 0.6, duration: 0.6 });\n            }\n        });\n        \n        card.addEventListener('mouseleave', () => {\n            gsap.to(card, { \n                y: 0, \n                scale: 1, \n                duration: 0.5, \n                ease: 'power3.inOut',\n                boxShadow: '0 8px 32px rgba(0,0,0,0.3)',\n                borderColor: 'rgba(255,255,255,0.05)'\n            });\n        });\n    });\n\n    // Spring Pop for all feasibility badges on entrance\n    inView('.feasibility-badge', (element) => {\n        animate(element, { scale: [0, 1.1, 1], opacity: [0, 1] }, { type: 'spring', visualDuration: 0.6, bounce: 0.5, delay: 0.3 });\n    });\n\n    // Slider Interaction\n    const slider = document.getElementById('boost-slider');\n    const valueDisplay = document.getElementById('boost-value');\n    slider.addEventListener('input', (e) => {\n        const val = e.target.value;\n        valueDisplay.textContent = `+$${val}/mo`;\n        animate(valueDisplay, { y: [-5, 0], opacity: [0.5, 1] }, { duration: 0.2 });\n    });\n\n    // Achievement badge initial pop\n    inView('.achievement-badge', (element) => {\n        animate(element, { scale: [0, 1.3, 1], opacity: [0, 1], rotate: [0, 12] }, { type: 'spring', visualDuration: 0.8, bounce: 0.6, delay: 0.5 });\n    });\n\n</script>\n",
