      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@600&family=Inter:wght@400;500;600;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --bg-deep: #0F1115;\n    --bg-obsidian: #121418;\n    --bg-card: #1E222A;\n    --emerald: #10B981; /* Lightened for better contrast */\n    --emerald-dark: #065F46;\n    --emerald-glow: #34D399;\n    --amber: #FB923C;\n    --text-primary: #F7F5F2;\n    --text-secondary: #8E9BAE;\n  }\n\n  * {\n    scrollbar-width: thin;\n    scrollbar-color: var(--emerald) transparent;\n  }\n\n  body {\n    font-family: 'Inter', sans-serif;\n    background-color: var(--bg-deep);\n    color: var(--text-primary);\n    overflow-x: clip;\n  }\n\n  .font-serif { font-family: 'Cormorant Garamond', serif; }\n  \n  .glass-panel {\n    background: rgba(30, 34, 42, 0.4);\n    backdrop-filter: blur(20px);\n    border: 1px solid rgba(255, 255, 255, 0.08);\n  }\n\n  .bento-grid {\n    display: grid;\n    grid-template-columns: repeat(12, 1fr);\n    grid-gap: 1.5rem;\n  }\n\n  .gauge-progress {\n    fill: none;\n    stroke: var(--emerald);\n    stroke-width: 12;\n    stroke-linecap: round;\n    stroke-dasharray: 251;\n    stroke-dashoffset: 251;\n  }\n\n  .pulse-amber {\n    animation: pulse-ring 2s cubic-bezier(0.455, 0.03, 0.515, 0.955) infinite;\n  }\n\n  @keyframes pulse-ring {\n    0% { transform: scale(0.8); opacity: 0.5; }\n    50% { transform: scale(1.2); opacity: 0; }\n    100% { transform: scale(0.8); opacity: 0.5; }\n  }\n\n  .active-nav {\n    background: rgba(16, 185, 129, 0.1);\n    color: var(--text-primary);\n    border-right: 3px solid var(--emerald);\n  }\n\n  .fab-launcher {\n    box-shadow: 0 0 30px rgba(7, 102, 83, 0.4);\n  }\n\n  /* Lenis support */\n  html.lenis {\n    height: auto;\n  }\n  .lenis.lenis-smooth {\n    scroll-behavior: auto;\n  }\n  .lenis.lenis-smooth [data-lenis-prevent] {\n    overscroll-behavior: contain;\n  }\n  .lenis.lenis-stopped {\n    overflow: hidden;\n  }\n\n  /* Custom tooltips or popovers if needed */\n  .hover-glow:hover {\n    box-shadow: 0 0 20px rgba(7, 102, 83, 0.15);\n  }\n</style>\n\n<div class=\"flex h-screen overflow-hidden bg-[var(--bg-deep)]\" data-kid=\"1\">\n  \n  <aside id=\"sidebar-dashboard\" class=\"w-72 bg-[var(--bg-obsidian)] border-r border-white/5 flex flex-col z-50\" data-kid=\"2\">\n    <div class=\"p-8 pb-8\" data-kid=\"3\">\n      <div class=\"flex items-center gap-3\" data-kid=\"4\">\n        <div class=\"w-11 h-11 bg-[var(--emerald-dark)]/20 border border-[var(--emerald)]/30 rounded-xl flex items-center justify-center\" data-kid=\"5\">\n          <i class=\"ti ti-chart-dots text-[var(--emerald)] text-2xl\" data-kid=\"6\"></i>\n        </div>\n        <h1 class=\"font-serif text-3xl font-bold tracking-tight text-white leading-none\" data-kid=\"7\">Fingo<span class=\"text-[var(--emerald)]\" data-kid=\"8\">.</span></h1>\n      </div>\n    </div>\n    \n    <nav class=\"flex-1 px-4 space-y-0.5 overflow-y-auto\" data-kid=\"9\">\n      <p class=\"px-4 text-[10px] font-bold text-[var(--text-secondary)] uppercase tracking-[0.25em] mb-4 mt-2 opacity-60\" data-kid=\"10\">Operations</p>\n      \n      <a href=\"#\" class=\"nav-item active-nav flex items-center gap-4 px-4 py-3 rounded-lg text-sm font-medium\" data-kid=\"11\">\n        <i class=\"ti ti-layout-dashboard text-lg\" data-kid=\"12\"></i>\n        <span data-kid=\"13\">Overview</span>\n      </a>\n      <a href=\"#\" class=\"nav-item flex items-center gap-4 px-4 py-3 rounded-lg text-sm font-medium text-[var(--text-secondary)]\" data-kid=\"14\">\n        <i class=\"ti ti-receipt text-lg\" data-kid=\"15\"></i>\n        <span data-kid=\"16\">Transactions</span>\n      </a>\n      <a href=\"#\" class=\"nav-item flex items-center gap-4 px-4 py-3 rounded-lg text-sm font-medium text-[var(--text-secondary)]\" data-kid=\"17\">\n        <i class=\"ti ti-target-ar