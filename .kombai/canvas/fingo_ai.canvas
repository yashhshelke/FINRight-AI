      "html": "\n<section class=\"flex w-full h-screen bg-[#0F1115] text-white font-geist overflow-hidden select-none\" data-kid=\"0\">\n    \n    <div class=\"w-[40%] bg-[#171A20] relative flex flex-col justify-between p-16 border-r border-white/5\" data-kid=\"1\">\n        \n        <div class=\"relative z-20\" data-kid=\"2\">\n            <h1 class=\"font-['Cormorant_Garamond'] text-6xl font-light tracking-tight text-white/95 italic\" data-kid=\"3\">Fingo AI</h1>\n        </div>\n\n        \n        <div class=\"absolute inset-0 flex items-center justify-center pointer-events-none\" data-kid=\"4\">\n            <img id=\"companion-img\" src=\"https://images.unsplash.com/photo-1614508569207-3295ac89d75f?auto=format&w=1000&q=90\" alt=\"AI Companion\" class=\"w-full h-full object-cover mix-blend-screen opacity-90 translate-x-[15%]\" decoding=\"async\" loading=\"lazy\" data-kid=\"5\">\n            \n            \n            <div class=\"absolute inset-0 bg-gradient-to-t from-[#171A20] via-transparent to-transparent opacity-80\" data-kid=\"6\"></div>\n        </div>\n\n        \n        <div class=\"relative z-20 max-w-md bg-white/[0.03] backdrop-blur-md border border-white/5 p-8\" data-kid=\"7\">\n            <div class=\"flex items-center gap-3 mb-4\" data-kid=\"8\">\n                <div class=\"w-1.5 h-1.5 rounded-full bg-[#10B981] animate-pulse\" data-kid=\"9\"></div>\n                <span class=\"text-[9px] uppercase tracking-[0.4em] text-[#10B981] font-black\" data-kid=\"10\">Neural Engine Active</span>\n            </div>\n            <p id=\"step-hint\" class=\"text-white/90 text-lg leading-relaxed font-light italic\" data-kid=\"11\">\n                \"Welcome. I'm your AI financial architect. Let's design your wealth journey step by step.\"\n            </p>\n        </div>\n    </div>\n\n    \n    <div class=\"w-[60%] flex items-center justify-center p-12 lg:p-24 relative overflow-hidden bg-[#0F1115]\" data-kid=\"12\">\n        \n        <div class=\"absolute top-[-20%] right-[-10%] w-[600px] h-[600px] bg-[#076653]/10 blur-[180px] rounded-full pointer-events-none\" data-kid=\"13\"></div>\n        <div class=\"absolute bottom-[-10%] left-[10%] w-[400px] h-[400px] bg-[#FF812B]/5 blur-[150px] rounded-full pointer-events-none\" data-kid=\"14\"></div>\n\n        \n        <div id=\"wizard-container\" class=\"w-full max-w-2xl bg-[#171A20]/40 backdrop-blur-3xl border border-white/10 p-12 lg:p-16 relative z-10 shadow-[0_48px_80px_-12px_rgba(0,0,0,0.8)]\" data-kid=\"15\">\n            \n            \n            <div class=\"flex items-center gap-4 mb-16\" data-kid=\"16\">\n                <div class=\"flex-1 h-0.5 bg-white/5 relative overflow-hidden\" data-kid=\"17\">\n                    <div id=\"dot-1\" class=\"step-indicator absolute inset-0 bg-[#10B981] origin-left scale-x-100\" data-kid=\"18\"></div>\n                </div>\n                <div class=\"flex-1 h-0.5 bg-white/10 relative overflow-hidden\" data-kid=\"19\">\n                    <div id=\"dot-2\" class=\"step-indicator absolute inset-0 bg-[#10B981] origin-left scale-x-0\" data-kid=\"20\"></div>\n                </div>\n                <div class=\"flex-1 h-0.5 bg-white/10 relative overflow-hidden\" data-kid=\"21\">\n                    <div id=\"dot-3\" class=\"step-indicator absolute inset-0 bg-[#10B981] origin-left scale-x-0\" data-kid=\"22\"></div>\n                </div>\n                <div class=\"flex-1 h-0.5 bg-white/10 relative overflow-hidden\" data-kid=\"23\">\n                    <div id=\"dot-4\" class=\"step-indicator absolute inset-0 bg-[#10B981] origin-left scale-x-0\" data-kid=\"24\"></div>\n                </div>\n            </div>\n\n            \n            <div id=\"steps-viewport\" class=\"relative w-full overflow-visible\" data-kid=\"25\">\n                \n                \n                <div id=\"step-1\" class=\"step-page w-full space-y-12\" data-kid=\"26\">\n                    <div data-kid=\"27\">\n                        <h2 class=\"text-4xl font-light text-white mb-3 tracking-tight\" data-kid=\"28\">Primary Income</h2>\n                        <p class=\"text-white/50 text-base font-light\" data-kid=\"29\">Your foundation defines the architectural limits of your growth.</p>\n                    </div>\n\n                    <div class=\"space-y-12 pt-4\" data-kid=\"30\">\n                        <div class=\"relative group\" data-kid=\"31\">\n                            <input type=\"text\" id=\"income-input\" placeholder=\" \" value=\"85,000\" class=\"peer w-full bg-transparent border-b border-white/20 py-5 text-4xl font-light outline-hidden focus:border-[#10B981] transition-colors tracking-tight\" data-kid=\"32\">\n                            <label for=\"income-input\" class=\"absolute left-0 top-5 text-white/50 text-lg pointer-events-none transition-all duration-300 peer-focus:top-[-30px] peer-focus:text-xs peer-focus:text-[#10B981] peer-focus:uppercase peer-focus:tracking-[0.15em] peer-[:not(:placeholder-shown)]:top-[-30px] peer-[:not(:placeholder-shown)]:text-xs peer-[:not(:placeholder-shown)]:uppercase peer-[:not(:placeholder-shown)]:tracking-[0.15em]\" data-kid=\"33\">\n                                Annual Gross Income ($)\n                            </label>\n                        </div>\n\n                        <div class=\"grid grid-cols-2 gap-4\" data-kid=\"34\">\n                            <button class=\"py-5 border border-white/10 bg-white/5 hover:bg-white/10 transition-all text-[10px] uppercase tracking-[0.15em] font-bold text-white/50\" data-kid=\"35\">\n                                Monthly View\n                            </button>\n                            <button class=\"py-5 border border-[#10B981] bg-[#10B981]/10 text-white text-[10px] uppercase tracking-[0.15em] font-bold\" data-kid=\"36\">\n                                Annual View\n                            </button>\n                        </div>\n                    </div>\n\n                    <div class=\"flex justify-between items-center pt-12 border-t border-white/5\" data-kid=\"37\">\n                        <span class=\"text-white/40 text-[9px] uppercase tracking-[0.2em] font-black\" data-kid=\"38\">Step 01 / 04</span>\n                        <button onclick=\"nextStep(2)\" class=\"bg-[#FF812B] text-black font-black py-5 px-14 hover:bg-[#ff9650] hover:scale-[1.02] active:scale-[0.98] shadow-[0_12px_40px_rgba(255,129,43,0.4)] uppercase tracking-[0.15em] text-xs\" data-kid=\"39\">\n                            Continue\n                        </button>\n                    </div>\n                </div>\n\n                \n                <div id=\"step-2\" class=\"step-page w-full space-y-8 hidden opacity-0\" data-kid=\"40\">\n                    <div data-kid=\"41\">\n                        <h2 class=\"text-4xl font-light text-white mb-3 tracking-tight\" data-kid=\"42\">Your Ambitions</h2>\n                        <p class=\"text-white/40 text-base font-light\" data-kid=\"43\">Select the primary milestones you wish to architect.</p>\n                    </div>\n\n                    <div class=\"grid grid-cols-2 gap-4\" data-kid=\"44\">\n                        <div onclick=\"toggleGoal(this)\" class=\"p-8 border border-white/10 bg-white/5 cursor-pointer hover:border-white/30 transition-all group flex flex-col justify-between h-48 active-goal-border\" data-kid=\"45\">\n                            <i class=\"ti ti-home text-3xl text-white/20 group-hover:text-white/60 mb-4 transition-colors\" data-kid=\"46\"></i>\n                            <div data-kid=\"47\">\n                                <h3 class=\"text-white text-xl font-light mb-1\" data-kid=\"48\">Buy a House</h3>\n                                <p class=\"text-white/30 text-xs uppercase tracking-widest\" data-kid=\"49\">Primary Residence</p>\n                            </div>\n                        </div>\n                        <div onclick=\"toggleGoal(this)\" class=\"p-8 border border-[#10B981] bg-[#10B981]/10 cursor-pointer transition-all flex flex-col justify-between h-48\" data-kid=\"50\">\n                            <i class=\"ti ti-briefcase text-3xl text-[#10B981] mb-4\" data-kid=\"51\"></i>\n                            <div data-kid=\"52\">\n                                <h3 class=\"text-white text-xl font-light mb-1\" data-kid=\"53\">Career Transition</h3>\n                                <p class=\"text-[#10B981]/80 text-xs uppercase tracking-widest font-bold\" data-kid=\"54\">Pivot Fund</p>\n                            </div>\n                        </div>\n                        <div onclick=\"toggleGoal(this)\" class=\"p-8 border border-white/10 bg-white/5 cursor-pointer hover:border-white/30 transition-all group flex flex-col justify-between h-48\" data-kid=\"55\">\n                            <i class=\"ti ti-chart-line text-3xl text-white/20 group-hover:text-white/60 mb-4 transition-colors\" data-kid=\"56\"></i>\n                            <div data-kid=\"57\">\n                                <h3 class=\"text-white text-xl font-light mb-1\" data-kid=\"58\">Stock Portfolio</h3>\n                                <p class=\"text-white/30 text-xs uppercase tracking-widest\" data-kid=\"59\">Wealth Accrual</p>\n                            </div>\n                        </div>\n                        <div onclick=\"toggleGoal(this)\" class=\"p-8 border border-white/10 bg-white/5 cursor-pointer hover:border-white/30 transition-all group flex flex-col justify-between h-48\" data-kid=\"60\">\n                            <i class=\"ti ti-shield-check text-3xl text-white/20 group-hover:text-white/60 mb-4 transition-colors\" data-kid=\"61\"></i>\n                            <div data-kid=\"62\">\n                                <h3 class=\"text-white text-xl font-light mb-1\" data-kid=\"63\">Safety Net</h3>\n                                <p class=\"text-white/30 text-xs uppercase tracking-widest\" data-kid=\"64\">Emergency Reserves</p>\n                            </div>\n                        </div>\n                    </div>\n\n                    <div class=\"flex justify-between items-center pt-8\" data-kid=\"65\">\n                        <button onclick=\"nextStep(1)\" class=\"text-white/30 hover:text-white transition-colors text-xs uppercase tracking-widest font-bold\" data-kid=\"66\">Back</button>\n                        <button onclick=\"nextStep(3)\" class=\"bg-[#FF812B] text-black font-black py-5 px-14 hover:bg-[#ff9650] transition-all hover:scale-[1.02] shadow-[0_12px_40px_rgba(255,129,43,0.3)] uppercase tracking-[0.1em] text-sm\" data-kid=\"67\">\n                            Next Step\n                        </button>\n                    </div>\n                </div>\n\n                \n                <div id=\"step-3\" class=\"step-page w-full space-y-12 hidden opacity-0\" data-kid=\"68\">\n                    <div data-kid=\"69\">\n                        <h2 class=\"text-4xl font-light text-white mb-3 tracking-tight\" data-kid=\"70\">Savings Target</h2>\n                        <p class=\"text-white/40 text-base font-light\" data-kid=\"71\">Define the monthly intensity of your capital accumulation.</p>\n                    </div>\n\n                    <div class=\"space-y-16 py-4\" data-kid=\"72\">\n                        <div class=\"relative\" data-kid=\"73\">\n                            <div class=\"flex justify-between items-end mb-8\" data-kid=\"74\">\n                                <div class=\"space-y-1\" data-kid=\"75\">\n                                    <span class=\"text-white/20 text-[10px] uppercase tracking-widest font-bold block\" data-kid=\"76\">Monthly Accumulation</span>\n                                    <span id=\"savings-val\" class=\"text-5xl font-light text-[#10B981] font-mono tracking-tighter\" data-kid=\"77\">$2,450</span>\n                                </div>\n                                <div class=\"text-right space-y-1\" data-kid=\"78\">\n                                    <span class=\"text-white/20 text-[10px] uppercase tracking-widest font-bold block\" data-kid=\"79\">Efficiency Rating</span>\n                                    <span class=\"text-2xl font-light text-white\" data-kid=\"80\">88%</span>\n                                </div>\n                            </div>\n                            \n                            \n                            <div class=\"relative h-0.5 w-full bg-white/10 group\" data-kid=\"81\">\n                                <div id=\"slider-track\" class=\"absolute h-full bg-[#10B981] w-[45%]\" data-kid=\"82\"></div>\n                                <input type=\"range\" min=\"500\" max=\"10000\" step=\"100\" value=\"2450\" oninput=\"updateSavings(this)\" class=\"absolute w-full h-full opacity-0 cursor-pointer z-10\" data-kid=\"83\">\n                                <div id=\"slider-thumb\" class=\"absolute h-8 w-0.5 bg-white top-1/2 -translate-y-1/2 left-[45%] shadow-[0_0_20px_rgba(255,255,255,0.4)] pointer-events-none transition-all\" data-kid=\"84\"></div>\n                            </div>\n                        </div>\n\n                        <div class=\"bg-[#10B981]/5 border-l border-[#10B981] p-8 flex gap-6 items-start\" data-kid=\"85\">\n                            <i class=\"ti ti-bulb text-[#10B981] text-3xl\" data-kid=\"86\"></i>\n                            <div class=\"space-y-2\" data-kid=\"87\">\n                                <h4 class=\"text-white font-bold text-[10px] uppercase tracking-[0.15em]\" data-kid=\"88\">AI Projection</h4>\n                                <p class=\"text-white/50 text-base leading-relaxed font-light\" data-kid=\"89\">\n                                    At <span class=\"text-white font-medium\" data-kid=\"90\">$2,450/mo</span>, you will exceed your Career Transition goal 4 months ahead of schedule. Your debt-to-income ratio remains <span class=\"text-[#10B981] font-bold\" data-kid=\"91\">Optimal</span>.\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n\n                    <div class=\"flex justify-between items-center pt-8\" data-kid=\"92\">\n                        <button onclick=\"nextStep(2)\" class=\"text-white/30 hover:text-white transition-colors text-xs uppercase tracking-widest font-bold\" data-kid=\"93\">Back</button>\n                        <button onclick=\"nextStep(4)\" class=\"bg-[#FF812B] text-black font-black py-5 px-14 hover:bg-[#ff9650] transition-all hover:scale-[1.02] shadow-[0_12px_40px_rgba(255,129,43,0.3)] uppercase tracking-[0.1em] text-sm\" data-kid=\"94\">\n                            Analyze Profile\n                        </button>\n                    </div>\n                </div>\n\n                \n                <div id=\"step-4\" class=\"step-page w-full space-y-10 hidden opacity-0\" data-kid=\"95\">\n                    <div data-kid=\"96\">\n                        <h2 class=\"text-4xl font-light text-white mb-3 tracking-tight\" data-kid=\"97\">Spending Profile</h2>\n                        <p class=\"text-white/40 text-base font-light\" data-kid=\"98\">Categorize your typical monthly outflow architecture.</p>\n                    </div>\n\n                    <div class=\"space-y-6\" data-kid=\"99\">\n                        <div class=\"grid grid-cols-1 gap-3\" data-kid=\"100\">\n                            <label class=\"flex items-center justify-between p-6 border border-white/10 bg-white/5 cursor-pointer hover:bg-white/10 transition-all group\" data-kid=\"101\">\n                                <div class=\"flex items-center gap-4\" data-kid=\"102\">\n                                    <div class=\"w-10 h-10 border border-white/20 flex items-center justify-center group-hover:border-white/40\" data-kid=\"103\">\n                                        <i class=\"ti ti-feather text-white/40\" data-kid=\"104\"></i>\n                                    </div>\n                                    <div data-kid=\"105\">\n                                        <h4 class=\"text-white font-medium\" data-kid=\"106\">Minimalist</h4>\n                                        <p class=\"text-white/30 text-[10px] uppercase tracking-widest\" data-kid=\"107\">Essential Only • Low Volatility</p>\n                                    </div>\n                                </div>\n                                <input type=\"radio\" name=\"profile\" class=\"w-4 h-4 accent-[#10B981]\" checked data-kid=\"108\">\n                            </label>\n\n                            <label class=\"flex items-center justify-between p-6 border border-[#10B981] bg-[#10B981]/10 cursor-pointer transition-all group\" data-kid=\"109\">\n                                <div class=\"flex items-center gap-4\" data-kid=\"110\">\n                                    <div class=\"w-10 h-10 border border-[#10B981]/30 flex items-center justify-center\" data-kid=\"111\">\n                                        <i class=\"ti ti-crown text-[#10B981]\" data-kid=\"112\"></i>\n                                    </div>\n                                    <div data-kid=\"113\">\n                                        <h4 class=\"text-white font-medium\" data-kid=\"114\">Balanced Lifestyle</h4>\n                                        <p class=\"text-[#10B981] text-[10px] uppercase tracking-[0.15em] font-bold\" data-kid=\"115\">Growth Focus • Calculated Risk</p>\n                                    </div>\n                                </div>\n                                <input type=\"radio\" name=\"profile\" class=\"w-4 h-4 accent-[#10B981]\" checked data-kid=\"116\">\n                            </label>\n\n                            <label class=\"flex items-center justify-between p-6 border border-white/10 bg-white/5 cursor-pointer hover:bg-white/10 transition-all group\" data-kid=\"117\">\n                                <div class=\"flex items-center gap-4\" data-kid=\"118\">\n                                    <div class=\"w-10 h-10 border border-white/20 flex items-center justify-center group-hover:border-white/40\" data-kid=\"119\">\n                                        <i class=\"ti ti-bolt text-white/40\" data-kid=\"120\"></i>\n                                    </div>\n                                    <div data-kid=\"121\">\n                                        <h4 class=\"text-white font-medium\" data-kid=\"122\">Aggressive Expansion</h4>\n                                        <p class=\"text-white/30 text-[10px] uppercase tracking-[0.15em]\" data-kid=\"123\">High Reinvestment • Dynamic Flow</p>\n                                    </div>\n                                </div>\n                                <input type=\"radio\" name=\"profile\" class=\"w-4 h-4 accent-[#10B981]\" data-kid=\"124\">\n                            </label>\n                        </div>\n                    </div>\n\n                    <div class=\"flex justify-between items-center pt-8\" data-kid=\"125\">\n                        <button onclick=\"nextStep(3)\" class=\"text-white/30 hover:text-white transition-colors text-xs uppercase tracking-widest font-bold\" data-kid=\"126\">Back</button>\n                        <button onclick=\"completeOnboarding()\" class=\"bg-[#FF812B] text-black font-black py-5 px-14 hover:bg-[#ff9650] transition-all hover:scale-[1.02] shadow-[0_12px_40px_rgba(255,129,43,0.3)] uppercase tracking-[0.1em] text-sm\" data-kid=\"127\">\n                            Generate Dashboard\n                        </button>\n                    </div>\n                </div>\n\n            </div>\n\n            \n            <div class=\"absolute bottom-8 right-16 flex items-center gap-4 pointer-events-none opacity-20 group-hover:opacity-40 transition-opacity\" data-kid=\"128\">\n                <span class=\"text-[10px] uppercase tracking-[0.3em] font-bold text-white\" data-kid=\"129\">Encryption Layer AES-256</span>\n                <i class=\"ti ti-lock text-sm\" data-kid=\"130\"></i>\n            </div>\n        </div>\n    </div>\n</section>\n\n<style data-kid=\"131\">\n@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300&family=Geist:wght@300;400;500;700;900&family=JetBrains+Mono:wght@300;500&display=swap');\n\nbody {\n    background-color: #0F1115;\n    margin: 0;\n    padding: 0;\n}\n\n.font-geist { font-family: 'Geist', sans-serif; }\n.font-mono { font-family: 'JetBrains+Mono', monospace; }\n\n/* Custom Slider Styles */\ninput[type=\"range\"]::-webkit-slider-thumb {\n    -webkit-appearance: none;\n    appearance: none;\n    width: 20px;\n    height: 40px;\n    background: transparent;\n    cursor: pointer;\n}\n\n/* Animations & Transitions - Removed conflicts with JS */\n.step-page {\n    /* Transitions removed for JS control */\n}\n\n/* Sharp Borders and Micro-Interactions */\nbutton { border-radius: 1px; }\n#wizard-container { border-radius: 2px; }\n\n.active-goal-border {\n    border-color: #10B981;\n    background-color: rgba(16, 185, 129, 0.1);\n}\n</style>\n\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" data-kid=\"132\">\n<script type=\"module\" data-kid=\"133\">\n    import { animate, spring, stagger } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n\n    let currentStep = 1;\n    const hints = [\n        \"Your foundation defines the architectural limits of your growth.\",\n        \"Your ambitions act as the structural beacons for the AI's modeling engine.\",\n        \"Precision in accumulation strategy maximizes long-term yield velocity.\",\n        \"Mapping your outflow habits allows the engine to predict friction points.\"\n    ];\n\n    window.nextStep = async (step) => {\n        const currentEl = document.getElementById(`step-${currentStep}`);\n        const nextEl = document.getElementById(`step-${step}`);\n        const hintEl = document.getElementById('step-hint');\n        const indicators = document.querySelectorAll('.step-indicator');\n        const direction = step > currentStep ? 1 : -1;\n\n        // Transition: Slide Push\n        await animate(currentEl, { \n            opacity: 0, \n            x: direction === 1 ? -40 : 40,\n            filter: \"blur(4px)\"\n        }, { duration: 0.3, ease: \"easeIn\" }).finished;\n        \n        currentEl.classList.add('hidden');\n        nextEl.classList.remove('hidden');\n        \n        animate(nextEl, { x: direction === 1 ? 40 : -40, opacity: 0, filter: \"blur(4px)\" }, { duration: 0 });\n        \n        currentStep = step;\n        hintEl.textContent = `\"${hints[currentStep - 1]}\"`;\n        \n        // Update Indicators using scaleX instead of width\n        indicators.forEach((ind, i) => {\n            if (i + 1 <= currentStep) {\n                animate(ind, { scaleX: 1 }, { duration: 0.5, ease: \"easeOut\" });\n            } else {\n                animate(ind, { scaleX: 0 }, { duration: 0.5, ease: \"easeOut\" });\n            }\n        });\n\n        animate(nextEl, { \n            opacity: 1, \n            x: 0,\n            filter: \"blur(0px)\"\n        }, { duration: 0.5, ease: [0.23, 1, 0.32, 1] });\n\n        // Companion subtle reaction\n        animate(\"#companion-img\", { \n            scale: [0.9, 0.92, 0.9],\n            x: direction === 1 ? [\"15%\", \"17%\", \"15%\"] : [\"15%\", \"13%\", \"15%\"]\n        }, { duration: 1.2 });\n    }\n\n    window.updateSavings = (el) => {\n        const val = parseInt(el.value);\n        document.getElementById('savings-val').textContent = `$${val.toLocaleString()}`;\n        const percent = ((val - 500) / (10000 - 500)) * 100;\n        document.getElementById('slider-track').style.width = `${percent}%`;\n        document.getElementById('slider-thumb').style.left = `${percent}%`;\n    }\n\n    window.toggleGoal = (el) => {\n        const isActive = el.classList.contains('active-goal-border');\n        if (isActive) {\n            el.classList.remove('active-goal-border', 'border-[#10B981]', 'bg-[#10B981]/10');\n            el.classList.add('border-white/10', 'bg-white/5');\n            el.querySelector('i').classList.remove('text-[#10B981]');\n            el.querySelector('i').classList.add('text-white/20');\n        } else {\n            el.classList.add('active-goal-border', 'border-[#10B981]', 'bg-[#10B981]/10');\n            el.classList.remove('border-white/10', 'bg-white/5');\n            el.querySelector('i').classList.add('text-[#10B981]');\n            el.querySelector('i').classList.remove('text-white/20');\n        }\n        \n        animate(el, { scale: [1, 0.98, 1] }, { duration: 0.2 });\n    }\n\n    window.completeOnboarding = () => {\n        const container = document.getElementById('wizard-container');\n        animate(container, { \n            y: -100, \n            opacity: 0, \n            scale: 0.9,\n            filter: \"blur(20px)\" \n        }, { duration: 0.8, ease: \"backIn\" }).finished.then(() => {\n            alert(\"Onboarding Complete. Initializing Financial Neural Network...\");\n        });\n    }\n\n    // Initial Entrance\n    animate(\"#wizard-container\", { \n        y: [40, 0], \n        opacity: [0, 1] \n    }, { delay: 0.5, duration: 1, ease: [0.23, 1, 0.32, 1] });\n    \n    animate(\"#dot-1\", { \n        scaleX: [0, 1] \n    }, { delay: 1, duration: 0.8 });\n    \n    // Ensure others are hidden initially\n    animate(\"#dot-2, #dot-3, #dot-4\", { scaleX: 0 }, { duration: 0 });\n\n</script>\n",
