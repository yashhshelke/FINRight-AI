      "html": "\n<div class=\"min-h-screen bg-[#0F1115] text-white font-sans selection:bg-emerald-500/30 overflow-x-clip\" data-kid=\"0\">\n    <style data-kid=\"1\">\n        @import url('https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Inter:wght@300;400;500;600;700&family=Cormorant+Garamond:ital,wght@0,600;1,600&display=swap');\n        @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n        :root {\n            --bg-deep: #0F1115;\n            --surface: #171A20;\n            --emerald: #076653;\n            --amber: #FF812B;\n            --charcoal: #1E222A;\n            --emerald-glow: rgba(7, 102, 83, 0.4);\n        }\n\n        .font-geist { font-family: 'Geist', sans-serif; }\n        .font-serif { font-family: 'Cormorant Garamond', serif; }\n        \n        /* Glassmorphism utility */\n        .glass {\n            background: rgba(255, 255, 255, 0.03);\n            backdrop-filter: blur(12px);\n            border: 1px solid rgba(255, 255, 255, 0.08);\n        }\n\n        /* Hide scrollbars but keep functionality */\n        .no-scrollbar::-webkit-scrollbar { display: none; }\n        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }\n\n        /* Animation utilities */\n        /* No initial opacity in CSS to follow GSAP best practices */\n        /* No transitions on message-bubble to avoid GSAP conflicts */\n        .prompt-chip { transform: scale(1); }\n    </style>\n\n    \n    <aside class=\"fixed left-0 top-0 h-full w-24 bg-[#171A20] border-r border-white/5 flex flex-col items-center py-10 z-50\" data-kid=\"2\">\n        <div class=\"mb-14\" data-kid=\"3\">\n            <span class=\"font-serif text-3xl text-emerald-400 italic\" data-kid=\"4\">F.</span>\n        </div>\n        \n        <nav class=\"flex flex-col gap-8 flex-1\" data-kid=\"5\">\n            <a href=\"#\" class=\"w-12 h-12 rounded-2xl flex items-center justify-center text-white/30 hover:bg-white/5 hover:text-emerald-400 transition-all duration-300\" data-kid=\"6\">\n                <i class=\"ti ti-layout-dashboard text-2xl\" data-kid=\"7\"></i>\n            </a>\n            <a href=\"#\" class=\"w-12 h-12 rounded-2xl flex items-center justify-center bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 relative\" data-kid=\"8\">\n                <i class=\"ti ti-robot text-2xl\" data-kid=\"9\"></i>\n                <div class=\"absolute -right-1 top-1/2 -translate-y-1/2 w-1 h-4 bg-emerald-500 rounded-full\" data-kid=\"10\"></div>\n            </a>\n            <a href=\"#\" class=\"w-12 h-12 rounded-2xl flex items-center justify-center text-white/30 hover:bg-white/5 hover:text-emerald-400 transition-all duration-300\" data-kid=\"11\">\n                <i class=\"ti ti-wallet text-2xl\" data-kid=\"12\"></i>\n            </a>\n            <a href=\"#\" class=\"w-12 h-12 rounded-2xl flex items-center justify-center text-white/30 hover:bg-white/5 hover:text-emerald-400 transition-all duration-300\" data-kid=\"13\">\n                <i class=\"ti ti-chart-dots text-2xl\" data-kid=\"14\"></i>\n            </a>\n            <a href=\"#\" class=\"w-12 h-12 rounded-2xl flex items-center justify-center text-white/30 hover:bg-white/5 hover:text-emerald-400 transition-all duration-300\" data-kid=\"15\">\n                <i class=\"ti ti-file-text text-2xl\" data-kid=\"16\"></i>\n            </a>\n        </nav>\n\n        <div class=\"mt-auto\" data-kid=\"17\">\n            <div class=\"w-12 h-12 rounded-full border border-white/10 p-0.5 overflow-hidden ring-2 ring-emerald-500/20\" data-kid=\"18\">\n                <img src=\"https://i.pravatar.cc/150?u=fingo\" alt=\"User\" class=\"w-full h-full object-cover rounded-full\" data-kid=\"19\">\n            </div>\n        </div>\n    </aside>\n\n    \n    <main class=\"ml-24 min-h-screen flex flex-col relative\" data-kid=\"20\">\n        \n        <header class=\"h-20 border-b border-white/5 px-10 flex items-center justify-between backdrop-blur-md bg-[#0F1115]/60 sticky top-0 z-40\" data-kid=\"21\">\n            <div class=\"flex items-center gap-3\" data-kid=\"22\">\n                <h1 class=\"text-xl font-geist font-semibold tracking-tight\" data-kid=\"23\">AI Financial Coach</h1>\n                <span class=\"px-2 py-0.5 bg-emerald-500/10 text-emerald-400 text-[10px] font-bold rounded-md uppercase tracking-widest border border-emerald-500/20\" data-kid=\"24\">v2.4 Pro</span>\n            </div>\n            \n            <div class=\"flex items-center gap-6\" data-kid=\"25\">\n                <div class=\"hidden lg:flex items-center gap-2 px-3 py-1.5 bg-white/5 border border-white/10 rounded-xl\" data-kid=\"26\">\n                    <div class=\"w-2 h-2 bg-emerald-500 rounded-full animate-pulse\" data-kid=\"27\"></div>\n                    <span class=\"text-[10px] font-bold text-white/40 uppercase tracking-widest\" data-kid=\"28\">Model: GPT-4o-Fingo</span>\n                    <i class=\"ti ti-chevron-down text-white/20 text-xs\" data-kid=\"29\"></i>\n                </div>\n                <div class=\"relative\" data-kid=\"30\">\n                    <i class=\"ti ti-search absolute left-4 top-1/2 -translate-y-1/2 text-white/30\" data-kid=\"31\"></i>\n                    <input type=\"text\" placeholder=\"Search insights...\" class=\"bg-white/5 border border-white/10 rounded-full py-2 pl-12 pr-6 text-sm w-48 focus:outline-none focus:border-emerald-500/50 transition-all\" data-kid=\"32\">\n                </div>\n                <button class=\"w-10 h-10 rounded-full glass flex items-center justify-center text-white/60 hover:text-white transition-colors relative\" data-kid=\"33\">\n                    <i class=\"ti ti-bell text-xl\" data-kid=\"34\"></i>\n                    <span class=\"absolute top-2 right-2 w-2 h-2 bg-amber-500 rounded-full ring-2 ring-[#0F1115]\" data-kid=\"35\"></span>\n                </button>\n            </div>\n        </header>\n\n        \n        <section class=\"flex-1 flex flex-col relative overflow-hidden h-[calc(100vh-5rem)]\" data-kid=\"36\">\n            \n            <div class=\"absolute inset-0 z-0 flex items-center justify-center pointer-events-none opacity-[0.06] mix-blend-lighten overflow-hidden\" data-kid=\"37\">\n                <img id=\"robot-bg\" src=\"https://images.unsplash.com/photo-1688587571105-c770775b2b42?auto=format&w=1200&q=80\" alt=\"Robot Watermark\" class=\"w-full h-full object-contain scale-110 blur-2xl\" data-kid=\"38\">\n                <div class=\"absolute inset-0 bg-radial-gradient from-transparent via-[#0F1115]/40 to-[#0F1115]\" data-kid=\"39\"></div>\n            </div>\n\n            \n            <div id=\"chat-window\" class=\"flex-1 overflow-y-auto px-10 py-10 no-scrollbar relative z-10\" data-kid=\"40\">\n                <div class=\"max-w-4xl mx-auto flex flex-col gap-12\" data-kid=\"41\">\n                    \n                    <div class=\"flex flex-col gap-3 max-w-2xl message-bubble\" data-kid=\"42\">\n                        <div class=\"flex items-center gap-3\" data-kid=\"43\">\n                            <div class=\"w-7 h-7 rounded-lg bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center\" data-kid=\"44\">\n                                <i class=\"ti ti-robot text-emerald-400 text-sm\" data-kid=\"45\"></i>\n                            </div>\n                            <span class=\"text-[11px] text-white/40 font-medium\" data-kid=\"46\">Fingo Assistant • 09:41 AM</span>\n                        </div>\n                        <div class=\"bg-[#1E222A] p-6 rounded-3xl rounded-tl-none border border-white/5 shadow-2xl\" data-kid=\"47\">\n                            <p class=\"text-[15px] leading-relaxed text-white/90 font-light\" data-kid=\"48\">\n                                Good morning! I've just completed a scan of your <span class=\"text-emerald-400 font-medium\" data-kid=\"49\">HDFC Savings Account</span> and noted a significant reduction in discretionary spending this week. You're currently <strong class=\"text-white\" data-kid=\"50\">₹4,200</strong> below your projected food budget.\n                            </p>\n                        </div>\n                        \n                        \n                        <div class=\"flex flex-wrap gap-3 mt-1\" data-kid=\"51\">\n                            <div class=\"glass p-3 pr-5 rounded-xl flex items-center gap-3 cursor-pointer group border-emerald-500/20 shadow-lg message-bubble hover:bg-white/5\" data-kid=\"52\">\n                                <i class=\"ti ti-heart-rate-monitor text-emerald-400 text-lg\" data-kid=\"53\"></i>\n                                <div data-kid=\"54\">\n                                    <p class=\"text-[9px] text-white/40 font-medium tracking-wide\" data-kid=\"55\">Health Score</p>\n                                    <div class=\"flex items-center gap-1.5\" data-kid=\"56\">\n                                        <span class=\"text-xs font-geist font-bold\" data-kid=\"57\">88/100</span>\n                                        <i class=\"ti ti-arrow-up-right text-emerald-400 text-[10px]\" data-kid=\"58\"></i>\n                                    </div>\n                                </div>\n                            </div>\n                            \n                            <div class=\"glass p-3 pr-5 rounded-xl flex items-center gap-3 cursor-pointer group border-emerald-500/20 shadow-lg message-bubble hover:bg-white/5\" data-kid=\"59\">\n                                <i class=\"ti ti-pig-money text-emerald-400 text-lg\" data-kid=\"60\"></i>\n                                <div data-kid=\"61\">\n                                    <p class=\"text-[9px] text-white/40 font-medium tracking-wide\" data-kid=\"62\">Jun Savings</p>\n                                    <div class=\"flex items-center gap-1.5\" data-kid=\"63\">\n                                        <span class=\"text-xs font-geist font-bold\" data-kid=\"64\">₹12,450</span>\n                                        <span class=\"text-[9px] text-emerald-400 font-medium\" data-kid=\"65\">+12.4%</span>\n                                    </div>\n                                </div>\n                            </div>\n\n                            <div class=\"glass p-3 pr-5 rounded-xl flex items-center gap-3 cursor-pointer group border-emerald-500/20 shadow-lg message-bubble hover:bg-white/5\" data-kid=\"66\">\n                                <i class=\"ti ti-file-text text-emerald-400 text-lg\" data-kid=\"67\"></i>\n                                <div data-kid=\"68\">\n                                    <p class=\"text-[9px] text-white/40 font-medium tracking-wide\" data-kid=\"69\">June Statement</p>\n                                    <div class=\"flex items-center gap-1.5\" data-kid=\"70\">\n                                        <span class=\"text-xs font-geist font-bold\" data-kid=\"71\">HDFC-9921</span>\n                                        <i class=\"ti ti-external-link text-white/20 text-[10px]\" data-kid=\"72\"></i>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n\n                    \n                    <div class=\"flex flex-col gap-3 max-w-xl self-end message-bubble\" data-kid=\"73\">\n                        <div class=\"flex items-center gap-3 justify-end\" data-kid=\"74\">\n                            <span class=\"text-[11px] text-white/40 font-medium\" data-kid=\"75\">You • Just Now</span>\n                            <div class=\"w-7 h-7 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center\" data-kid=\"76\">\n                                <i class=\"ti ti-user text-white/40 text-sm\" data-kid=\"77\"></i>\n                            </div>\n                        </div>\n                        <div class=\"bg-[#076653] p-6 rounded-3xl rounded-tr-none shadow-2xl border border-emerald-400/10\" data-kid=\"78\">\n                            <p class=\"text-[15px] leading-relaxed text-white\" data-kid=\"79\">\n                                That's great to hear. Based on these savings, is it a good time to increase my mutual fund SIP or should I keep more in liquid cash?\n                            </p>\n                        </div>\n                    </div>\n\n                    \n                    <div id=\"ai-typing\" class=\"flex flex-col gap-3 max-w-2xl message-bubble\" data-kid=\"80\">\n                        <div class=\"flex items-center gap-3\" data-kid=\"81\">\n                            <div class=\"w-7 h-7 rounded-lg bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center\" data-kid=\"82\">\n                                <i class=\"ti ti-robot text-emerald-400 text-sm\" data-kid=\"83\"></i>\n                            </div>\n                            <span class=\"text-[11px] text-white/40 font-medium\" data-kid=\"84\">Fingo Assistant • Thinking</span>\n                        </div>\n                        <div class=\"bg-[#1E222A] p-6 rounded-3xl rounded-tl-none border border-white/5 shadow-2xl flex items-center gap-1.5\" data-kid=\"85\">\n                            <div class=\"w-1.5 h-1.5 bg-emerald-500/60 rounded-full animate-bounce\" style=\"animation-delay: 0s\" data-kid=\"86\"></div>\n                            <div class=\"w-1.5 h-1.5 bg-emerald-500/60 rounded-full animate-bounce\" style=\"animation-delay: 0.2s\" data-kid=\"87\"></div>\n                            <div class=\"w-1.5 h-1.5 bg-emerald-500/60 rounded-full animate-bounce\" style=\"animation-delay: 0.4s\" data-kid=\"88\"></div>\n                        </div>\n                    </div>\n\n                    \n                    <div id=\"ai-response-2\" class=\"hidden flex flex-col gap-3 max-w-2xl message-bubble\" data-kid=\"89\">\n                        <div class=\"flex items-center gap-3\" data-kid=\"90\">\n                            <div class=\"w-7 h-7 rounded-lg bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center\" data-kid=\"91\">\n                                <i class=\"ti ti-robot text-emerald-400 text-sm\" data-kid=\"92\"></i>\n                            </div>\n                            <span class=\"text-[11px] text-white/40 font-medium\" data-kid=\"93\">Fingo Assistant</span>\n                        </div>\n                        <div class=\"bg-[#1E222A] p-6 rounded-3xl rounded-tl-none border border-white/5 shadow-2xl\" data-kid=\"94\">\n                            <p class=\"text-[15px] leading-relaxed text-white/90 font-light\" data-kid=\"95\">\n                                Analyzing your risk profile and upcoming expenses... 📊<br data-kid=\"96\"><br data-kid=\"97\">\n                                Your current liquidity stands at <strong class=\"text-emerald-400\" data-kid=\"98\">3.5x</strong> your monthly expenses. Recommended buffer is 3x. I suggest increasing your <strong class=\"text-white italic\" data-kid=\"99\">Index Fund SIP</strong> by <strong class=\"text-emerald-400\" data-kid=\"100\">₹2,500</strong>. This optimizes your long-term growth without compromising safety.\n                            </p>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"p-10 bg-[#0F1115] relative z-30\" data-kid=\"101\">\n                <div class=\"max-w-4xl mx-auto flex flex-col gap-6\" data-kid=\"102\">\n                    \n                    \n                    <div id=\"prompt-chips\" class=\"flex gap-2.5 overflow-x-auto no-scrollbar pb-1 justify-center\" data-kid=\"103\">\n                        <button class=\"prompt-chip whitespace-nowrap px-6 py-2 glass rounded-full text-xs font-medium text-white/50 hover:text-emerald-400 hover:border-emerald-500/40 transition-colors cursor-pointer\" data-kid=\"104\">\n                            Analyze Credit Card Score\n                        </button>\n                        <button class=\"prompt-chip whitespace-nowrap px-6 py-2 glass rounded-full text-xs font-medium text-white/50 hover:text-emerald-400 hover:border-emerald-500/40 transition-colors cursor-pointer\" data-kid=\"105\">\n                            Optimize Tax Savings\n                        </button>\n                        <button class=\"prompt-chip whitespace-nowrap px-6 py-2 glass rounded-full text-xs font-medium text-white/50 hover:text-emerald-400 hover:border-emerald-500/40 transition-colors cursor-pointer\" data-kid=\"106\">\n                            Auto-Categorize UPI\n                        </button>\n                        <button class=\"prompt-chip whitespace-nowrap px-6 py-2 glass rounded-full text-xs font-medium text-white/50 hover:text-emerald-400 hover:border-emerald-500/40 transition-colors cursor-pointer\" data-kid=\"107\">\n                            Find Subscriptions to Cancel\n                        </button>\n                    </div>\n\n                    \n                    <div class=\"relative group\" data-kid=\"108\">\n                        <div class=\"relative flex items-center bg-[#171A20] border border-white/10 rounded-[2rem] p-2 pr-4 transition-all group-focus-within:border-emerald-500/40 group-focus-within:shadow-[0_4px_20px_rgba(7,102,83,0.1)]\" data-kid=\"109\">\n                            <div class=\"px-5 text-white/20\" data-kid=\"110\">\n                                <i class=\"ti ti-microphone text-xl hover:text-emerald-400 cursor-pointer\" data-kid=\"111\"></i>\n                            </div>\n                            <input type=\"text\" placeholder=\"Ask Fingo anything about your wealth journey...\" class=\"flex-1 bg-transparent border-none py-4 text-sm focus:outline-none placeholder:text-white/40\" data-kid=\"112\">\n                            <div class=\"flex items-center gap-3\" data-kid=\"113\">\n                                <button class=\"w-10 h-10 rounded-full hover:bg-white/5 flex items-center justify-center text-white/40 transition-colors\" data-kid=\"114\">\n                                    <i class=\"ti ti-paperclip text-xl\" data-kid=\"115\"></i>\n                                </button>\n                                <button class=\"h-11 px-6 bg-emerald-600 hover:bg-emerald-500 rounded-full font-geist font-medium text-xs transition-all shadow-lg shadow-emerald-900/30 flex items-center gap-2\" data-kid=\"116\">\n                                    Send insight <i class=\"ti ti-send-2 text-lg\" data-kid=\"117\"></i>\n                                </button>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </section>\n    </main>\n\n    \n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"118\"></script>\n    <script type=\"module\" data-kid=\"119\">\n        import { animate, spring, stagger } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n\n        // GSAP Entrance\n        window.addEventListener('load', () => {\n            // Initial state for messages (before GSAP)\n            gsap.set('.message-bubble', { y: 20, opacity: 0 });\n\n            gsap.to('.message-bubble', {\n                opacity: 1,\n                y: 0,\n                duration: 0.8,\n                stagger: 0.1,\n                ease: \"power2.out\"\n            });\n\n            // Simulate AI reply delay\n            setTimeout(() => {\n                const typing = document.getElementById('ai-typing');\n                const response = document.getElementById('ai-response-2');\n                \n                if (typing && response) {\n                    gsap.to(typing, { \n                        opacity: 0, \n                        y: -10, \n                        duration: 0.4, \n                        onComplete: () => {\n                            typing.classList.add('hidden');\n                            response.classList.remove('hidden');\n                            gsap.fromTo(response, \n                                { y: 15, opacity: 0 }, \n                                { y: 0, opacity: 1, duration: 0.6, ease: \"power2.out\" }\n                            );\n                        } \n                    });\n                }\n            }, 3500);\n        });\n\n        // MotionJS - Prompt Chips Pop\n        const chips = document.querySelectorAll('.prompt-chip');\n        chips.forEach(chip => {\n            chip.addEventListener('mouseenter', () => {\n                animate(chip, { scale: 1.05 }, { type: \"spring\", stiffness: 400, damping: 10 });\n            });\n            chip.addEventListener('mouseleave', () => {\n                animate(chip, { scale: 1 }, { type: \"spring\", stiffness: 400, damping: 10 });\n            });\n        });\n\n        // Stagger list on enter for prompt chips\n        animate('#prompt-chips > *', \n            { opacity: [0, 1], x: [-20, 0] }, \n            { delay: stagger(0.1), duration: 0.6 }\n        );\n\n        // Watermark subtle drift\n        animate('#robot-bg', \n            { scale: [1.25, 1.35], x: [-10, 10], y: [-10, 10] }, \n            { duration: 20, repeat: Infinity, direction: \"alternate\", ease: \"easeInOut\" }\n        );\n\n    </script>\n</div>\n",
