      "html": "\n\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" data-kid=\"0\">\n<link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" data-kid=\"1\">\n\n<style data-kid=\"2\">\n    @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@600&family=Inter:wght@400;500;600;700&family=Geist:wght@400;700;900&display=swap');\n\n    :root {\n        --fingo-void: #0F1115;\n        --fingo-graphite: #1E222A;\n        --fingo-amber: #FF812B;\n        --fingo-success: #22C55E;\n        --fingo-warning: #F59E0B;\n    }\n\n    .fingo-canvas {\n        background-color: var(--fingo-void);\n        color: white;\n        font-family: 'Inter', sans-serif;\n        overflow-x: clip;\n        min-height: 100vh;\n    }\n\n    .font-cormorant { font-family: 'Cormorant Garamond', serif; }\n    .font-geist { font-family: 'Geist', sans-serif; }\n\n    /* Tactile Surfaces */\n    .tactile-panel {\n        background: var(--fingo-graphite);\n        border: 1px solid rgba(255, 255, 255, 0.03);\n        box-shadow: \n            inset 0 1px 1px rgba(255, 255, 255, 0.05),\n            0 20px 40px rgba(0, 0, 0, 0.4);\n    }\n\n    .glass-highlight {\n        background: rgba(255, 255, 255, 0.02);\n        backdrop-filter: blur(10px);\n        border: 1px solid rgba(255, 255, 255, 0.08);\n    }\n\n    .text-glow-amber { text-shadow: 0 0 20px rgba(255, 129, 43, 0.3); }\n    .text-glow-success { text-shadow: 0 0 20px rgba(34, 197, 94, 0.3); }\n\n    /* Gauge Driven by GSAP - No CSS transitions */\n\n    /* Prevent text wrapping on simulator */\n    .no-wrap { white-space: nowrap; }\n    \n    .timeline-node {\n        transition: transform 0.3s ease;\n    }\n    .timeline-node:hover {\n        transform: scale(1.1);\n    }\n</style>\n\n<div class=\"fingo-canvas\" data-kid=\"3\">\n    \n    <nav class=\"fixed bottom-6 left-1/2 -translate-x-1/2 z-50 px-5 py-2.5 glass-highlight rounded-2xl flex items-center gap-5\" data-kid=\"4\">\n        <div class=\"w-9 h-9 bg-white text-black rounded-lg flex items-center justify-center font-cormorant text-xl font-bold\" data-kid=\"5\">F</div>\n        <div class=\"h-4 w-px bg-white/10\" data-kid=\"6\"></div>\n        <div class=\"flex items-center gap-4\" data-kid=\"7\">\n            <button class=\"p-2 text-white/30 hover:text-white transition-all\" data-kid=\"8\"><i class=\"ti ti-home text-xl\" data-kid=\"9\"></i></button>\n            <button class=\"p-2 text-white/30 hover:text-white transition-all\" data-kid=\"10\"><i class=\"ti ti-chart-bar text-xl\" data-kid=\"11\"></i></button>\n            <button class=\"p-2 text-amber-500 bg-amber-500/10 rounded-lg\" data-kid=\"12\"><i class=\"ti ti-shield-check text-xl\" data-kid=\"13\"></i></button>\n            <button class=\"p-2 text-white/30 hover:text-white transition-all\" data-kid=\"14\"><i class=\"ti ti-message-dots text-xl\" data-kid=\"15\"></i></button>\n            <button class=\"p-2 text-white/30 hover:text-white transition-all\" data-kid=\"16\"><i class=\"ti ti-settings text-xl\" data-kid=\"17\"></i></button>\n        </div>\n    </nav>\n\n    <div id=\"smooth-wrapper\" data-kid=\"18\">\n        \n        <section class=\"min-h-screen flex flex-col items-center justify-center px-6 pt-12 pb-24 relative\" data-kid=\"19\">\n            <div class=\"container mx-auto max-w-5xl text-center z-10\" data-kid=\"20\">\n                <div class=\"mb-8 inline-flex items-center gap-2 px-3 py-1 bg-white/5 border border-white/10 rounded-full text-[10px] font-bold uppercase tracking-widest text-white/40\" data-kid=\"21\">\n                    <span class=\"w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse\" data-kid=\"22\"></span>\n                    Live Risk Analysis\n                </div>\n                \n                <h1 class=\"text-6xl md:text-8xl font-geist font-black tracking-tighter leading-none mb-12\" data-kid=\"23\">\n                    SURVIVAL <span class=\"text-white/10\" data-kid=\"24\">WINDOW</span>\n                </h1>\n\n                <div class=\"relative w-full max-w-xl mx-auto mb-16\" id=\"gauge-container\" data-kid=\"25\">\n                    <svg class=\"w-full h-auto\" viewBox=\"0 0 100 52\" data-kid=\"26\">\n                        <path d=\"M 10 45 A 40 40 0 0 1 90 45\" fill=\"none\" stroke=\"#22262e\" stroke-width=\"4\" stroke-linecap=\"round\" data-kid=\"27\"></path>\n                        <path id=\"survival-gauge-path\" d=\"M 10 45 A 40 40 0 0 1 90 45\" fill=\"none\" stroke=\"url(#hero-grad)\" stroke-width=\"4\" stroke-linecap=\"round\" stroke-dasharray=\"126\" stroke-dashoffset=\"126\" data-kid=\"28\"></path>\n                        <defs data-kid=\"29\">\n                            <linearGradient id=\"hero-grad\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"0%\" data-kid=\"30\">\n                                <stop offset=\"0%\" stop-color=\"#F59E0B\" data-kid=\"31\"></stop>\n                                <stop offset=\"100%\" stop-color=\"#22C55E\" data-kid=\"32\"></stop>\n                            </linearGradient>\n                        </defs>\n                    </svg>\n                    \n                    <div class=\"absolute inset-0 flex flex-col items-center justify-center translate-y-4\" data-kid=\"33\">\n                        <div class=\"flex items-baseline gap-2\" data-kid=\"34\">\n                            <span class=\"text-8xl md:text-9xl font-geist font-black tracking-tighter text-glow-success\" data-kid=\"35\">8.4</span>\n                            <span class=\"text-2xl font-bold text-white/20 uppercase tracking-widest\" data-kid=\"36\">Months</span>\n                        </div>\n                        <p class=\"text-[10px] font-black text-white/30 uppercase tracking-[0.4em] mt-2\" data-kid=\"37\">Calculated Resilience Runway</p>\n                    </div>\n                </div>\n\n                <div class=\"flex flex-wrap items-center justify-center gap-4\" data-kid=\"38\">\n                    <button class=\"px-8 py-4 bg-white text-black font-bold rounded-xl text-sm uppercase tracking-widest hover:bg-amber-500 transition-all flex items-center gap-2\" data-kid=\"39\">\n                        Bolster Reserve\n                        <i class=\"ti ti-arrow-right\" data-kid=\"40\"></i>\n                    </button>\n                    <button class=\"px-8 py-4 glass-highlight text-white font-bold rounded-xl text-sm uppercase tracking-widest hover:bg-white/5 transition-all\" data-kid=\"41\">\n                        Full Audit\n                    </button>\n                </div>\n            </div>\n        </section>\n\n        \n        <section class=\"py-24 px-6 container mx-auto\" data-kid=\"42\">\n            <div class=\"tactile-panel rounded-[3rem] p-1 shadow-2xl\" data-kid=\"43\">\n                <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-px bg-white/5\" data-kid=\"44\">\n                    \n                    \n                    <div class=\"lg:col-span-4 p-12 bg-white/[0.02] border-r border-white/5\" data-kid=\"45\">\n                        <div class=\"flex items-center gap-4 mb-10\" data-kid=\"46\">\n                            <div class=\"w-12 h-12 rounded-xl bg-emerald-500/10 flex items-center justify-center text-emerald-500 shadow-[inset_0_0_20px_rgba(34,197,94,0.1)]\" data-kid=\"47\">\n                                <i class=\"ti ti-bolt text-2xl\" data-kid=\"48\"></i>\n                            </div>\n                            <span class=\"text-[11px] font-black uppercase tracking-[0.2em] text-white/40\" data-kid=\"49\">Readiness</span>\n                        </div>\n                        <div class=\"flex items-baseline gap-3 mb-6\" data-kid=\"50\">\n                            <span class=\"text-7xl font-geist font-black\" data-kid=\"51\">92</span>\n                            <span class=\"text-emerald-500 font-bold\" data-kid=\"52\">/100</span>\n                        </div>\n                        <div class=\"w-full h-1 bg-white/5 rounded-full overflow-hidden mb-8\" data-kid=\"53\">\n                            <div class=\"h-full bg-emerald-500 w-[92%]\" data-kid=\"54\"></div>\n                        </div>\n                        <p class=\"text-sm text-white/40 leading-relaxed\" data-kid=\"55\">Your reserve positioning is <span class=\"text-white\" data-kid=\"56\">highly efficient</span> compared to local peers.</p>\n                    </div>\n\n                    \n                    <div class=\"lg:col-span-5 p-12\" data-kid=\"57\">\n                        <div class=\"flex items-center gap-3 mb-10\" data-kid=\"58\">\n                            <div class=\"w-10 h-10 rounded-lg bg-white/5 flex items-center justify-center text-white/60\" data-kid=\"59\">\n                                <i class=\"ti ti-chart-dots text-xl\" data-kid=\"60\"></i>\n                            </div>\n                            <span class=\"text-[10px] font-black uppercase tracking-widest text-white/30\" data-kid=\"61\">Burn Breakdown</span>\n                        </div>\n                        <div class=\"flex items-baseline gap-1 mb-10\" data-kid=\"62\">\n                            <span class=\"text-2xl font-bold text-white/20\" data-kid=\"63\">$</span>\n                            <span class=\"text-6xl font-geist font-black tracking-tighter\" data-kid=\"64\">4,250</span>\n                            <span class=\"text-white/20 text-xs font-bold uppercase ml-3\" data-kid=\"65\">Monthly Essentials</span>\n                        </div>\n                        <div class=\"space-y-4\" data-kid=\"66\">\n                            <div class=\"flex items-center justify-between text-xs font-bold\" data-kid=\"67\">\n                                <span class=\"text-white/40\" data-kid=\"68\">Housing & Utilities</span>\n                                <span data-kid=\"69\">$1,840</span>\n                            </div>\n                            <div class=\"w-full h-1 bg-white/5 rounded-full\" data-kid=\"70\">\n                                <div class=\"h-full bg-white/20 w-[43%]\" data-kid=\"71\"></div>\n                            </div>\n                            <div class=\"flex items-center justify-between text-xs font-bold\" data-kid=\"72\">\n                                <span class=\"text-white/40\" data-kid=\"73\">Recurring Services</span>\n                                <span data-kid=\"74\">$420</span>\n                            </div>\n                            <div class=\"w-full h-1 bg-white/5 rounded-full\" data-kid=\"75\">\n                                <div class=\"h-full bg-white/20 w-[10%]\" data-kid=\"76\"></div>\n                            </div>\n                        </div>\n                    </div>\n\n                    \n                    <div class=\"lg:col-span-3 p-12 bg-white/[0.02]\" data-kid=\"77\">\n                        <div class=\"flex items-center gap-3 mb-10\" data-kid=\"78\">\n                            <div class=\"w-10 h-10 rounded-lg bg-amber-500/10 flex items-center justify-center text-amber-500\" data-kid=\"79\">\n                                <i class=\"ti ti-shield-alert text-xl\" data-kid=\"80\"></i>\n                            </div>\n                            <span class=\"text-[10px] font-black uppercase tracking-widest text-white/30\" data-kid=\"81\">Volatility Index</span>\n                        </div>\n                        <div class=\"mb-10\" data-kid=\"82\">\n                            <div class=\"text-5xl font-geist font-black text-amber-500 mb-2\" data-kid=\"83\">LOW</div>\n                            <p class=\"text-[10px] font-black text-white/20 uppercase tracking-widest\" data-kid=\"84\">Aggregate Exposure</p>\n                        </div>\n                        <ul class=\"space-y-4\" data-kid=\"85\">\n                            <li class=\"flex items-center justify-between text-[10px] font-black\" data-kid=\"86\">\n                                <span class=\"text-white/30\" data-kid=\"87\">JOB STABILITY</span>\n                                <span class=\"text-emerald-500\" data-kid=\"88\">EXCELLENT</span>\n                            </li>\n                            <li class=\"flex items-center justify-between text-[10px] font-black\" data-kid=\"89\">\n                                <span class=\"text-white/30\" data-kid=\"90\">CASH FLOW</span>\n                                <span class=\"text-emerald-500\" data-kid=\"91\">STABLE</span>\n                            </li>\n                            <li class=\"flex items-center justify-between text-[10px] font-black\" data-kid=\"92\">\n                                <span class=\"text-white/30\" data-kid=\"93\">MARKET VOL</span>\n                                <span class=\"text-amber-500\" data-kid=\"94\">MODERATE</span>\n                            </li>\n                        </ul>\n                    </div>\n                </div>\n            </div>\n        </section>\n\n        \n        <section class=\"py-40 px-6 container mx-auto\" data-kid=\"95\">\n            <div class=\"flex flex-col md:flex-row md:items-end justify-between mb-16 gap-8\" data-kid=\"96\">\n                <div data-kid=\"97\">\n                    <h2 class=\"text-5xl font-geist font-black tracking-tight mb-4 uppercase\" data-kid=\"98\">Stress <span class=\"text-white/20\" data-kid=\"99\">Test</span></h2>\n                    <p class=\"text-white/40 text-lg max-w-lg\" data-kid=\"100\">Comparing normal growth against simulated total income loss.</p>\n                </div>\n                <div class=\"flex gap-4\" data-kid=\"101\">\n                    <button class=\"px-6 py-3 glass-highlight rounded-xl text-[10px] font-black uppercase tracking-widest\" data-kid=\"102\">Adjust Metrics</button>\n                    <button class=\"px-6 py-3 bg-amber-500 text-black rounded-xl text-[10px] font-black uppercase tracking-widest shadow-xl\" data-kid=\"103\">Run Simulator</button>\n                </div>\n            </div>\n\n            <div class=\"grid grid-cols-1 lg:grid-cols-2 gap-px bg-white/10 rounded-[4rem] overflow-hidden border border-white/5 shadow-2xl\" data-kid=\"104\">\n                \n                <div class=\"bg-fingo-graphite p-12 md:p-20 relative overflow-hidden\" style=\"background-color: #1E222A;\" data-kid=\"105\">\n                    <div class=\"relative z-10\" data-kid=\"106\">\n                        <div class=\"flex items-center gap-3 mb-12\" data-kid=\"107\">\n                            <div class=\"w-2.5 h-2.5 rounded-full bg-emerald-500\" data-kid=\"108\"></div>\n                            <span class=\"text-[10px] font-black uppercase tracking-widest text-emerald-500\" data-kid=\"109\">Safe Haven Trajectory</span>\n                        </div>\n                        <span class=\"text-white/20 text-[10px] font-bold uppercase block mb-4 tracking-widest\" data-kid=\"110\">Net Worth Forecast (12m)</span>\n                        <div class=\"text-6xl md:text-7xl font-geist font-black tracking-tighter mb-12 no-wrap\" data-kid=\"111\">$84,200</div>\n                        <div class=\"grid grid-cols-2 gap-4 mb-12\" data-kid=\"112\">\n                            <div class=\"p-6 bg-white/5 rounded-2xl border border-white/5\" data-kid=\"113\">\n                                <span class=\"text-emerald-500 text-xs font-bold\" data-kid=\"114\">+12.4%</span>\n                                <p class=\"text-[10px] text-white/30 uppercase font-black mt-1\" data-kid=\"115\">Growth</p>\n                            </div>\n                            <div class=\"p-6 bg-white/5 rounded-2xl border border-white/5\" data-kid=\"116\">\n                                <span class=\"text-white text-xs font-bold\" data-kid=\"117\">28%</span>\n                                <p class=\"text-[10px] text-white/30 uppercase font-black mt-1\" data-kid=\"118\">Save Rate</p>\n                            </div>\n                        </div>\n                        <p class=\"text-sm text-white/30 italic leading-relaxed border-l border-white/10 pl-6\" data-kid=\"119\">\"Continued accumulation phase. Retirement targets are currently 114% of required baseline.\"</p>\n                    </div>\n                </div>\n\n                \n                <div class=\"bg-fingo-graphite p-12 md:p-20 relative overflow-hidden\" style=\"background-color: #1E222A;\" data-kid=\"120\">\n                    <div class=\"absolute inset-0 bg-gradient-to-br from-amber-500/[0.03] to-transparent\" data-kid=\"121\"></div>\n                    <div class=\"relative z-10\" data-kid=\"122\">\n                        <div class=\"flex items-center gap-3 mb-12\" data-kid=\"123\">\n                            <div class=\"w-2.5 h-2.5 rounded-full bg-amber-500 animate-pulse\" data-kid=\"124\"></div>\n                            <span class=\"text-[10px] font-black uppercase tracking-widest text-amber-500\" data-kid=\"125\">Simulated Disruption</span>\n                        </div>\n                        <span class=\"text-white/20 text-[10px] font-bold uppercase block mb-4 tracking-widest\" data-kid=\"126\">Liquidity Depletion Point</span>\n                        <div class=\"text-6xl md:text-7xl font-geist font-black tracking-tighter text-amber-500 mb-12 no-wrap\" data-kid=\"127\">Nov 2025</div>\n                        <div class=\"grid grid-cols-2 gap-4 mb-12\" data-kid=\"128\">\n                            <div class=\"p-6 bg-amber-500/5 rounded-2xl border border-amber-500/10\" data-kid=\"129\">\n                                <span class=\"text-amber-500 text-xs font-bold\" data-kid=\"130\">$4.2k/mo</span>\n                                <p class=\"text-[10px] text-amber-500/30 uppercase font-black mt-1\" data-kid=\"131\">Burn Rate</p>\n                            </div>\n                            <div class=\"p-6 bg-amber-500/5 rounded-2xl border border-amber-500/10\" data-kid=\"132\">\n                                <span class=\"text-amber-500 text-xs font-bold\" data-kid=\"133\">254 Days</span>\n                                <p class=\"text-[10px] text-amber-500/30 uppercase font-black mt-1\" data-kid=\"134\">Coverage</p>\n                            </div>\n                        </div>\n                        <p class=\"text-sm text-white/30 italic leading-relaxed border-l border-amber-500/20 pl-6\" data-kid=\"135\">\"Discretionary funds dry up first. Essential coverage remains stable through early winter.\"</p>\n                    </div>\n                </div>\n            </div>\n        </section>\n\n        \n        <section class=\"py-40 px-6 container mx-auto\" data-kid=\"136\">\n            <div class=\"tactile-panel rounded-[4rem] p-16 md:p-24 relative overflow-hidden\" data-kid=\"137\">\n                \n                <div class=\"absolute top-[-40%] left-[60%] w-[50%] h-[180%] bg-[linear-gradient(180deg,rgba(255,129,43,0.1),transparent)] transform -rotate-15 pointer-events-none opacity-50\" data-kid=\"138\"></div>\n                \n                <div class=\"relative z-10\" data-kid=\"139\">\n                    <div class=\"mb-24\" data-kid=\"140\">\n                        <h2 class=\"text-4xl font-geist font-black tracking-tight mb-4 uppercase\" data-kid=\"141\">Impact <span class=\"text-white/20\" data-kid=\"142\">Timeline</span></h2>\n                        <p class=\"text-white/40 text-lg\" data-kid=\"143\">Detailed trajectory of depletion following total disruption.</p>\n                    </div>\n\n                    \n                    <div class=\"relative h-2 bg-white/5 rounded-full mb-48\" data-kid=\"144\">\n                        <div class=\"absolute left-0 h-full w-[65%] bg-gradient-to-r from-emerald-500 to-amber-500 rounded-full\" data-kid=\"145\"></div>\n                        \n                        \n                        <div class=\"absolute left-0 top-1/2 -translate-y-1/2 -translate-x-1/2 flex flex-col items-center\" data-kid=\"146\">\n                            <div class=\"w-5 h-5 bg-white rounded-full shadow-[0_0_20px_rgba(255,255,255,0.4)] border-4 border-[#1E222A]\" data-kid=\"147\"></div>\n                            <div class=\"mt-12 text-center\" data-kid=\"148\">\n                                <span class=\"block text-[10px] font-black text-white/50 uppercase tracking-widest whitespace-nowrap mb-1\" data-kid=\"149\">MAR 2025</span>\n                                <span class=\"block text-xs font-bold text-white tracking-widest\" data-kid=\"150\">DISRUPTION</span>\n                            </div>\n                        </div>\n\n                        <div class=\"absolute left-[32%] top-1/2 -translate-y-1/2 -translate-x-1/2\" data-kid=\"151\">\n                            <div class=\"w-3 h-3 bg-white/40 rounded-full shadow-[0_0_10px_rgba(255,255,255,0.1)]\" data-kid=\"152\"></div>\n                            <span class=\"absolute top-10 left-1/2 -translate-x-1/2 text-[10px] font-black text-white/20 tracking-widest uppercase no-wrap\" data-kid=\"153\">JUN 2025</span>\n                        </div>\n\n                        \n                        <div class=\"absolute left-[65%] top-1/2 -translate-y-1/2 -translate-x-1/2 flex flex-col items-center\" data-kid=\"154\">\n                            <div class=\"relative w-12 h-12 flex items-center justify-center\" data-kid=\"155\">\n                                <div class=\"absolute inset-0 bg-amber-500 rounded-full animate-ping opacity-10\" data-kid=\"156\"></div>\n                                <div class=\"w-10 h-10 rounded-full bg-amber-500 flex items-center justify-center border-4 border-[#1E222A] shadow-[0_0_40px_rgba(255,129,43,0.5)]\" data-kid=\"157\">\n                                    <i class=\"ti ti-alert-triangle text-black text-xl\" data-kid=\"158\"></i>\n                                </div>\n                            </div>\n                            <div class=\"mt-16 text-center\" data-kid=\"159\">\n                                <span class=\"block text-3xl font-geist font-black text-amber-500 leading-none\" data-kid=\"160\">NOV 12, 2025</span>\n                                <span class=\"block text-[9px] font-black text-white/30 uppercase tracking-[0.4em] mt-3\" data-kid=\"161\">ZERO BALANCE EVENT</span>\n                            </div>\n                        </div>\n\n                        <div class=\"absolute left-[100%] top-1/2 -translate-y-1/2 -translate-x-1/2\" data-kid=\"162\">\n                            <div class=\"w-2.5 h-2.5 bg-white/5 border border-white/10 rounded-full\" data-kid=\"163\"></div>\n                            <span class=\"absolute top-8 left-1/2 -translate-x-1/2 text-[9px] font-black text-white/10 tracking-widest uppercase no-wrap\" data-kid=\"164\">FEB 2026</span>\n                        </div>\n                    </div>\n\n                    \n                    <div class=\"grid grid-cols-1 lg:grid-cols-2 gap-12 items-center\" data-kid=\"165\">\n                        <div class=\"p-10 bg-white/[0.02] rounded-[3rem] border border-white/5 relative overflow-hidden group\" data-kid=\"166\">\n                            <div class=\"absolute top-0 right-0 p-8 opacity-10 group-hover:opacity-100 transition-opacity\" data-kid=\"167\">\n                                <i class=\"ti ti-cpu text-3xl text-amber-500\" data-kid=\"168\"></i>\n                            </div>\n                            <h4 class=\"text-[9px] font-black text-white/20 uppercase tracking-[0.4em] mb-6\" data-kid=\"169\">AI Extension Protocol</h4>\n                            <p class=\"text-2xl text-white/80 leading-tight mb-8\" data-kid=\"170\">\n                                Automating a <span class=\"text-emerald-500 font-bold\" data-kid=\"171\">15% spend cut</span> today extends your survival until <span class=\"text-white font-bold\" data-kid=\"172\">Jan 2026</span>.\n                            </p>\n                            <button class=\"px-6 py-3 bg-white text-black rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-emerald-500 transition-all\" data-kid=\"173\">Enable Auto-Pilot</button>\n                        </div>\n\n                        <div class=\"flex flex-col md:flex-row items-center gap-8 px-8 py-10 bg-white/[0.03] rounded-[3rem] border border-white/5\" data-kid=\"174\">\n                            <div class=\"relative shrink-0 group\" data-kid=\"175\">\n                                <div class=\"absolute inset-[-10px] bg-amber-500/10 rounded-full blur-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-700\" data-kid=\"176\"></div>\n                                <img src=\"https://images.pexels.com/photos/8294598/pexels-photo-8294598.jpeg?auto=compress&cs=tinysrgb&w=300&q=80\" alt=\"Companion\" class=\"relative w-28 h-28 rounded-full object-cover border-2 border-white/20 shadow-2xl transition-all duration-700\" data-kid=\"177\">\n                                <div class=\"absolute bottom-1 right-1 w-6 h-6 bg-emerald-500 rounded-full border-4 border-[#1E222A] flex items-center justify-center\" data-kid=\"178\">\n                                    <div class=\"w-1.5 h-1.5 bg-white rounded-full animate-pulse\" data-kid=\"179\"></div>\n                                </div>\n                            </div>\n                            <div class=\"text-center md:text-left\" data-kid=\"180\">\n                                <p class=\"text-white/40 italic text-base leading-relaxed mb-6\" data-kid=\"181\">\"I've identified $840 in luxury outflow that can be paused instantly. Ready to execute?\"</p>\n                                <div class=\"flex gap-3 justify-center md:justify-start\" data-kid=\"182\">\n                                    <button class=\"px-5 py-2 bg-amber-500 text-black text-[9px] font-black uppercase tracking-widest rounded-lg\" data-kid=\"183\">Proceed</button>\n                                    <button class=\"px-5 py-2 bg-white/5 text-white/40 text-[9px] font-black uppercase tracking-widest rounded-lg border border-white/10\" data-kid=\"184\">Full List</button>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </section>\n\n        \n        <section class=\"py-40 text-center px-6\" data-kid=\"185\">\n            <h2 class=\"text-2xl font-geist font-bold text-white/10 mb-20 uppercase tracking-[0.2em]\" data-kid=\"186\">Build Your Shield.</h2>\n            <div class=\"flex items-center justify-center gap-12 mb-32 opacity-20\" data-kid=\"187\">\n                <div class=\"w-12 h-px bg-white\" data-kid=\"188\"></div>\n                <div class=\"font-cormorant text-xl italic text-white/80\" data-kid=\"189\">Precision is the only security.</div>\n                <div class=\"w-12 h-px bg-white\" data-kid=\"190\"></div>\n            </div>\n            <div class=\"text-[9px] font-black text-white/5 uppercase tracking-[1em] pb-10\" data-kid=\"191\">FINGO &bull; AUTOMATED RESILIENCE &bull; 2025</div>\n        </section>\n    </div>\n</div>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"192\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"193\"></script>\n<script type=\"module\" data-kid=\"194\">\n    import Lenis from \"https://esm.sh/lenis@1\"\n    \n    gsap.registerPlugin(ScrollTrigger);\n\n    // Initialize Lenis\n    const lenis = new Lenis({\n        duration: 1.2,\n        smoothWheel: true,\n        wheelMultiplier: 1.1\n    });\n\n    function raf(time) {\n        lenis.raf(time);\n        requestAnimationFrame(raf);\n    }\n    requestAnimationFrame(raf);\n\n    // Gauge Entrance\n    gsap.to(\"#survival-gauge-path\", {\n        strokeDashoffset: 126 * (1 - 0.84),\n        duration: 2.5,\n        ease: \"expo.out\",\n        scrollTrigger: {\n            trigger: \"#gauge-container\",\n            start: \"top 80%\",\n        }\n    });\n\n    // Sections Entrance\n    gsap.from(\".tactile-panel\", {\n        y: 60,\n        opacity: 0,\n        duration: 1.2,\n        stagger: 0.3,\n        ease: \"power4.out\",\n        scrollTrigger: {\n            trigger: \".tactile-panel\",\n            start: \"top 85%\",\n        }\n    });\n\n</script>\n",
