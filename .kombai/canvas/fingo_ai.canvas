      "html": "\n<style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@600;700&family=Geist:wght@400;600;700&family=Inter:wght@400;500;600;700&display=swap');\n\n    :root {\n        --color-bg: #0F1115;\n        --color-surface: #171A20;\n        --color-emerald: #076653;\n        --color-emerald-light: #0F8A6B;\n        --color-amber: #FF812B;\n    }\n\n    body {\n        background-color: var(--color-bg);\n        color: white;\n        font-family: 'Inter', sans-serif;\n        margin: 0;\n        overflow-x: clip;\n    }\n\n    .font-cormorant { font-family: 'Cormorant Garamond', serif; }\n    .font-geist { font-family: 'Geist', sans-serif; }\n\n    .glass-card {\n        background: rgba(23, 26, 32, 0.6);\n        backdrop-filter: blur(12px);\n        border: 1px solid rgba(255, 255, 255, 0.05);\n        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);\n    }\n\n    .glass-card-highlight {\n        background: radial-gradient(circle at top right, rgba(16, 185, 129, 0.1), transparent), rgba(23, 26, 32, 0.8);\n        border: 1px solid rgba(16, 185, 129, 0.2);\n    }\n\n    .emerald-glow {\n        box-shadow: 0 0 20px rgba(15, 138, 107, 0.3);\n    }\n\n    /* Custom range input styling */\n    input[type=range]::-webkit-slider-thumb {\n        -webkit-appearance: none;\n        height: 16px;\n        width: 16px;\n        border-radius: 50%;\n        background: var(--color-amber);\n        cursor: pointer;\n        box-shadow: 0 0 10px rgba(255, 129, 43, 0.4);\n        margin-top: -6px;\n    }\n\n    input[type=range]::-webkit-slider-runnable-track {\n        width: 100%;\n        height: 4px;\n        cursor: pointer;\n        background: rgba(255, 255, 255, 0.1);\n        border-radius: 2px;\n    }\n\n    /* Hide scrollbar */\n    .no-scrollbar::-webkit-scrollbar { display: none; }\n    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }\n</style>\n\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" data-kid=\"1\">\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"2\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"3\"></script>\n\n<div class=\"flex h-screen overflow-hidden\" data-kid=\"4\">\n    \n    <aside class=\"w-64 bg-[#171A20] border-r border-white/5 flex flex-col p-6 shrink-0\" data-kid=\"5\">\n        <div class=\"mb-12 flex items-center gap-2\" data-kid=\"6\">\n            <div class=\"w-8 h-8 bg-emerald-500 rounded-lg flex items-center justify-center\" data-kid=\"7\">\n                <i class=\"ti ti-chart-pie-3 text-white\" data-kid=\"8\"></i>\n            </div>\n            <span class=\"text-2xl font-cormorant font-bold tracking-tight\" data-kid=\"9\">Fingo AI</span>\n        </div>\n\n        <nav class=\"flex-1 space-y-2\" data-kid=\"10\">\n            <a href=\"#\" class=\"flex items-center gap-3 px-4 py-3 text-white/50 hover:text-white hover:bg-white/5 rounded-xl transition-all group\" data-kid=\"11\">\n                <i class=\"ti ti-layout-dashboard text-xl group-hover:text-emerald-400\" data-kid=\"12\"></i>\n                <span class=\"font-medium\" data-kid=\"13\">Overview</span>\n            </a>\n            <a href=\"#\" class=\"flex items-center gap-3 px-4 py-3 text-white/50 hover:text-white hover:bg-white/5 rounded-xl transition-all group\" data-kid=\"14\">\n                <i class=\"ti ti-arrows-left-right text-xl group-hover:text-emerald-400\" data-kid=\"15\"></i>\n                <span class=\"font-medium\" data-kid=\"16\">Transactions</span>\n            </a>\n            <a href=\"#\" class=\"flex items-center gap-3 px-4 py-3 bg-emerald-500/10 text-emerald-400 rounded-xl transition-all group border border-emerald-500/20\" data-kid=\"17\">\n                <i class=\"ti ti-target-arrow text-xl\" data-kid=\"18\"></i>\n                <span class=\"font-medium\" data-kid=\"19\">Goals Tracker</span>\n            </a>\n            <a href=\"#\" class=\"flex items-center gap-3 px-4 py-3 text-white/50 hover:text-white hover:bg-white/5 rounded-xl transition-all group\" data-kid=\"20\">\n                <i class=\"ti ti-wallet text-xl group-hover:text-emerald-400\" data-kid=\"21\"></i>\n                <span class=\"font-medium\" data-kid=\"22\">Budget</span>\n            </a>\n            <a href=\"#\" class=\"flex items-center gap-3 px-4 py-3 text-white/50 hover:text-white hover:bg-white/5 rounded-xl transition-all group\" data-kid=\"23\">\n                <i class=\"ti ti-robot text-xl group-hover:text-emerald-400\" data-kid=\"24\"></i>\n                <span class=\"font-medium\" data-kid=\"25\">AI Coach</span>\n            </a>\n        </nav>\n\n        <div class=\"p-5 rounded-2xl bg-white/5 border border-white/10 mt-auto shadow-inner\" data-kid=\"26\">\n            <p class=\"text-[10px] text-white/30 uppercase tracking-[0.2em] mb-4 font-bold\" data-kid=\"27\">Premium Tier</p>\n            <div class=\"flex items-center gap-4 mb-4\" data-kid=\"28\">\n                <div class=\"w-12 h-12 rounded-xl bg-linear-to-br from-emerald-500/20 to-emerald-800/20 flex items-center justify-center border border-emerald-500/30 shadow-[0_0_15px_rgba(16,185,129,0.15)]\" data-kid=\"29\">\n                    <i class=\"ti ti-crown text-emerald-400 text-xl\" data-kid=\"30\"></i>\n                </div>\n                <div data-kid=\"31\">\n                    <p class=\"text-sm font-bold text-white/90\" data-kid=\"32\">Gold Member</p>\n                    <p class=\"text-[11px] text-white/40\" data-kid=\"33\">Renew in 12 days</p>\n                </div>\n            </div>\n            <button class=\"w-full py-2.5 bg-emerald-500/10 hover:bg-emerald-500/20 text-emerald-400 text-xs font-bold rounded-xl transition-all border border-emerald-500/20\" data-kid=\"34\">Manage Benefits</button>\n        </div>\n    </aside>\n\n    \n    <main class=\"flex-1 flex flex-col min-w-0 bg-[#0F1115] relative\" data-kid=\"35\">\n        <div class=\"absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(15,138,107,0.05),transparent_70%)] pointer-events-none\" data-kid=\"36\"></div>\n        \n        <header class=\"h-20 border-b border-white/5 flex items-center justify-between px-10 bg-[#0F1115]/50 backdrop-blur-md sticky top-0 z-50\" data-kid=\"37\">\n            <div class=\"flex items-center gap-4 bg-white/5 px-4 py-2 rounded-xl border border-white/10 w-96\" data-kid=\"38\">\n                <i class=\"ti ti-search text-white/40\" data-kid=\"39\"></i>\n                <input type=\"text\" placeholder=\"Search goals, assets, insights...\" class=\"bg-transparent border-none outline-hidden text-sm w-full text-white placeholder:text-white/20\" data-kid=\"40\">\n            </div>\n            <div class=\"flex items-center gap-6\" data-kid=\"41\">\n                <button class=\"text-white/40 hover:text-white relative\" data-kid=\"42\">\n                    <i class=\"ti ti-bell text-2xl\" data-kid=\"43\"></i>\n                    <span class=\"absolute top-0 right-0 w-2 h-2 bg-amber-500 rounded-full border-2 border-[#0F1115]\" data-kid=\"44\"></span>\n                </button>\n                <div class=\"flex items-center gap-3 pl-6 border-l border-white/10\" data-kid=\"45\">\n                    <div class=\"text-right\" data-kid=\"46\">\n                        <p class=\"text-sm font-bold\" data-kid=\"47\">Alex Rivera</p>\n                        <p class=\"text-[10px] text-white/40\" data-kid=\"48\">Pro Account</p>\n                    </div>\n                    <img src=\"https://i.pravatar.cc/100?u=alex\" alt=\"Avatar\" class=\"w-10 h-10 rounded-xl border border-white/10\" decoding=\"async\" loading=\"lazy\" data-kid=\"49\">\n                </div>\n            </div>\n        </header>\n\n        \n        <div class=\"flex-1 overflow-y-auto no-scrollbar p-10 space-y-12\" data-kid=\"50\">\n            \n            <div class=\"flex justify-between items-end\" data-kid=\"51\">\n                <div class=\"space-y-2\" data-kid=\"52\">\n                    <h1 class=\"text-4xl font-geist font-bold tracking-tight\" data-kid=\"53\">Financial Goals</h1>\n                    <p class=\"text-white/50 text-lg\" data-kid=\"54\">Visualizing your path to financial freedom through AI analysis.</p>\n                </div>\n                <button class=\"px-6 py-3 bg-linear-to-r from-emerald-600 to-emerald-500 hover:from-emerald-500 hover:to-emerald-400 text-white rounded-xl font-bold flex items-center gap-2 transition-all shadow-[0_10px_20px_rgba(16,185,129,0.2)] active:scale-95\" data-kid=\"55\">\n                    <i class=\"ti ti-plus\" data-kid=\"56\"></i> New Goal\n                </button>\n            </div>\n\n            \n            <div class=\"grid grid-cols-4 gap-6\" data-kid=\"57\">\n                <div class=\"p-6 rounded-3xl bg-white/5 border border-white/5 flex flex-col justify-between group hover:bg-white/[0.07] transition-colors\" data-kid=\"58\">\n                    <p class=\"text-[10px] text-white/30 font-bold uppercase tracking-widest mb-4\" data-kid=\"59\">Total Goal Value</p>\n                    <div class=\"flex items-end justify-between\" data-kid=\"60\">\n                        <h3 class=\"text-3xl font-geist font-bold\" data-kid=\"61\">$2.26M</h3>\n                        <div class=\"w-12 h-6 bg-emerald-500/10 border border-emerald-500/20 rounded flex items-center justify-center\" data-kid=\"62\">\n                            <i class=\"ti ti-trending-up text-emerald-400 text-xs\" data-kid=\"63\"></i>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"p-6 rounded-3xl bg-emerald-500/5 border border-emerald-500/10 flex flex-col justify-between\" data-kid=\"64\">\n                    <p class=\"text-[10px] text-emerald-400/50 font-bold uppercase tracking-widest mb-4\" data-kid=\"65\">Saved So Far</